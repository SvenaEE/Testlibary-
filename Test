				G2L[mlKey].Position = UDim2.new(1, -10, 1, -14);
				G2L[mlKey].Size = UDim2.new(0.44, 0, 0, 12);
				G2L[mlKey].BackgroundTransparency = 1;
				G2L[mlKey].ZIndex = 8;
				G2L[mlKey].Parent = r;

				local kbE = KBAdd(name, key);

				local function updateDisplay()
					G2L[kbKey].Text = key and key.Name or "None";
					G2L[mlKey].Text = "● " .. mode;
					G2L[mlKey].TextColor3 = mode == "Toggle" and T.TxMut or mode == "Hold" and T.Accent or T.Warn;
				end

				G2L[kbKey].MouseButton1Click:Connect(function()
					if mode == "Always On" then return; end
					binding = true;
					G2L[kbKey].Text = "...";
					G2L[kbKey].TextColor3 = T.Warn;
				end);

				r.InputBegan:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton2 then
						MakeCtxMenu(r, {"Toggle", "Hold", "Always On"}, function() return mode; end, function(picked)
							mode = picked;
							updateDisplay();
							if mode == "Always On" and cb then task.spawn(cb, true); end
						end);
					end
				end);

				UserInputService.InputBegan:Connect(function(i, gp)
					if binding and not gp then
						binding = false;
						key = i.KeyCode;
						G2L[kbKey].TextColor3 = T.Accent;
						KBUpdate(kbE, key);
						updateDisplay();
						return;
					end
					if not key or i.KeyCode ~= key or gp then return; end
					if mode == "Toggle" then
						if cb then task.spawn(cb, key); end
					elseif mode == "Hold" then
						if cb then task.spawn(cb, true); end
					end
				end);

				UserInputService.InputEnded:Connect(function(i)
					if not key or i.KeyCode ~= key then return; end
					if mode == "Hold" and cb then task.spawn(cb, false); end
				end);

				updateDisplay();

				return {
					Get = function(_) return key; end;
					GetMode = function(_) return mode; end;
					Set = function(_, k) key = k; KBUpdate(kbE, k); updateDisplay(); end;
				};
			end

