        local ttl=opts.Title or "Notice"
        local msg=opts.Message or ""
        local dur=opts.Duration or 4
        local T=self._T
        local card=New("Frame",{
            Size=UDim2.new(1,0,0,56),BackgroundColor3=T.Panel,
            BackgroundTransparency=0.04,ClipsDescendants=true,
            ZIndex=601,Parent=self._notifHolder,
        })
        Crn(6,card); Stk(T.Border,1,card)
        New("Frame",{Size=UDim2.new(0,2,1,0),BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=602,Parent=card})
        New("TextLabel",{
            Text=ttl,Font=Enum.Font.GothamBold,TextSize=11,TextColor3=T.TextPrim,
            TextXAlignment=Enum.TextXAlignment.Left,
            Position=UDim2.new(0,10,0,6),Size=UDim2.new(1,-14,0,14),
            BackgroundTransparency=1,ZIndex=603,Parent=card,
        })
        New("TextLabel",{
            Text=msg,Font=Enum.Font.Gotham,TextSize=10,TextColor3=T.TextSec,
            TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,
            Position=UDim2.new(0,10,0,22),Size=UDim2.new(1,-14,0,26),
            BackgroundTransparency=1,ZIndex=603,Parent=card,
        })
        local prog=New("Frame",{
            Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),
            BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=604,Parent=card,
        })
        Tw(prog,{Size=UDim2.new(0,0,0,2)},dur,Enum.EasingStyle.Linear):Play()
        card.Position=UDim2.new(1,10,0,0)
        Tw(card,{Position=UDim2.new(0,0,0,0)},0.26):Play()
        task.delay(dur,function()
            Tw(card,{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0)},0.2):Play()
            task.delay(0.22,function() card:Destroy() end)
        end)
    end

    return Win
end

return Lib
