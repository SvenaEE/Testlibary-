-- ── makToggleRow: a simple toggle row inside any panel ────────────────────────
local function makeToggleRow(parent, label, fontSize, default, callback)
	local state = (default == true);

	local G2L_row = Instance.new("Frame", parent);
	G2L_row["Name"]             = [[Toggle_]] .. label;
	G2L_row["Size"]             = UDim2.new(1, 0, 0, fontSize == 12 and 28 or 32);
	G2L_row["BackgroundColor3"] = fontSize == 12
		and Color3.fromRGB(18, 18, 24)
		or  Color3.fromRGB(14, 14, 19);
	G2L_row["BorderSizePixel"]  = 0;
	G2L_row["LayoutOrder"]      = #parent:GetChildren();
	G2L_row["Active"]           = true;
	local G2L_rc = Instance.new("UICorner", G2L_row);
	G2L_rc["CornerRadius"] = UDim.new(0, fontSize == 12 and 5 or 6);
	addHoverFx(G2L_row);

	local G2L_lbl = Instance.new("TextLabel", G2L_row);
	G2L_lbl["Size"]                  = UDim2.new(1, -50, 1, 0);
	G2L_lbl["Position"]              = UDim2.new(0, fontSize == 12 and 8 or 10, 0, 0);
	G2L_lbl["BackgroundTransparency"] = 1;
	G2L_lbl["BorderSizePixel"]       = 0;
	G2L_lbl["FontFace"]              = G2L["FONT_JOSEFIN"];
	G2L_lbl["TextSize"]              = fontSize;
	G2L_lbl["TextColor3"]            = fontSize == 12
		and Color3.fromRGB(180, 180, 200)
		or  Color3.fromRGB(200, 200, 215);
	G2L_lbl["TextXAlignment"]        = Enum.TextXAlignment.Left;
	G2L_lbl["Text"]                  = label;

	local G2L_track, _, setPill = makePill(G2L_row, state);
	G2L_track["Position"] = UDim2.new(1, fontSize == 12 and -40 or -44, 0.5, -9);

	local function set(newState)
		state = newState;
		setPill(state);
		if callback then callback(state) end;
	end;

	G2L_row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			set(not state);
		end;
	end);

	if callback then callback(state) end;
	return set;
end;

