local kbList    = {}
local kbRebuild = nil

local function kbAdd(label, key)
	local entry = { label = label, keyName = key and key.Name or "None" }
	table.insert(kbList, entry)
	if kbRebuild then kbRebuild() end
	return entry
end

local function kbUpdate(entry, key)
	entry.keyName = key and key.Name or "None"
	if kbRebuild then kbRebuild() end
end

local activeCtx = nil

local function closeCtx()
	if activeCtx then
		activeCtx:Destroy()
		activeCtx = nil
	end
end

UserInputService.InputBegan:Connect(function(input, gp)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		task.defer(closeCtx)
	end
end)

local function openCtxMenu(parent, options, getCurrent, onPick)
	closeCtx()

	local menu = make("Frame", parent, {
		Size             = UDim2.new(0, 120, 0, #options * 26 + 8),
		Position         = UDim2.new(1, -120, 1, 4),
		BackgroundColor3 = col.panel,
		BorderSizePixel  = 0,
		ZIndex           = 200,
	})
	corner(6, menu)
	stroke(col.border, 1, menu)
	pad(4, 4, 4, 4, menu)
	vlist(menu, 2)
	activeCtx = menu

	for _, opt in ipairs(options) do
		local current = (opt == getCurrent())

		local btn = make("TextButton", menu, {
			Text                   = opt,
			Font                   = Enum.Font.Gotham,
			TextSize               = 11,
			TextColor3             = current and col.accent or col.txprim,
			TextXAlignment         = Enum.TextXAlignment.Left,
			Size                   = UDim2.new(1, 0, 0, 24),
			BackgroundColor3       = col.hover,
			BackgroundTransparency = 1,
			AutoButtonColor        = false,
			ZIndex                 = 201,
		})
		corner(4, btn)
		pad(10, 6, 0, 0, btn)

		if current then
			make("Frame", btn, {
				Size             = UDim2.new(0, 4, 0, 4),
				AnchorPoint      = Vector2.new(1, 0.5),
				Position         = UDim2.new(1, -6, 0.5, 0),
				BackgroundColor3 = col.accent,
				BorderSizePixel  = 0,
				ZIndex           = 202,
			})
		end

		btn.MouseEnter:Connect(function()
			tween(btn, { BackgroundTransparency = 0 }, 0.1)
		end)
		btn.MouseLeave:Connect(function()
			tween(btn, { BackgroundTransparency = 1 }, 0.1)
		end)

		local captured = opt
		btn.MouseButton1Click:Connect(function()
			closeCtx()
			onPick(captured)
		end)
	end
end

