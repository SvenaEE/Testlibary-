		ZIndex                 = 502,
	})
	pad(10, 12, 0, 0, wmLbl)

	local fpsA, fpsC, fpsV, lastWM = 0, 0, 60, 0
	local function updateWM()
		local ok, ping = pcall(function() return lp:GetNetworkPing() end)
		local p = ok and math.round((ping or 0) * 1000) or 0
		local t = os.date("*t")
		wmLbl.Text = string.format(
			" %s  |  %s  |  FPS: %d  |  Ping: %dms  |  %02d:%02d ",
			title, lp.Name, fpsV, p, t.hour, t.min
		)
	end

	RunService.Heartbeat:Connect(function(dt)
		fpsA = fpsA + (1 / dt)
		fpsC = fpsC + 1
		if fpsC >= 20 then
			fpsV = math.floor(fpsA / fpsC)
			fpsA = 0
			fpsC = 0
		end
		local now = os.clock()
		if now - lastWM >= 1 then
			lastWM = now
			updateWM()
		end
	end)
	updateWM()

