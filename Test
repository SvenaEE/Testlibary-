		if inputState ~= Enum.UserInputState.Begin then return end;
		if isTweening then return end;
		if isVisible then
			for _, tab in ipairs(tabs) do homePos[tab] = tab.Position end;
			isVisible = false;
			slideAll(G2L["TWEEN_OUT"], hiddenPos, function()
				G2L["layout"]["Visible"] = false;
			end);
		else
			for _, tab in ipairs(tabs) do tab["Position"] = hiddenPos(tab) end;
			G2L["layout"]["Visible"] = true;
			isVisible = true;
			slideAll(G2L["TWEEN_IN"], function(tab) return homePos[tab] or tab.Position end);
		end;
	end, false, Enum.KeyCode.Insert);

