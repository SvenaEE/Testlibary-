	local G2L_abc = Instance.new("UICorner", G2L_alphabar);
	G2L_abc["CornerRadius"] = UDim.new(0, 4);

	-- Checkerboard pattern to show transparency
	local G2L_checker = Instance.new("ImageLabel", G2L_alphabar);
	G2L_checker["Size"]                = UDim2.new(1, 0, 1, 0);
