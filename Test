    -- ════════════════════════════════════════════════════════════
    --  Notify
    -- ════════════════════════════════════════════════════════════
    function Window:Notify(opts)
        opts=opts or {}
        local title=opts.Title or "Notice"
        local msg=opts.Message or ""
        local dur=opts.Duration or 4
        local T=self._T

        local card=New("Frame",{
            Size=UDim2.new(1,0,0,58),
            BackgroundColor3=T.Panel,
            BackgroundTransparency=0.05,
            ClipsDescendants=true, ZIndex=301,
            Parent=self._notifHolder,
        })
        Corner(7,card); Stroke(T.Border,1,card)
        New("Frame",{Size=UDim2.new(0,2,1,0), BackgroundColor3=T.Accent, BorderSizePixel=0, ZIndex=302, Parent=card})
        New("TextLabel",{
            Text=title, Font=Enum.Font.GothamBold, TextSize=12, TextColor3=T.TextPrim,
            TextXAlignment=Enum.TextXAlignment.Left,
            Position=UDim2.new(0,11,0,7), Size=UDim2.new(1,-15,0,15),
            BackgroundTransparency=1, ZIndex=303, Parent=card,
        })
        New("TextLabel",{
            Text=msg, Font=Enum.Font.Gotham, TextSize=11, TextColor3=T.TextSec,
            TextXAlignment=Enum.TextXAlignment.Left, TextWrapped=true,
            Position=UDim2.new(0,11,0,24), Size=UDim2.new(1,-15,0,26),
            BackgroundTransparency=1, ZIndex=303, Parent=card,
        })
        local prog=New("Frame",{
            Size=UDim2.new(1,0,0,2), Position=UDim2.new(0,0,1,-2),
            BackgroundColor3=T.Accent, BorderSizePixel=0, ZIndex=304, Parent=card,
        })
        Tween(prog,{Size=UDim2.new(0,0,0,2)},dur,Enum.EasingStyle.Linear):Play()
        card.Position=UDim2.new(1,10,0,0)
        Tween(card,{Position=UDim2.new(0,0,0,0)},0.28):Play()
        task.delay(dur,function()
            Tween(card,{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0)},0.22):Play()
            task.delay(0.25,function() card:Destroy() end)
        end)
    end

    return Window
end

