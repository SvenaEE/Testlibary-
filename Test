                -- ── AddKeybind ────────────────────────────────
                function SEC:AddKeybind(text, default, cb)
                    local key=default; local binding=false
                    local r = Row()
                    RowLbl(r, text)
                    local kBtn = New("TextButton", {
                        Text=key and key.Name or "None",
                        Font=Enum.Font.GothamBold, TextSize=9,
                        TextColor3=T.Accent,
                        Size=UDim2.new(0.44,0,0,20),
                        AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=T.Surface,
                        AutoButtonColor=false, ZIndex=8, Parent=r,
                    })
                    Corner(4,kBtn)
                    Stroke(T.Border,1,kBtn)
                    kBtn.MouseButton1Click:Connect(function()
                        binding=true; kBtn.Text="..."; kBtn.TextColor3=T.Warning
                    end)
                    UserInputService.InputBegan:Connect(function(i,gp)
                        if binding and not gp then
                            binding=false; key=i.KeyCode
                            kBtn.Text=key.Name; kBtn.TextColor3=T.Accent
                        elseif not binding and key and i.KeyCode==key then
                            task.spawn(cb,key)
                        end
                    end)
                    refresh()
                    return {
                        Get=function(_) return key end,
                        Set=function(_,k) key=k; kBtn.Text=k and k.Name or "None" end,
                    }
                end

                -- ── AddColorPicker ────────────────────────────
                function SEC:AddColorPicker(text, default, cb)
                    local color=default or Color3.fromRGB(255,50,50)
                    local open=false; local h,s,v=color:ToHSV()
                    local r=Row()
                    RowLbl(r,text)

                    local swatch=New("TextButton",{
                        Text="", Size=UDim2.new(0,26,0,16),
                        AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=color,
                        AutoButtonColor=false, ZIndex=8, Parent=r,
                    })
                    Corner(4,swatch); Stroke(T.Border,1,swatch)

                    local pp=New("Frame",{
                        Size=UDim2.new(0,160,0,136),
                        AnchorPoint=Vector2.new(1,0), Position=UDim2.new(1,-10,1,4),
                        BackgroundColor3=T.Panel,
                        BorderSizePixel=0, Visible=false, ZIndex=60, Parent=r,
                    })
                    Corner(8,pp); Stroke(T.Border,1,pp); Pad(7,7,7,7,pp)

                    local hueBar=New("ImageLabel",{
                        Image="rbxassetid://2615689002",
                        Size=UDim2.new(1,0,0,13),
                        BackgroundTransparency=1, ZIndex=61, Parent=pp,
                    })
                    Corner(4,hueBar)
                    local hC=New("Frame",{
                        Size=UDim2.new(0,4,1,4),
                        AnchorPoint=Vector2.new(0.5,0.5),
                        Position=UDim2.new(h,0,0.5,0),
                        BackgroundColor3=Color3.new(1,1,1),
                        ZIndex=62, Parent=hueBar,
                    })
                    Corner(2,hC)

                    local svC=New("ImageLabel",{
                        Image="rbxassetid://2615689003",
                        Size=UDim2.new(1,0,0,88),
                        Position=UDim2.new(0,0,0,20),
                        BackgroundColor3=Color3.fromHSV(h,1,1),
                        ZIndex=61, Parent=pp,
                    })
                    Corner(4,svC)
                    local svK=New("Frame",{
                        Size=UDim2.new(0,8,0,8),
                        AnchorPoint=Vector2.new(0.5,0.5),
                        Position=UDim2.new(s,0,1-v,0),
                        BackgroundColor3=Color3.new(1,1,1),
                        ZIndex=62, Parent=svC,
                    })
                    Corner(4,svK); Stroke(Color3.new(0,0,0),1,svK)

                    local function upd()
                        color=Color3.fromHSV(h,s,v)
                        swatch.BackgroundColor3=color
                        svC.BackgroundColor3=Color3.fromHSV(h,1,1)
                        hC.Position=UDim2.new(h,0,0.5,0)
                        svK.Position=UDim2.new(s,0,1-v,0)
                        task.spawn(cb,color)
                    end

                    local dH,dSV=false,false
                    hueBar.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dH=true end end)
                    svC.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dSV=true end end)
                    UserInputService.InputEnded:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then dH=false;dSV=false end
                    end)
                    UserInputService.InputChanged:Connect(function(i)
                        if i.UserInputType~=Enum.UserInputType.MouseMovement then return end
                        if dH then
                            h=math.clamp((i.Position.X-hueBar.AbsolutePosition.X)/hueBar.AbsoluteSize.X,0,1);upd()
                        elseif dSV then
                            s=math.clamp((i.Position.X-svC.AbsolutePosition.X)/svC.AbsoluteSize.X,0,1)
                            v=1-math.clamp((i.Position.Y-svC.AbsolutePosition.Y)/svC.AbsoluteSize.Y,0,1);upd()
                        end
                    end)
                    swatch.MouseButton1Click:Connect(function() open=not open;pp.Visible=open end)
                    refresh()
                    return {
                        Get=function(_) return color end,
                        Set=function(_,c) color=c;h,s,v=c:ToHSV();upd() end,
                    }
                end

