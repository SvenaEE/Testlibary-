	local G2L_hbc = Instance.new("UICorner", G2L_huebar);
	G2L_hbc["CornerRadius"] = UDim.new(0, 4);

	-- Build hue gradient using 7 colored frames stacked
	local hueColors = {
		Color3.fromRGB(255,0,0);
		Color3.fromRGB(255,128,0);
		Color3.fromRGB(255,255,0);
		Color3.fromRGB(0,255,0);
