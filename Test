					BackgroundTransparency = 1,
					ZIndex         = 8,
				})

				local kbEntry = kbAdd(text, key)

				local function updateDisplay()
					kbBtn.Text    = key and key.Name or "None"
					modeLbl.Text  = "● " .. mode
					modeLbl.TextColor3 = mode == "Toggle" and col.txmut
						or mode == "Hold" and col.accent
						or col.warn
				end

				kbBtn.MouseButton1Click:Connect(function()
					if mode == "Always On" then return end
					binding = true
					kbBtn.Text      = "..."
					kbBtn.TextColor3 = col.warn
				end)

				r.InputBegan:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton2 then
						openCtxMenu(r,
							{"Toggle", "Hold", "Always On"},
							function() return mode end,
							function(picked)
								mode = picked
								updateDisplay()
								if mode == "Always On" and cb then task.spawn(cb, true) end
							end
						)
					end
				end)

				UserInputService.InputBegan:Connect(function(i, gp)
					if binding and not gp then
						binding = false
						key = i.KeyCode
						kbBtn.TextColor3 = col.accent
						kbUpdate(kbEntry, key)
						updateDisplay()
						return
					end
					if not key or i.KeyCode ~= key or gp then return end
					if mode == "Toggle" then
						if cb then task.spawn(cb, key) end
					elseif mode == "Hold" then
						if cb then task.spawn(cb, true) end
					end
				end)

				UserInputService.InputEnded:Connect(function(i)
					if not key or i.KeyCode ~= key then return end
					if mode == "Hold" and cb then task.spawn(cb, false) end
				end)

				updateDisplay()

				return {
					Get     = function(_) return key end,
					GetMode = function(_) return mode end,
					Set     = function(_, k) key = k; kbUpdate(kbEntry, k); updateDisplay() end,
				}
			end

