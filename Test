		["Position"]               = UDim2.new(G2L_dot.Position.X.Scale, 0, G2L_dot.Position.Y.Scale - 0.6, 0);
		["BackgroundTransparency"] = 1;
		["Size"]                   = UDim2.new(0, 1, 0, 1);
