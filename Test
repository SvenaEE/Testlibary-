	-- ── Toggle (Insert key) ───────────────────────────────────────────────────
	-- homePos stores each tab's "visible" position so toggle always
	-- returns to the right place even after dragging.
	local homePos   = {}   -- [tabFrame] = UDim2  (updated after drag)
	local isVisible  = true
	local isTweening = false

	local tweenOut = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
	local tweenIn  = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

	local OFFSCREEN_X = -1900  -- px to slide off to the left

	local function hiddenPos(tab)
		local h = homePos[tab] or tab.Position
		return UDim2.new(0, h.X.Offset + OFFSCREEN_X, 0, h.Y.Offset)
	end

	local function slideAll(info, targetFn, onDone)
		isTweening = true
		local done = 0
		if #tabs == 0 then isTweening = false if onDone then onDone() end return end
		for _, tab in ipairs(tabs) do
			local t = TweenService:Create(tab, info, {Position = targetFn(tab)})
			t:Play()
			t.Completed:Connect(function()
				done += 1
				if done >= #tabs then
					isTweening = false
					if onDone then onDone() end
				end
			end)
		end
	end

	ContextActionService:BindAction("ToggleUI", function(_, inputState, _)
		if inputState ~= Enum.UserInputState.Begin then return end
		if isTweening then return end

		if isVisible then
			-- Save current positions as home before sliding out
			for _, tab in ipairs(tabs) do
				homePos[tab] = tab.Position
			end
			isVisible = false
			slideAll(tweenOut, hiddenPos, function()
				layoutFrame.Visible = false
			end)
		else
			-- Snap to off-screen, then tween back to home
			for _, tab in ipairs(tabs) do
				tab.Position = hiddenPos(tab)
			end
			layoutFrame.Visible = true
			isVisible = true
			slideAll(tweenIn, function(tab)
				return homePos[tab] or tab.Position
			end)
		end
	end, false, Enum.KeyCode.Insert)

