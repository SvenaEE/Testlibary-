local Library = {}
Library.__index = Library

function Library:CreateWindow(title, opts)
    opts = opts or {}
    local T         = Themes[opts.Theme or "Primordial"] or Themes.Primordial
    local toggleKey = opts.Key or Enum.KeyCode.RightShift

    -- dimensions
    local WIN_W  = 760
    local WIN_H  = 480
    local TAB_H  = 50
    local SIDE_W = 138
    local TITLE_H= 36
    local BODY_H = WIN_H - TITLE_H - TAB_H

    -- ── ScreenGui ─────────────────────────────────────────────
    local gui = New("ScreenGui",{
        Name           = "UL_"..HttpService:GenerateGUID(false):sub(1,6),
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder   = 999,
        Parent         = (RunService:IsStudio() and LP.PlayerGui) or game:GetService("CoreGui"),
    })

    -- ── Watermark (top-left, outside window) ──────────────────
    local wmFrame = New("Frame",{
        Name             = "Watermark",
        Position         = UDim2.new(0,8,0,8),
        Size             = UDim2.new(0,280,0,26),
        BackgroundColor3 = T.WatermarkBG,
        BorderSizePixel  = 0,
        ZIndex           = 500,
        Parent           = gui,
    })
    Crn(4, wmFrame)
    Stk(T.Border, 1, wmFrame)
    Pad(10,10,0,0, wmFrame)

    -- accent left stripe on watermark
    New("Frame",{
        Size=UDim2.new(0,2,1,0), Position=UDim2.new(0,0,0,0),
        BackgroundColor3=T.Accent, BorderSizePixel=0, ZIndex=501, Parent=wmFrame,
    })

    local wmLabel = New("TextLabel",{
        Text  = title.."  |  FPS: --  |  Ping: --  |  --:--",
        Font  = Enum.Font.Code,
        TextSize = 11,
        TextColor3 = T.TextSec,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0,6,0,0),
        Size = UDim2.new(1,-6,1,0),
        BackgroundTransparency = 1,
        ZIndex = 502,
        Parent = wmFrame,
    })

    -- Update watermark every second
    local wmConn
    wmConn = RunService.Heartbeat:Connect(function()
        local ok, ping = pcall(function() return LP:GetNetworkPing() end)
        local pingMs = ok and math.floor(ping*1000) or 0
        local fps    = math.floor(1/RunService.Heartbeat:Wait()*0.1 + 0.5)  -- approx
        local t      = os.date("*t")
        local timeStr= string.format("%02d:%02d", t.hour, t.min)
        -- FPS via stats
        local fpsReal = math.floor(1/(RunService.Heartbeat:Wait() + 0.0001))
        wmLabel.Text = string.format(
            "%s  |  %s  |  FPS: %d  |  Ping: %dms  |  %s",
            title, LP.Name, math.min(fpsReal,165), pingMs, timeStr
        )
    end)
    -- clean on destroy
    gui.Destroying:Connect(function() wmConn:Disconnect() end)

    -- ── Keybind List (mid-left, below watermark) ──────────────
    local kbFrame = New("Frame",{
        Name             = "KeybindList",
        Position         = UDim2.new(0,8,0,40),
        Size             = UDim2.new(0,200,0,0),
        AutomaticSize    = Enum.AutomaticSize.Y,
        BackgroundColor3 = T.WatermarkBG,
        BorderSizePixel  = 0,
        ZIndex           = 500,
        Parent           = gui,
    })
    Crn(4, kbFrame)
    Stk(T.Border, 1, kbFrame)
    Pad(0,0,4,4, kbFrame)
    VList(kbFrame, 0)

    local function RebuildKeybindList()
        for _,c in ipairs(kbFrame:GetChildren()) do
            if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end
        end
        if #KeybindRegistry == 0 then
            kbFrame.Visible = false
            return
        end
        kbFrame.Visible = true
        for _, kb in ipairs(KeybindRegistry) do
            local row = New("Frame",{
                Size=UDim2.new(1,0,0,20),
                BackgroundTransparency=1, ZIndex=501,
                Parent=kbFrame,
            })
            New("TextLabel",{
                Text=kb.label, Font=Enum.Font.Code, TextSize=10,
                TextColor3=T.TextSec, TextXAlignment=Enum.TextXAlignment.Left,
                Position=UDim2.new(0,10,0,0), Size=UDim2.new(1,-70,1,0),
                BackgroundTransparency=1, ZIndex=502, Parent=row,
            })
            New("TextLabel",{
                Text="["..kb.key.."]", Font=Enum.Font.Code, TextSize=10,
                TextColor3=T.Accent, TextXAlignment=Enum.TextXAlignment.Right,
                AnchorPoint=Vector2.new(1,0), Position=UDim2.new(1,-8,0,0),
                Size=UDim2.new(0,60,1,0),
                BackgroundTransparency=1, ZIndex=502, Parent=row,
            })
        end
    end
    RebuildKeybindList()

    -- ── Notification holder (bottom-right) ────────────────────
    local notifHolder = New("Frame",{
        AnchorPoint=Vector2.new(1,1),
        Position=UDim2.new(1,-12,1,-12),
        Size=UDim2.new(0,290,1,-24),
        BackgroundTransparency=1, ZIndex=600,
        Parent=gui,
    })
    New("UIListLayout",{
        Parent=notifHolder, VerticalAlignment=Enum.VerticalAlignment.Bottom,
        SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0,6),
    })

    -- ── Root window ───────────────────────────────────────────
    local root = New("Frame",{
        Name="Root",
        AnchorPoint=Vector2.new(0.5,0.5),
        Position=UDim2.new(0.5,0,0.5,0),
        Size=UDim2.new(0,WIN_W,0,WIN_H),
        BackgroundColor3=T.BG,
        BorderSizePixel=0,
        ClipsDescendants=false,
        Parent=gui,
    })
    Crn(8, root)
    Stk(T.Border, 1, root)
    -- drop shadow
    New("ImageLabel",{
        AnchorPoint=Vector2.new(0.5,0.5),
        Position=UDim2.new(0.5,0,0.5,10),
        Size=UDim2.new(1,60,1,60),
        ZIndex=0, BackgroundTransparency=1,
        Image="rbxassetid://6015897843",
        ImageColor3=Color3.new(0,0,0),
        ImageTransparency=0.48,
        ScaleType=Enum.ScaleType.Slice,
        SliceCenter=Rect.new(49,49,450,450),
        Parent=root,
    })

    -- inner clip
    local inner = New("Frame",{
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,
        ClipsDescendants=true,
        ZIndex=1, Parent=root,
    })
    Crn(8, inner)

    -- ── Title bar ─────────────────────────────────────────────
    local titleBar = New("Frame",{
        Size=UDim2.new(1,0,0,TITLE_H),
        BackgroundColor3=T.Panel,
        BorderSizePixel=0, ZIndex=10,
        Parent=inner,
    })
    -- bottom rule
    New("Frame",{
        Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=T.Border, BorderSizePixel=0, ZIndex=11, Parent=titleBar,
    })
    -- left accent stripe
    New("Frame",{
        Size=UDim2.new(0,3,0,18), Position=UDim2.new(0,10,0.5,-9),
        BackgroundColor3=T.Accent, BorderSizePixel=0, ZIndex=12, Parent=titleBar,
    })
    New("TextLabel",{
        Text=title, Font=Enum.Font.GothamBold, TextSize=12,
        TextColor3=T.TextPrim, TextXAlignment=Enum.TextXAlignment.Left,
        Position=UDim2.new(0,22,0,0), Size=UDim2.new(1,-100,1,0),
        BackgroundTransparency=1, ZIndex=12, Parent=titleBar,
    })
    -- keybind badge (top right)
    local kbBadge = New("Frame",{
        Size=UDim2.new(0,72,0,20),
        AnchorPoint=Vector2.new(1,0.5),
        Position=UDim2.new(1,-10,0.5,0),
        BackgroundColor3=T.Surface,
        BorderSizePixel=0, ZIndex=12, Parent=titleBar,
    })
    Crn(4, kbBadge)
    Stk(T.Border,1,kbBadge)
    New("TextLabel",{
        Text=toggleKey.Name, Font=Enum.Font.GothamBold, TextSize=9,
        TextColor3=T.TextMuted, TextXAlignment=Enum.TextXAlignment.Center,
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1, ZIndex=13, Parent=kbBadge,
    })

    -- drag
    do
        local drag,ds,sp
        titleBar.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                drag=true; ds=i.Position; sp=root.Position
            end
        end)
        titleBar.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
                local d=i.Position-ds
                root.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
            end
        end)
    end

    -- ── Body ──────────────────────────────────────────────────
    local body = New("Frame",{
        Size=UDim2.new(1,0,0,BODY_H),
        Position=UDim2.new(0,0,0,TITLE_H),
        BackgroundTransparency=1, ZIndex=2, Parent=inner,
    })

    -- ── Sidebar ───────────────────────────────────────────────
    local sidebar = New("Frame",{
        Size=UDim2.new(0,SIDE_W,1,0),
        BackgroundColor3=T.SideBar,
        BorderSizePixel=0, ZIndex=3,
        Parent=body,
    })
    -- right border
    New("Frame",{
        Size=UDim2.new(0,1,1,0), Position=UDim2.new(1,-1,0,0),
        BackgroundColor3=T.Border, BorderSizePixel=0, ZIndex=4, Parent=sidebar,
    })

    -- This frame holds the page-list for whichever tab is active
    -- We swap visibility between per-tab page-list frames
    local sideContent = New("Frame",{
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,
        ZIndex=4, Parent=sidebar,
    })

    -- ── Content area ──────────────────────────────────────────
    local contentArea = New("Frame",{
        Size=UDim2.new(1,-SIDE_W,1,0),
        Position=UDim2.new(0,SIDE_W,0,0),
        BackgroundColor3=T.BG,
        BorderSizePixel=0,
        ClipsDescendants=true,
        ZIndex=2, Parent=body,
    })

    -- ── Bottom tab bar ────────────────────────────────────────
    local tabBar = New("Frame",{
        Size=UDim2.new(1,0,0,TAB_H),
        Position=UDim2.new(0,0,1,-TAB_H),
        BackgroundColor3=T.TabBG,
        BorderSizePixel=0, ZIndex=10,
        Parent=inner,
    })
    -- top rule
    New("Frame",{
        Size=UDim2.new(1,0,0,1),
        BackgroundColor3=T.Border,
        BorderSizePixel=0, ZIndex=11, Parent=tabBar,
    })
    local tabRow = New("Frame",{
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1, ZIndex=11,
        Parent=tabBar,
    })
    HList(tabRow, 0)

    -- ── Toggle key ────────────────────────────────────────────
    local visible = true
    UserInputService.InputBegan:Connect(function(i,gp)
        if gp then return end
        if i.KeyCode==toggleKey then
            visible = not visible
            root.Visible = visible
            wmFrame.Visible = visible
            kbFrame.Visible = visible and (#KeybindRegistry > 0)
        end
    end)

    -- ══════════════════════════════════════════════════════════
    --  Window object
    -- ══════════════════════════════════════════════════════════
    local Window = {
        _T             = T,
        _tabs          = {},
        _activeTab     = nil,
        _sideContent   = sideContent,
        _contentArea   = contentArea,
        _tabRow        = tabRow,
        _notifHolder   = notifHolder,
        _rebuildKB     = RebuildKeybindList,
        _gui           = gui,
    }

    function Window:_switchTab(tab)
        if self._activeTab == tab then return end
        if self._activeTab then
            local o = self._activeTab
            o._pageList.Visible = false
            Tw(o._btn,{BackgroundTransparency=1},0.14):Play()
            o._btnLine.Visible = false
            Tw(o._btnLbl,{TextColor3=T.TextMuted},0.14):Play()
        end
        self._activeTab = tab
        tab._pageList.Visible = true
        tab._btnLine.Visible = true
        Tw(tab._btn,{BackgroundTransparency=0, BackgroundColor3=T.ActiveTab},0.14):Play()
        Tw(tab._btnLbl,{TextColor3=T.TextPrim},0.14):Play()
        -- show first page (or re-show active one)
        if not tab._activePage and #tab._pages>0 then
            tab:_switchPage(tab._pages[1])
        elseif tab._activePage then
            tab._activePage._frame.Visible = true
        end
    end

    -- ══════════════════════════════════════════════════════════
    --  AddTab
    -- ══════════════════════════════════════════════════════════
    function Window:AddTab(name, icon)
        local T   = self._T
        local TAB_W = 90  -- each tab button width

        -- Tab button (in bottom bar)
        local btn = New("TextButton",{
            Text="", Size=UDim2.new(0,TAB_W,1,0),
            BackgroundColor3=T.ActiveTab, BackgroundTransparency=1,
            AutoButtonColor=false, ZIndex=12,
            Parent=self._tabRow,
        })
        -- active indicator line (top edge of tab button)
        local btnLine = New("Frame",{
            Size=UDim2.new(0.65,0,0,2),
            AnchorPoint=Vector2.new(0.5,0),
            Position=UDim2.new(0.5,0,0,0),
            BackgroundColor3=T.Accent,
            BorderSizePixel=0, Visible=false, ZIndex=13,
            Parent=btn,
        })
        Crn(1,btnLine)
        -- icon
        if icon and icon~="" then
            New("ImageLabel",{
                Image=icon, Size=UDim2.new(0,16,0,16),
                AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new(0.5,0,0.5,-8),
                BackgroundTransparency=1, ZIndex=13, Parent=btn,
            })
        end
        -- label
        local btnLbl = New("TextLabel",{
            Text=name, Font=Enum.Font.GothamSemibold, TextSize=10,
            TextColor3=T.TextMuted,
            AnchorPoint=Vector2.new(0.5,1),
            Position=UDim2.new(0.5,0,1,-4),
            Size=UDim2.new(1,-4,0,12),
            TextXAlignment=Enum.TextXAlignment.Center,
            BackgroundTransparency=1, ZIndex=13, Parent=btn,
        })

        -- Per-tab page list (inside sidebar)
        local pageList = New("ScrollingFrame",{
            Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1,
            BorderSizePixel=0,
            ScrollBarThickness=2,
            ScrollBarImageColor3=T.Scroll,
            CanvasSize=UDim2.new(0,0,0,0),
            AutomaticCanvasSize=Enum.AutomaticSize.Y,
            Visible=false, ZIndex=5,
            Parent=self._sideContent,
        })
        VList(pageList,2)
        Pad(6,6,8,6,pageList)

        local tab = {
            _btn        = btn,
            _btnLbl     = btnLbl,
            _btnLine    = btnLine,
            _pageList   = pageList,
            _pages      = {},
            _activePage = nil,
            _window     = self,
            _T          = T,
        }

        function tab:_switchPage(page)
            if self._activePage == page then return end
            if self._activePage then
                self._activePage._frame.Visible = false
                Tw(self._activePage._sBtn,{BackgroundTransparency=1,TextColor3=T.TextSec},0.12):Play()
                self._activePage._sDot.BackgroundTransparency=1
            end
            self._activePage = page
            page._frame.Visible = true
            Tw(page._sBtn,{BackgroundTransparency=0,BackgroundColor3=T.SurfHov,TextColor3=T.TextPrim},0.12):Play()
            page._sDot.BackgroundTransparency=0
        end

        btn.MouseEnter:Connect(function()
            if self._activeTab~=tab then
                Tw(btn,{BackgroundTransparency=0.65,BackgroundColor3=T.ActiveTab},0.12):Play()
                Tw(btnLbl,{TextColor3=T.TextSec},0.12):Play()
            end
        end)
        btn.MouseLeave:Connect(function()
            if self._activeTab~=tab then
                Tw(btn,{BackgroundTransparency=1},0.12):Play()
                Tw(btnLbl,{TextColor3=T.TextMuted},0.12):Play()
            end
        end)
        btn.MouseButton1Click:Connect(function() self:_switchTab(tab) end)

        table.insert(self._tabs, tab)
        if #self._tabs==1 then self:_switchTab(tab) end

        -- ════════════════════════════════════════════════════
        --  AddPage
        -- ════════════════════════════════════════════════════
        function tab:AddPage(pageName)
            local T = self._T

            -- Sidebar button
            local sBtn = New("TextButton",{
                Text=pageName, Font=Enum.Font.Gotham, TextSize=12,
                TextColor3=T.TextSec,
                TextXAlignment=Enum.TextXAlignment.Left,
                Size=UDim2.new(1,0,0,28),
                BackgroundColor3=T.SurfHov,
                BackgroundTransparency=1,
                AutoButtonColor=false, ZIndex=6,
                Parent=pageList,
            })
            Crn(5,sBtn)
            Pad(20,8,0,0,sBtn)
            local sDot = New("Frame",{
                Size=UDim2.new(0,3,0,12),
                AnchorPoint=Vector2.new(0,0.5),
                Position=UDim2.new(0,7,0.5,0),
                BackgroundColor3=T.Accent,
                BackgroundTransparency=1,
                BorderSizePixel=0, ZIndex=7,
                Parent=sBtn,
            })
            Crn(2,sDot)

            sBtn.MouseEnter:Connect(function()
                if self._activePage and self._activePage._sBtn==sBtn then return end
                Tw(sBtn,{BackgroundTransparency=0.6,BackgroundColor3=T.SurfHov},0.1):Play()
            end)
            sBtn.MouseLeave:Connect(function()
                if self._activePage and self._activePage._sBtn==sBtn then return end
                Tw(sBtn,{BackgroundTransparency=1},0.1):Play()
            end)

            -- ── Page content frame ─────────────────────────
            -- Uses a HORIZONTAL list of column frames.
            -- Each column is a vertical list of sections.
            -- This avoids UIGridLayout's AutomaticSize conflict.
            local pageScroll = New("ScrollingFrame",{
                Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1,
                BorderSizePixel=0,
                ScrollBarThickness=3,
                ScrollBarImageColor3=T.Scroll,
                CanvasSize=UDim2.new(0,0,0,0),
                AutomaticCanvasSize=Enum.AutomaticSize.Y,
                Visible=false, ZIndex=3,
                Parent=self._window._contentArea,
            })
            Pad(10,10,10,10,pageScroll)
            -- Horizontal row that holds two columns
            local colRow = New("Frame",{
                Size=UDim2.new(1,0,0,0),
                AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,
                ZIndex=3, Parent=pageScroll,
            })
            HList(colRow, 10)

            -- Column A (left)
            local colA = New("Frame",{
                Size=UDim2.new(0.5,-5,0,0),
                AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,
                ZIndex=3, Parent=colRow,
            })
            VList(colA, 10)
            -- Column B (right)
            local colB = New("Frame",{
                Size=UDim2.new(0.5,-5,0,0),
                AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,
                ZIndex=3, Parent=colRow,
            })
            VList(colB, 10)

            local page = {
                _sBtn  = sBtn,
                _sDot  = sDot,
                _frame = pageScroll,
                _colA  = colA,
                _colB  = colB,
                _secCount = 0,
                _T     = T,
                _tab   = self,
            }

            sBtn.MouseButton1Click:Connect(function() tab:_switchPage(page) end)
            table.insert(self._pages, page)
            if #self._pages==1 and self._window._activeTab==self then
                self:_switchPage(page)
            end

            -- ════════════════════════════════════════════════
            --  AddSection
            -- ════════════════════════════════════════════════
            function page:AddSection(secName)
                local T = self._T
                self._secCount = self._secCount + 1
                -- Alternate between left and right column
                local col = (self._secCount % 2 == 1) and self._colA or self._colB

                -- Section wrapper: AutomaticSize.Y to grow with its content
                local secWrap = New("Frame",{
                    Size=UDim2.new(1,0,0,0),
                    AutomaticSize=Enum.AutomaticSize.Y,
                    BackgroundColor3=T.Card,
                    BorderSizePixel=0, ZIndex=4,
                    Parent=col,
                })
                Crn(5,secWrap)
                Stk(T.Border,1,secWrap)

                -- Section header
                local hdr = New("Frame",{
                    Size=UDim2.new(1,0,0,28),
                    BackgroundColor3=T.Surface,
                    BorderSizePixel=0, ZIndex=5,
                    Parent=secWrap,
                })
                Crn(5,hdr)
                -- mask bottom corners of header
                New("Frame",{
                    Size=UDim2.new(1,0,0,6),
                    Position=UDim2.new(0,0,1,-6),
                    BackgroundColor3=T.Surface,
                    BorderSizePixel=0, ZIndex=6, Parent=hdr,
                })
                -- left accent bar
                New("Frame",{
                    Size=UDim2.new(0,2,0,13),
                    Position=UDim2.new(0,8,0.5,-6),
                    BackgroundColor3=T.Accent,
                    BorderSizePixel=0, ZIndex=7, Parent=hdr,
                })
                New("TextLabel",{
                    Text=secName, Font=Enum.Font.GothamBold, TextSize=10,
                    TextColor3=T.TextSec,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    Position=UDim2.new(0,16,0,0),
                    Size=UDim2.new(1,-20,1,0),
                    BackgroundTransparency=1, ZIndex=7, Parent=hdr,
                })

                -- Elements list (grows automatically)
                local elems = New("Frame",{
                    Size=UDim2.new(1,0,0,0),
                    AutomaticSize=Enum.AutomaticSize.Y,
                    Position=UDim2.new(0,0,0,28),
                    BackgroundTransparency=1,
                    ZIndex=5, Parent=secWrap,
                })
                VList(elems,0)

                -- ── Element row factory ───────────────────────
                local ROW_H = 30
                local function Row(h)
                    local r = New("Frame",{
                        Size=UDim2.new(1,0,0,h or ROW_H),
                        BackgroundTransparency=1,
                        ZIndex=6, Parent=elems,
                    })
                    -- thin separator
                    New("Frame",{
                        Size=UDim2.new(1,-16,0,1),
                        Position=UDim2.new(0,8,1,-1),
                        BackgroundColor3=T.BorderDim,
                        BackgroundTransparency=0.4,
                        BorderSizePixel=0, ZIndex=6, Parent=r,
                    })
                    return r
                end

                local function RowText(row, text, muted)
                    New("TextLabel",{
                        Text=text, Font=Enum.Font.Gotham, TextSize=11,
                        TextColor3=muted and T.TextMuted or T.TextPrim,
                        TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,10,0,0),
                        Size=UDim2.new(0.54,0,1,0),
                        BackgroundTransparency=1, ZIndex=7, Parent=row,
                    })
                end

                local SEC = {_T=T}

                -- ── AddLabel ──────────────────────────────────
                function SEC:AddLabel(text)
                    local r=Row()
                    New("TextLabel",{
                        Text=text, Font=Enum.Font.Gotham, TextSize=11,
                        TextColor3=T.TextSec,
                        TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,10,0,0),
                        Size=UDim2.new(1,-20,1,0),
                        BackgroundTransparency=1, ZIndex=7, Parent=r,
                    })
                end

                -- ── AddButton ─────────────────────────────────
                function SEC:AddButton(text, cb)
                    local r=Row()
                    local btn=New("TextButton",{
                        Text="", Size=UDim2.new(1,0,1,0),
                        BackgroundTransparency=1,
                        AutoButtonColor=false, ZIndex=7, Parent=r,
                    })
                    New("TextLabel",{
                        Text=text, Font=Enum.Font.Gotham, TextSize=11,
                        TextColor3=T.TextPrim,
                        TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,10,0,0),
                        Size=UDim2.new(1,-30,1,0),
                        BackgroundTransparency=1, ZIndex=8, Parent=btn,
                    })
                    New("TextLabel",{
                        Text="›", Font=Enum.Font.GothamBold, TextSize=14,
                        TextColor3=T.TextMuted,
                        AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),
                        Size=UDim2.new(0,12,1,0),
