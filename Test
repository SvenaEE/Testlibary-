                -- ── AddToggle ─────────────────────────────────
                function SEC:AddToggle(text, default, cb)
                    local on = default or false
                    local r  = Row()
                    RowLbl(r, text)

                    local track = New("TextButton", {
                        Text="",
                        Size=UDim2.new(0,32,0,17),
                        AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=on and T.Accent or T.Surface,
                        AutoButtonColor=false, ZIndex=8, Parent=r,
                    })
                    Corner(9, track)
                    Stroke(T.Border, 1, track)

                    local knob = New("Frame", {
                        Size=UDim2.new(0,11,0,11),
                        AnchorPoint=Vector2.new(0,0.5),
                        Position=on and UDim2.new(1,-14,0.5,0) or UDim2.new(0,3,0.5,0),
                        BackgroundColor3=Color3.new(1,1,1),
                        ZIndex=9, Parent=track,
                    })
                    Corner(6, knob)

                    local function upd()
                        Tween(track, {BackgroundColor3=on and T.Accent or T.Surface}, 0.14):Play()
                        Tween(knob,  {Position=on and UDim2.new(1,-14,0.5,0) or UDim2.new(0,3,0.5,0)}, 0.14):Play()
                    end
                    track.MouseButton1Click:Connect(function()
                        on=not on; upd(); task.spawn(cb,on)
