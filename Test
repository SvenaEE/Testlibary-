			G2L["CtxDot_"..opt].ZIndex = 202;
			G2L["CtxDot_"..opt].Parent = G2L["CtxBtn_"..opt];
		end

		G2L["CtxBtn_"..opt].MouseEnter:Connect(function()
			Tween(G2L["CtxBtn_"..opt], {BackgroundTransparency = 0}, 0.1):Play();
		end);
		G2L["CtxBtn_"..opt].MouseLeave:Connect(function()
			Tween(G2L["CtxBtn_"..opt], {BackgroundTransparency = 1}, 0.1):Play();
		end);
		local capturedOpt = opt;
		G2L["CtxBtn_"..opt].MouseButton1Click:Connect(function()
			CloseCtx();
