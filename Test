    function Win:Notify(ttl,msg,dur)
        local T=self._T; dur=dur or 4
        local card=New("Frame",{
            Size=UDim2.new(1,0,0,56),BackgroundColor3=T.Panel,
            BackgroundTransparency=0.04,ClipsDescendants=true,
            ZIndex=601,Parent=self._notifHolder,
