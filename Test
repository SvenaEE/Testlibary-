-- ════════════════════════════════════════════════════════════
--  KEYBIND REGISTRY  (module-level so all windows share it)
-- ════════════════════════════════════════════════════════════
local KBList     = {}
local kbRebuild  = nil   -- set after kbFrame is created

local function kbAdd(label,key)
    local e={label=label,keyName=key and key.Name or "None"}
    table.insert(KBList,e)
    if kbRebuild then kbRebuild() end
    return e
end
local function kbUpd(e,key)
    e.keyName=key and key.Name or "None"
    if kbRebuild then kbRebuild() end
end

-- ════════════════════════════════════════════════════════════
--  LIBRARY  (dot-method constructor like Kavo)
-- ════════════════════════════════════════════════════════════
local UI = {}

function UI.CreateLib(title, theme)
    local T   = Themes[theme or "Primordial"] or Themes.Primordial
    local tKey = Enum.KeyCode.RightShift

    local WIN_W  = 740
    local WIN_H  = 460
    local TAB_H  = 48
    local TITLE_H= 36
    local BODY_H = WIN_H - TITLE_H - TAB_H

    -- ── ScreenGui ─────────────────────────────────────────────
    local gui = New("ScreenGui",{
        Name           = "UL_"..Http:GenerateGUID(false):sub(1,6),
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder   = 999,
        Parent         = Run:IsStudio() and LP.PlayerGui
                         or game:GetService("CoreGui"),
    })

    -- ── Watermark (top-left, auto-width) ──────────────────────
    local wmOuter = New("Frame",{
        Position=UDim2.new(0,8,0,6),
        Size=UDim2.new(0,10,0,24),
        AutomaticSize=Enum.AutomaticSize.X,
        BackgroundColor3=T.WMBG,BorderSizePixel=0,
        ZIndex=500,Parent=gui,
    })
    Crn(4,wmOuter); Stk(T.Border,1,wmOuter)
    New("Frame",{   -- accent left stripe
        Size=UDim2.new(0,2,1,0),BackgroundColor3=T.Accent,
        BorderSizePixel=0,ZIndex=501,Parent=wmOuter,
    })
    local wmLbl=New("TextLabel",{
        Text="",Font=Enum.Font.Code,TextSize=12,TextColor3=T.TxSec,
        TextXAlignment=Enum.TextXAlignment.Left,
        Size=UDim2.new(0,10,1,0),AutomaticSize=Enum.AutomaticSize.X,
        BackgroundTransparency=1,ZIndex=502,Parent=wmOuter,
    })
    Pad(10,12,0,0,wmLbl)

    local fpsA,fpsC,fpsV,lastWM=0,0,60,0
    local function doWM()
        local ok,ping=pcall(function() return LP:GetNetworkPing() end)
        local p=ok and math.round((ping or 0)*1000) or 0
        local t=os.date("*t")
        wmLbl.Text=string.format(" %s  |  %s  |  FPS: %d  |  Ping: %dms  |  %02d:%02d ",
            title,LP.Name,fpsV,p,t.hour,t.min)
    end
    Run.Heartbeat:Connect(function(dt)
        fpsA=fpsA+(1/dt); fpsC=fpsC+1
        if fpsC>=20 then fpsV=math.floor(fpsA/fpsC); fpsA=0; fpsC=0 end
        local now=os.clock()
        if now-lastWM>=1 then lastWM=now; doWM() end
    end)
    doWM()

    -- ── Keybind list (middle-left of screen) ──────────────────
    local kbFrame=New("Frame",{
        AnchorPoint=Vector2.new(0,0.5),
        Position=UDim2.new(0,8,0.5,0),
        Size=UDim2.new(0,192,0,0),
        AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundColor3=T.WMBG,BorderSizePixel=0,
        ZIndex=500,Visible=false,Parent=gui,
    })
    Crn(4,kbFrame); Stk(T.Border,1,kbFrame); Pad(0,0,4,4,kbFrame)
    VList(kbFrame,0)

    local kbHdr=New("Frame",{Size=UDim2.new(1,0,0,20),BackgroundTransparency=1,ZIndex=501,Parent=kbFrame})
    New("Frame",{Size=UDim2.new(0,2,1,0),BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=502,Parent=kbHdr})
    New("TextLabel",{
        Text=" KEYBINDS",Font=Enum.Font.GothamBold,TextSize=9,
        TextColor3=T.TxMut,TextXAlignment=Enum.TextXAlignment.Left,
        Position=UDim2.new(0,8,0,0),Size=UDim2.new(1,-8,1,0),
        BackgroundTransparency=1,ZIndex=502,Parent=kbHdr,
    })
    local kbBody=New("Frame",{
        Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1,ZIndex=501,Parent=kbFrame,
    })
    VList(kbBody,0)

    kbRebuild=function()
        for _,c in ipairs(kbBody:GetChildren()) do
            if not c:IsA("UIListLayout") then c:Destroy() end
        end
        if #KBList==0 then kbFrame.Visible=false; return end
        kbFrame.Visible=true
        for _,kb in ipairs(KBList) do
            local row=New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,ZIndex=502,Parent=kbBody})
            New("TextLabel",{
                Text=kb.label,Font=Enum.Font.Code,TextSize=10,TextColor3=T.TxSec,
                TextXAlignment=Enum.TextXAlignment.Left,
                Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-70,1,0),
                BackgroundTransparency=1,ZIndex=503,Parent=row,
            })
            New("TextLabel",{
                Text="["..kb.keyName.."]",Font=Enum.Font.Code,TextSize=10,
                TextColor3=T.Accent,TextXAlignment=Enum.TextXAlignment.Right,
                AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-8,0,0),
                Size=UDim2.new(0,62,1,0),
                BackgroundTransparency=1,ZIndex=503,Parent=row,
            })
        end
    end

    -- ── Notification holder (bottom-right) ────────────────────
    local notifHolder=New("Frame",{
        AnchorPoint=Vector2.new(1,1),Position=UDim2.new(1,-12,1,-12),
        Size=UDim2.new(0,295,1,-24),BackgroundTransparency=1,ZIndex=600,Parent=gui,
    })
    New("UIListLayout",{Parent=notifHolder,VerticalAlignment=Enum.VerticalAlignment.Bottom,
        SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6)})

    -- ── Root window ───────────────────────────────────────────
    local root=New("Frame",{
        AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),
        Size=UDim2.new(0,WIN_W,0,WIN_H),
        BackgroundColor3=T.BG,BorderSizePixel=0,ClipsDescendants=false,Parent=gui,
    })
    Crn(8,root)
    -- Stroke applied to inner (clipped) so corners are pixel-perfect
    -- Stk is added after inner is created below
    New("ImageLabel",{
        AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,14),
        Size=UDim2.new(1,60,1,60),ZIndex=0,BackgroundTransparency=1,
        Image="rbxassetid://6015897843",ImageColor3=Color3.new(0,0,0),
        ImageTransparency=0.46,ScaleType=Enum.ScaleType.Slice,
        SliceCenter=Rect.new(49,49,450,450),Parent=root,
    })
    local inner=New("Frame",{
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
        ClipsDescendants=true,ZIndex=1,Parent=root,
    })
    Crn(8,inner)
    Stk(T.Border,1,inner)  -- border on the clipped inner → perfect rounded corners

    -- ── Title bar ─────────────────────────────────────────────
    local titleBar=New("Frame",{
        Size=UDim2.new(1,0,0,TITLE_H),BackgroundColor3=T.Panel,
        BorderSizePixel=0,ZIndex=10,Parent=inner,
    })
    New("Frame",{   -- bottom rule
        Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=11,Parent=titleBar,
    })
    New("Frame",{   -- left accent stripe
        Size=UDim2.new(0,3,0,16),Position=UDim2.new(0,10,0.5,-8),
        BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=12,Parent=titleBar,
    })
    New("TextLabel",{
        Text=title,Font=Enum.Font.GothamBold,TextSize=12,
        TextColor3=T.TxPrim,TextXAlignment=Enum.TextXAlignment.Left,
        Position=UDim2.new(0,22,0,0),Size=UDim2.new(1,-110,1,0),
        BackgroundTransparency=1,ZIndex=12,Parent=titleBar,
    })
    -- toggle key badge (right side, vertically centered)
    local kbBadge=New("Frame",{
        Size=UDim2.new(0,82,0,20),
        AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
        BackgroundColor3=T.Surface,BorderSizePixel=0,ZIndex=12,Parent=titleBar,
    })
    Crn(4,kbBadge); Stk(T.Border,1,kbBadge)
    local kbBadgeLbl=New("TextLabel",{
        Text=tKey.Name,Font=Enum.Font.GothamBold,TextSize=9,
        TextColor3=T.TxSec,TextXAlignment=Enum.TextXAlignment.Center,
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=13,Parent=kbBadge,
    })

    -- drag
    do
        local drag,ds,sp
        titleBar.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                drag=true;ds=i.Position;sp=root.Position
            end
        end)
        titleBar.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
        end)
        UIS.InputChanged:Connect(function(i)
            if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
                local d=i.Position-ds
                root.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
            end
        end)
    end

    -- ── Content area (full-width, between title and tab bar) ──
    local contentArea=New("Frame",{
        Size=UDim2.new(1,0,0,BODY_H),Position=UDim2.new(0,0,0,TITLE_H),
        BackgroundColor3=T.BG,BorderSizePixel=0,
        ClipsDescendants=true,ZIndex=2,Parent=inner,
    })

    -- ── Tab bar (bottom) ──────────────────────────────────────
    -- Built OUTSIDE inner so the active line can sit on the TOP border
    -- without being clipped
    local tabBarOuter=New("Frame",{
        Size=UDim2.new(1,0,0,TAB_H+1),  -- +1 to include the top rule
        Position=UDim2.new(0,0,1,-TAB_H-1),
        BackgroundColor3=T.TabBG,BorderSizePixel=0,ZIndex=10,Parent=inner,
    })
    New("Frame",{   -- top separator rule
        Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0,0),
        BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=11,Parent=tabBarOuter,
    })
    -- tab buttons row, sits below that rule
    local tabRow=New("Frame",{
        Size=UDim2.new(1,0,1,-1),Position=UDim2.new(0,0,0,1),
        BackgroundTransparency=1,ZIndex=11,Parent=tabBarOuter,
    })
    New("UIListLayout",{
        Parent=tabRow,FillDirection=Enum.FillDirection.Horizontal,
        HorizontalAlignment=Enum.HorizontalAlignment.Center,
        VerticalAlignment=Enum.VerticalAlignment.Center,
        SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,0),
    })

    -- ── Visibility toggle ─────────────────────────────────────
    local visible=true
    UIS.InputBegan:Connect(function(i,gp)
        if gp then return end
        if i.KeyCode==tKey then
            visible=not visible
            root.Visible=visible
            -- watermark and keybind list stay visible always
        end
    end)

    -- ════════════════════════════════════════════════════════
    --  Window object
    -- ════════════════════════════════════════════════════════
    local Win={
        _T=T, _tabs={}, _activeTab=nil,
        _contentArea=contentArea,
        _tabRow=tabRow,
        _notifHolder=notifHolder,
        _gui=gui,
        _kbBadgeLbl=kbBadgeLbl,
    }

    function Win:SetKey(k)
        tKey=k
        self._kbBadgeLbl.Text=k.Name
    end

    function Win:_switch(tab)
        if self._activeTab==tab then return end
        -- hide old
        if self._activeTab then
            local o=self._activeTab
            if o._frame then o._frame.Visible=false end
            Tw(o._btn,{BackgroundTransparency=1},0.14):Play()
            o._line.Visible=false
            Tw(o._lbl,{TextColor3=T.TxMut},0.14):Play()
        end
        -- show new
        self._activeTab=tab
        if tab._frame then tab._frame.Visible=true end
        tab._line.Visible=true
        Tw(tab._btn,{BackgroundTransparency=0,BackgroundColor3=T.ActTab},0.14):Play()
        Tw(tab._lbl,{TextColor3=T.TxPrim},0.14):Play()
    end

    -- ════════════════════════════════════════════════════════
    --  NewTab(name)
    -- ════════════════════════════════════════════════════════
    function Win:NewTab(name)
        local T=self._T

        -- tab button
        local btn=New("TextButton",{
            Text="",Size=UDim2.new(0,92,1,0),
            BackgroundColor3=T.ActTab,BackgroundTransparency=1,
            AutoButtonColor=false,ZIndex=12,Parent=self._tabRow,
        })
        -- active indicator: a line that sits at the TOP of the tab button
        -- positioned at y=0 of the button, so it appears ON the separator rule
        local line=New("Frame",{
            Size=UDim2.new(0.55,0,0,2),
            AnchorPoint=Vector2.new(0.5,0),
            Position=UDim2.new(0.5,0,0,0),
            BackgroundColor3=T.Accent,
            BorderSizePixel=0,Visible=false,ZIndex=15,
            Parent=btn,
        })
        Crn(1,line)
        local lbl=New("TextLabel",{
            Text=name,Font=Enum.Font.GothamSemibold,TextSize=11,
            TextColor3=T.TxMut,
            AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),
            Size=UDim2.new(1,-4,1,0),
            TextXAlignment=Enum.TextXAlignment.Center,
            BackgroundTransparency=1,ZIndex=13,Parent=btn,
        })

        -- tab's scrollable content frame (two-column layout)
        local frame=New("ScrollingFrame",{
            Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
            BorderSizePixel=0,ScrollBarThickness=3,
            ScrollBarImageColor3=T.Scroll,
            CanvasSize=UDim2.new(0,0,0,0),
            AutomaticCanvasSize=Enum.AutomaticSize.Y,
            Visible=false,ZIndex=3,Parent=self._contentArea,
        })

        -- FIX: scale-based widths break inside ScrollingFrame (canvas X = 0).
        -- Use absolute pixel column widths instead.
        -- COL_W = (windowWidth - scrollbar - padding*2 - gap) / 2
        local COL_W = math.floor((WIN_W - 6 - 20 - 10) / 2)

        local innerPad=New("Frame",{
            Size=UDim2.new(1,-6,0,0),AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1,ZIndex=3,Parent=frame,
        })
        Pad(10,0,10,10,innerPad)

        local colHolder=New("Frame",{
            Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1,ZIndex=3,Parent=innerPad,
        })
        New("UIListLayout",{
            Parent=colHolder,FillDirection=Enum.FillDirection.Horizontal,
            VerticalAlignment=Enum.VerticalAlignment.Top,
            HorizontalAlignment=Enum.HorizontalAlignment.Left,
            SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,10),
        })
        local colA=New("Frame",{
            Size=UDim2.new(0,COL_W,0,0),AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1,ZIndex=3,Parent=colHolder,
        })
        VList(colA,10)
        local colB=New("Frame",{
            Size=UDim2.new(0,COL_W,0,0),AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1,ZIndex=3,Parent=colHolder,
        })
        VList(colB,10)

        local tab={
            _btn=btn,_lbl=lbl,_line=line,
            _frame=frame,_colA=colA,_colB=colB,
            _secCount=0,_T=T,_win=self,
        }

        btn.MouseEnter:Connect(function()
            if self._activeTab~=tab then
                Tw(btn,{BackgroundTransparency=0.65,BackgroundColor3=T.ActTab},0.12):Play()
                Tw(lbl,{TextColor3=T.TxSec},0.12):Play()
            end
        end)
        btn.MouseLeave:Connect(function()
            if self._activeTab~=tab then
                Tw(btn,{BackgroundTransparency=1},0.12):Play()
                Tw(lbl,{TextColor3=T.TxMut},0.12):Play()
            end
        end)
        btn.MouseButton1Click:Connect(function() self:_switch(tab) end)
        table.insert(self._tabs,tab)
        if #self._tabs==1 then self:_switch(tab) end

        -- ════════════════════════════════════════════════════
        --  NewSection(name)
        -- ════════════════════════════════════════════════════
        function tab:NewSection(name)
            local T=self._T
            self._secCount=self._secCount+1
            local col=(self._secCount%2==1) and self._colA or self._colB

            -- section card
            local card=New("Frame",{
                Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundColor3=T.Card,BorderSizePixel=0,ZIndex=4,Parent=col,
            })
            Crn(6,card); Stk(T.Border,1,card)

            -- header
            local hdr=New("Frame",{
                Size=UDim2.new(1,0,0,28),BackgroundColor3=T.Surface,
                BorderSizePixel=0,ZIndex=5,Parent=card,
            })
            Crn(6,hdr)
            New("Frame",{   -- mask bottom corners of rounded header
                Size=UDim2.new(1,0,0,8),Position=UDim2.new(0,0,1,-8),
                BackgroundColor3=T.Surface,BorderSizePixel=0,ZIndex=6,Parent=hdr,
            })
            New("Frame",{   -- accent stripe
                Size=UDim2.new(0,2,0,14),Position=UDim2.new(0,8,0.5,-7),
                BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=7,Parent=hdr,
            })
            New("TextLabel",{
                Text=name,Font=Enum.Font.GothamBold,TextSize=10,
                TextColor3=T.TxSec,TextXAlignment=Enum.TextXAlignment.Left,
                Position=UDim2.new(0,17,0,0),Size=UDim2.new(1,-21,1,0),
                BackgroundTransparency=1,ZIndex=7,Parent=hdr,
            })

            -- elements list
            local elems=New("Frame",{
                Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                Position=UDim2.new(0,0,0,28),
                BackgroundTransparency=1,ZIndex=5,Parent=card,
            })
            VList(elems,0)

            -- ── element row factories ──────────────────────────
            local function Row(h)
                local r=New("Frame",{
                    Size=UDim2.new(1,0,0,h or 30),
                    BackgroundTransparency=1,ZIndex=6,Parent=elems,
                })
                New("Frame",{   -- separator
                    Size=UDim2.new(1,-16,0,1),Position=UDim2.new(0,8,1,-1),
                    BackgroundColor3=T.BdDim,BackgroundTransparency=0.5,
                    BorderSizePixel=0,ZIndex=6,Parent=r,
                })
                return r
            end

            -- left label + small info subtitle
            local function RowLabel(row,text,info)
                New("TextLabel",{
                    Text=text,Font=Enum.Font.Gotham,TextSize=11,
                    TextColor3=T.TxPrim,TextXAlignment=Enum.TextXAlignment.Left,
                    Position=UDim2.new(0,10,0,1),Size=UDim2.new(0.54,0,0,15),
                    BackgroundTransparency=1,ZIndex=7,Parent=row,
                })
                if info and info~="" then
                    New("TextLabel",{
                        Text=info,Font=Enum.Font.Gotham,TextSize=9,
                        TextColor3=T.TxInfo,TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,10,0,16),Size=UDim2.new(0.54,0,0,12),
                        BackgroundTransparency=1,ZIndex=7,Parent=row,
                    })
                end
            end

            -- ── Section object ─────────────────────────────────
            local Sec={_T=T,_elems=elems}

            -- ──────────────────────────────────────────────────
            --  NewButton(name, info, callback)
            -- ──────────────────────────────────────────────────
            function Sec:NewButton(name,info,cb)
                local r=Row(info~="" and 42 or 30)
                local btn=New("TextButton",{
                    Text="",Size=UDim2.new(1,0,1,0),
                    BackgroundTransparency=1,AutoButtonColor=false,ZIndex=7,Parent=r,
                })
                RowLabel(r,name,info)
                New("TextLabel",{
                    Text="›",Font=Enum.Font.GothamBold,TextSize=14,TextColor3=T.TxMut,
                    AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                    Size=UDim2.new(0,12,1,0),BackgroundTransparency=1,ZIndex=8,Parent=btn,
                })
                btn.MouseEnter:Connect(function()
                    Tw(r,{BackgroundColor3=T.Hover,BackgroundTransparency=0},0.1):Play()
                end)
                btn.MouseLeave:Connect(function()
                    Tw(r,{BackgroundTransparency=1},0.1):Play()
                end)
                btn.MouseButton1Click:Connect(function() if cb then task.spawn(cb) end end)
            end

            -- ──────────────────────────────────────────────────
            --  NewToggle(name, info, callback)
            -- ──────────────────────────────────────────────────
            function Sec:NewToggle(name,info,cb)
                local on=false
                local hasInfo=info and info~=""
                local r=Row(hasInfo and 42 or 30)
                RowLabel(r,name,info)
                local track=New("TextButton",{
                    Text="",Size=UDim2.new(0,32,0,17),
                    AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                    BackgroundColor3=T.ChkOff,AutoButtonColor=false,ZIndex=8,Parent=r,
                })
                Crn(9,track); Stk(T.Border,1,track)
                local knob=New("Frame",{
                    Size=UDim2.new(0,11,0,11),AnchorPoint=Vector2.new(0,0.5),
                    Position=UDim2.new(0,3,0.5,0),
                    BackgroundColor3=Color3.new(1,1,1),ZIndex=9,Parent=track,
                })
                Crn(6,knob)
                local function upd()
                    Tw(track,{BackgroundColor3=on and T.Accent or T.ChkOff},0.14):Play()
                    Tw(knob,{Position=on and UDim2.new(1,-14,0.5,0) or UDim2.new(0,3,0.5,0)},0.14):Play()
                end
                track.MouseButton1Click:Connect(function()
                    on=not on; upd()
                    if cb then task.spawn(cb,on) end
                end)

                return {
                    Set=function(_,v) on=v;upd();if cb then task.spawn(cb,on) end end,
                    Get=function(_) return on end,
                }
            end

            -- ──────────────────────────────────────────────────
            --  NewSlider(name, info, max, min, callback)
            -- ──────────────────────────────────────────────────
            function Sec:NewSlider(name,info,maxV,minV,cb)
                local hasInfo=info and info~=""
                local r=Row(hasInfo and 56 or 44)
                RowLabel(r,name,info)
                local val=minV or 0
                local valLbl=New("TextLabel",{
                    Text=tostring(val),Font=Enum.Font.GothamBold,TextSize=10,
                    TextColor3=T.Accent,TextXAlignment=Enum.TextXAlignment.Right,
                    AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-10,0,0),
                    Size=UDim2.new(0,40,0,22),BackgroundTransparency=1,ZIndex=8,Parent=r,
                })
                local trackY=hasInfo and 40 or 32
                local bg=New("Frame",{
                    Size=UDim2.new(1,-20,0,3),Position=UDim2.new(0,10,0,trackY),
                    BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=8,Parent=r,
                })
                Crn(2,bg)
                local fill=New("Frame",{
                    Size=UDim2.new(0,0,1,0),BackgroundColor3=T.Accent,
                    BorderSizePixel=0,ZIndex=9,Parent=bg,
                })
                Crn(2,fill)
                local knob=New("Frame",{
                    Size=UDim2.new(0,9,0,9),AnchorPoint=Vector2.new(0.5,0.5),
                    Position=UDim2.new(0,0,0.5,0),
                    BackgroundColor3=Color3.new(1,1,1),ZIndex=10,Parent=bg,
                })
                Crn(5,knob); Stk(T.Accent,2,knob)
                local mn=minV or 0; local mx=maxV or 100
                local function setVal(v)
                    val=math.clamp(v,mn,mx)
                    local rel=(val-mn)/(mx-mn)
                    fill.Size=UDim2.new(rel,0,1,0)
                    knob.Position=UDim2.new(rel,0,0.5,0)
                    valLbl.Text=tostring(val)
                    if cb then task.spawn(cb,val) end
                end
                local drag=false
                bg.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
                end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
                end)
                UIS.InputChanged:Connect(function(i)
                    if not drag or i.UserInputType~=Enum.UserInputType.MouseMovement then return end
                    local rel=math.clamp((i.Position.X-bg.AbsolutePosition.X)/bg.AbsoluteSize.X,0,1)
                    setVal(math.floor(mn+(mx-mn)*rel))
                end)
                return {Set=function(_,v) setVal(v) end, Get=function(_) return val end}
            end

            -- ──────────────────────────────────────────────────
            --  NewTextBox(name, info, callback)
            -- ──────────────────────────────────────────────────
            function Sec:NewTextBox(name,info,cb)
                local hasInfo=info and info~=""
                local r=Row(hasInfo and 42 or 30)
                RowLabel(r,name,info)
                local box=New("TextBox",{
                    PlaceholderText="...",Text="",
                    Font=Enum.Font.Gotham,TextSize=10,
                    TextColor3=T.TxPrim,PlaceholderColor3=T.TxMut,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    Size=UDim2.new(0.44,0,0,20),
                    AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                    BackgroundColor3=T.Surface,BorderSizePixel=0,
                    ClearTextOnFocus=false,ZIndex=8,Parent=r,
                })
                Crn(4,box)
                local bs=New("UIStroke",{Color=T.Border,Thickness=1,Parent=box})
                Pad(6,6,0,0,box)
                box.Focused:Connect(function()
                    Tw(box,{BackgroundColor3=T.Hover},0.12):Play(); bs.Color=T.Accent
                end)
                box.FocusLost:Connect(function(enter)
                    Tw(box,{BackgroundColor3=T.Surface},0.12):Play(); bs.Color=T.Border
