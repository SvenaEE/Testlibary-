                    end)
                    btn.MouseButton1Click:Connect(function() task.spawn(cb) end)
                end

                -- ── AddToggle ─────────────────────────────────
                function SEC:AddToggle(text, default, cb)
                    local on = default or false
                    local r  = Row()
                    RowText(r, text)

                    local track=New("TextButton",{
                        Text="",
                        Size=UDim2.new(0,32,0,17),
                        AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=on and T.Accent or T.CheckOff,
                        AutoButtonColor=false, ZIndex=8, Parent=r,
                    })
                    Crn(9,track)
                    Stk(T.Border,1,track)
                    local knob=New("Frame",{
                        Size=UDim2.new(0,11,0,11),
                        AnchorPoint=Vector2.new(0,0.5),
                        Position=on and UDim2.new(1,-14,0.5,0) or UDim2.new(0,3,0.5,0),
                        BackgroundColor3=Color3.new(1,1,1),
                        ZIndex=9, Parent=track,
                    })
                    Crn(6,knob)

                    local function upd()
                        Tw(track,{BackgroundColor3=on and T.Accent or T.CheckOff},0.14):Play()
                        Tw(knob,{Position=on and UDim2.new(1,-14,0.5,0) or UDim2.new(0,3,0.5,0)},0.14):Play()
                    end
                    track.MouseButton1Click:Connect(function()
                        on=not on; upd(); task.spawn(cb,on)
                    end)
                    return {
                        Set=function(_,v) on=v;upd();task.spawn(cb,on) end,
                        Get=function(_) return on end,
                    }
                end

                -- ── AddSlider ─────────────────────────────────
                function SEC:AddSlider(text, mn, mx, default, cb)
                    local val=math.clamp(default or mn, mn, mx)
                    local r=Row(44)
                    RowText(r, text)

                    local valLbl=New("TextLabel",{
                        Text=tostring(val),
                        Font=Enum.Font.GothamBold, TextSize=10,
                        TextColor3=T.Accent,
                        TextXAlignment=Enum.TextXAlignment.Right,
                        AnchorPoint=Vector2.new(1,0),
                        Position=UDim2.new(1,-10,0,0),
                        Size=UDim2.new(0,38,0,22),
                        BackgroundTransparency=1, ZIndex=8, Parent=r,
                    })

                    local trackBg=New("Frame",{
                        Size=UDim2.new(1,-20,0,3),
                        Position=UDim2.new(0,10,0,32),
                        BackgroundColor3=T.Border,
                        BorderSizePixel=0, ZIndex=8, Parent=r,
                    })
                    Crn(2,trackBg)
                    local fill=New("Frame",{
                        Size=UDim2.new((val-mn)/(mx-mn),0,1,0),
                        BackgroundColor3=T.Accent,
                        BorderSizePixel=0, ZIndex=9, Parent=trackBg,
                    })
                    Crn(2,fill)
                    local knob=New("Frame",{
                        Size=UDim2.new(0,9,0,9),
                        AnchorPoint=Vector2.new(0.5,0.5),
                        Position=UDim2.new((val-mn)/(mx-mn),0,0.5,0),
                        BackgroundColor3=Color3.new(1,1,1),
                        ZIndex=10, Parent=trackBg,
                    })
                    Crn(5,knob)
                    Stk(T.Accent,2,knob)

                    local drag=false
                    trackBg.InputBegan:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
                    end)
                    UserInputService.InputEnded:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
                    end)
                    UserInputService.InputChanged:Connect(function(i)
                        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
                            local rel=math.clamp((i.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1)
                            val=math.floor(mn+(mx-mn)*rel)
                            fill.Size=UDim2.new(rel,0,1,0)
                            knob.Position=UDim2.new(rel,0,0.5,0)
                            valLbl.Text=tostring(val)
                            task.spawn(cb,val)
                        end
                    end)
                    return {
                        Set=function(_,v)
                            val=math.clamp(v,mn,mx)
                            local rel=(val-mn)/(mx-mn)
                            fill.Size=UDim2.new(rel,0,1,0)
                            knob.Position=UDim2.new(rel,0,0.5,0)
                            valLbl.Text=tostring(val)
                            task.spawn(cb,val)
                        end,
                        Get=function(_) return val end,
                    }
                end

                -- ── AddDropdown ───────────────────────────────
                function SEC:AddDropdown(text, options, default, cb)
                    local sel=default or options[1]
                    local open=false
                    local r=Row()
                    RowText(r, text)

                    local dBtn=New("TextButton",{
                        Text="",
                        Size=UDim2.new(0.44,0,0,20),
                        AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=T.Surface,
                        AutoButtonColor=false, ZIndex=8, Parent=r,
                    })
                    Crn(4,dBtn); Stk(T.Border,1,dBtn)
                    local selLbl=New("TextLabel",{
                        Text=sel, Font=Enum.Font.Gotham, TextSize=10,
                        TextColor3=T.TextPrim,
                        TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,6,0,0),
                        Size=UDim2.new(1,-18,1,0),
                        BackgroundTransparency=1, ZIndex=9, Parent=dBtn,
                    })
                    local arrow=New("TextLabel",{
                        Text="▾", Font=Enum.Font.GothamBold, TextSize=8,
                        TextColor3=T.TextMuted,
                        AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-4,0.5,0),
                        Size=UDim2.new(0,10,1,0),
                        BackgroundTransparency=1, ZIndex=9, Parent=dBtn,
                    })

                    local panH=math.min(#options,6)*24+6
                    local panel=New("Frame",{
                        Size=UDim2.new(0.44,0,0,panH),
                        AnchorPoint=Vector2.new(1,0),
                        Position=UDim2.new(1,-10,1,2),
                        BackgroundColor3=T.Panel,
                        BorderSizePixel=0, Visible=false,
                        ZIndex=60, ClipsDescendants=true,
                        Parent=r,
                    })
                    Crn(5,panel); Stk(T.Border,1,panel)
                    local pScroll=New("ScrollingFrame",{
                        Size=UDim2.new(1,0,1,0),
                        BackgroundTransparency=1,
                        BorderSizePixel=0,
                        ScrollBarThickness=2,
                        ScrollBarImageColor3=T.Scroll,
                        CanvasSize=UDim2.new(0,0,0,0),
                        AutomaticCanvasSize=Enum.AutomaticSize.Y,
                        ZIndex=61, Parent=panel,
                    })
                    VList(pScroll,0); Pad(4,4,3,3,pScroll)

                    local function buildOpts()
                        for _,c in ipairs(pScroll:GetChildren()) do
                            if c:IsA("TextButton") then c:Destroy() end
                        end
                        for _,opt in ipairs(options) do
                            local ob=New("TextButton",{
                                Text=opt, Font=Enum.Font.Gotham, TextSize=10,
                                TextColor3=opt==sel and T.Accent or T.TextPrim,
                                TextXAlignment=Enum.TextXAlignment.Left,
                                Size=UDim2.new(1,0,0,24),
                                BackgroundColor3=T.SurfHov,
                                BackgroundTransparency=1,
                                AutoButtonColor=false, ZIndex=62,
                                Parent=pScroll,
                            })
                            Crn(3,ob); Pad(8,8,0,0,ob)
                            ob.MouseEnter:Connect(function() Tw(ob,{BackgroundTransparency=0},0.1):Play() end)
                            ob.MouseLeave:Connect(function() Tw(ob,{BackgroundTransparency=1},0.1):Play() end)
                            ob.MouseButton1Click:Connect(function()
                                sel=opt; selLbl.Text=opt
                                open=false; panel.Visible=false
                                Tw(arrow,{Rotation=0},0.14):Play()
                                buildOpts(); task.spawn(cb,opt)
                            end)
                        end
                    end
                    buildOpts()

                    dBtn.MouseButton1Click:Connect(function()
                        open=not open; panel.Visible=open
                        Tw(arrow,{Rotation=open and 180 or 0},0.14):Play()
                    end)
                    return {
                        Set=function(_,v) sel=v;selLbl.Text=v;buildOpts();task.spawn(cb,v) end,
                        Get=function(_) return sel end,
                        Refresh=function(_,o2) options=o2;buildOpts() end,
                    }
                end

                -- ── AddTextbox ────────────────────────────────
                function SEC:AddTextbox(text, placeholder, cb)
                    local r=Row()
                    RowText(r,text)
                    local box=New("TextBox",{
                        PlaceholderText=placeholder or "",
                        Text="", Font=Enum.Font.Gotham, TextSize=10,
                        TextColor3=T.TextPrim,
                        PlaceholderColor3=T.TextMuted,
                        TextXAlignment=Enum.TextXAlignment.Left,
                        Size=UDim2.new(0.44,0,0,20),
                        AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=T.Surface,
                        BorderSizePixel=0,
                        ClearTextOnFocus=false,
                        ZIndex=8, Parent=r,
                    })
                    Crn(4,box)
                    local bS=New("UIStroke",{Color=T.Border,Thickness=1,Parent=box})
                    Pad(6,6,0,0,box)
                    box.Focused:Connect(function()
                        Tw(box,{BackgroundColor3=T.SurfHov},0.12):Play()
                        bS.Color=T.Accent
                    end)
                    box.FocusLost:Connect(function(enter)
                        Tw(box,{BackgroundColor3=T.Surface},0.12):Play()
                        bS.Color=T.Border
                        if enter then task.spawn(cb,box.Text) end
                    end)
                    return {Get=function(_) return box.Text end, Set=function(_,v) box.Text=v end}
                end

                -- ── AddKeybind ────────────────────────────────
                function SEC:AddKeybind(text, default, cb)
                    local key=default; local binding=false
                    local r=Row()
                    RowText(r,text)
                    local kBtn=New("TextButton",{
                        Text=key and key.Name or "None",
                        Font=Enum.Font.GothamBold, TextSize=9,
                        TextColor3=T.Accent,
                        Size=UDim2.new(0.44,0,0,20),
                        AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=T.Surface,
                        AutoButtonColor=false, ZIndex=8, Parent=r,
                    })
                    Crn(4,kBtn); Stk(T.Border,1,kBtn)

                    -- Register in global keybind list
                    local kbEntry={label=text, key=key and key.Name or "None"}
                    table.insert(KeybindRegistry, kbEntry)

                    local function updateKBList()
                        kbEntry.key=key and key.Name or "None"
                        RebuildKeybindList()
                    end

                    kBtn.MouseButton1Click:Connect(function()
                        binding=true; kBtn.Text="..."; kBtn.TextColor3=T.Warning
                    end)
                    UserInputService.InputBegan:Connect(function(i,gp)
                        if binding and not gp then
                            binding=false; key=i.KeyCode
                            kBtn.Text=key.Name; kBtn.TextColor3=T.Accent
                            updateKBList()
                        elseif not binding and key and i.KeyCode==key then
                            task.spawn(cb,key)
                        end
                    end)
                    return {
                        Get=function(_) return key end,
                        Set=function(_,k)
                            key=k; kBtn.Text=k and k.Name or "None"; updateKBList()
                        end,
                    }
                end

                -- ── AddColorPicker ────────────────────────────
                function SEC:AddColorPicker(text, default, cb)
                    local color=default or Color3.fromRGB(255,50,50)
                    local open=false; local h,s,v=color:ToHSV()
                    local r=Row()
                    RowText(r,text)

                    local sw=New("TextButton",{
                        Text="", Size=UDim2.new(0,26,0,16),
                        AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=color,
                        AutoButtonColor=false, ZIndex=8, Parent=r,
                    })
                    Crn(4,sw); Stk(T.Border,1,sw)

                    local pp=New("Frame",{
                        Size=UDim2.new(0,155,0,130),
                        AnchorPoint=Vector2.new(1,0),
                        Position=UDim2.new(1,-10,1,4),
                        BackgroundColor3=T.Panel,
                        BorderSizePixel=0, Visible=false,
                        ZIndex=70, Parent=r,
                    })
                    Crn(7,pp); Stk(T.Border,1,pp); Pad(7,7,7,7,pp)

                    local hBar=New("ImageLabel",{
                        Image="rbxassetid://2615689002",
                        Size=UDim2.new(1,0,0,12),
                        BackgroundTransparency=1, ZIndex=71, Parent=pp,
                    })
                    Crn(4,hBar)
                    local hC=New("Frame",{
                        Size=UDim2.new(0,4,1,4),
                        AnchorPoint=Vector2.new(0.5,0.5),
                        Position=UDim2.new(h,0,0.5,0),
                        BackgroundColor3=Color3.new(1,1,1),
                        ZIndex=72, Parent=hBar,
                    })
                    Crn(2,hC)
                    local svC=New("ImageLabel",{
                        Image="rbxassetid://2615689003",
                        Size=UDim2.new(1,0,0,82),
                        Position=UDim2.new(0,0,0,18),
                        BackgroundColor3=Color3.fromHSV(h,1,1),
                        ZIndex=71, Parent=pp,
                    })
                    Crn(4,svC)
                    local svK=New("Frame",{
                        Size=UDim2.new(0,8,0,8),
                        AnchorPoint=Vector2.new(0.5,0.5),
                        Position=UDim2.new(s,0,1-v,0),
                        BackgroundColor3=Color3.new(1,1,1),
                        ZIndex=72, Parent=svC,
                    })
                    Crn(4,svK); Stk(Color3.new(0,0,0),1,svK)

                    local function upd()
                        color=Color3.fromHSV(h,s,v)
                        sw.BackgroundColor3=color
                        svC.BackgroundColor3=Color3.fromHSV(h,1,1)
                        hC.Position=UDim2.new(h,0,0.5,0)
                        svK.Position=UDim2.new(s,0,1-v,0)
                        task.spawn(cb,color)
                    end

                    local dH,dSV=false,false
                    hBar.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dH=true end end)
                    svC.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dSV=true end end)
                    UserInputService.InputEnded:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then dH=false;dSV=false end
                    end)
                    UserInputService.InputChanged:Connect(function(i)
                        if i.UserInputType~=Enum.UserInputType.MouseMovement then return end
                        if dH then h=math.clamp((i.Position.X-hBar.AbsolutePosition.X)/hBar.AbsoluteSize.X,0,1);upd()
                        elseif dSV then
                            s=math.clamp((i.Position.X-svC.AbsolutePosition.X)/svC.AbsoluteSize.X,0,1)
                            v=1-math.clamp((i.Position.Y-svC.AbsolutePosition.Y)/svC.AbsoluteSize.Y,0,1);upd()
                        end
                    end)
                    sw.MouseButton1Click:Connect(function() open=not open;pp.Visible=open end)
                    return {
                        Get=function(_) return color end,
                        Set=function(_,c) color=c;h,s,v=c:ToHSV();upd() end,
                    }
                end

                -- ── AddDivider ────────────────────────────────
                function SEC:AddDivider(labelText)
                    local r=New("Frame",{
                        Size=UDim2.new(1,0,0,15),
                        BackgroundTransparency=1, ZIndex=6,
                        Parent=elems,
                    })
                    New("Frame",{
                        Size=UDim2.new(1,-16,0,1),
                        Position=UDim2.new(0,8,0.5,0),
                        BackgroundColor3=T.Border,
                        BorderSizePixel=0, ZIndex=7, Parent=r,
                    })
                    if labelText and labelText~="" then
                        New("TextLabel",{
                            Text=labelText, Font=Enum.Font.GothamBold, TextSize=8,
                            TextColor3=T.TextMuted,
                            TextXAlignment=Enum.TextXAlignment.Center,
                            AnchorPoint=Vector2.new(0.5,0.5),
                            Position=UDim2.new(0.5,0,0.5,0),
                            Size=UDim2.new(0.55,0,1,0),
                            BackgroundColor3=T.Card,
                            ZIndex=8, Parent=r,
                        })
                    end
                end

                return SEC
            end  -- AddSection

            return page
        end  -- AddPage

        return tab
    end  -- AddTab

    -- ══════════════════════════════════════════════════════════
    --  Notify
    -- ══════════════════════════════════════════════════════════
    function Window:Notify(opts)
        opts=opts or {}
        local title=opts.Title or "Notice"
        local msg=opts.Message or ""
        local dur=opts.Duration or 4
        local T=self._T

        local card=New("Frame",{
            Size=UDim2.new(1,0,0,56),
            BackgroundColor3=T.Panel,
            BackgroundTransparency=0.04,
            ClipsDescendants=true, ZIndex=601,
            Parent=self._notifHolder,
        })
        Crn(6,card); Stk(T.Border,1,card)
        New("Frame",{
            Size=UDim2.new(0,2,1,0),
            BackgroundColor3=T.Accent,
            BorderSizePixel=0, ZIndex=602, Parent=card,
        })
        New("TextLabel",{
            Text=title, Font=Enum.Font.GothamBold, TextSize=11,
            TextColor3=T.TextPrim,
            TextXAlignment=Enum.TextXAlignment.Left,
            Position=UDim2.new(0,10,0,6),
            Size=UDim2.new(1,-14,0,14),
            BackgroundTransparency=1, ZIndex=603, Parent=card,
        })
        New("TextLabel",{
            Text=msg, Font=Enum.Font.Gotham, TextSize=10,
            TextColor3=T.TextSec,
            TextXAlignment=Enum.TextXAlignment.Left,
            TextWrapped=true,
            Position=UDim2.new(0,10,0,22),
            Size=UDim2.new(1,-14,0,26),
            BackgroundTransparency=1, ZIndex=603, Parent=card,
        })
        local prog=New("Frame",{
            Size=UDim2.new(1,0,0,2),
            Position=UDim2.new(0,0,1,-2),
            BackgroundColor3=T.Accent,
            BorderSizePixel=0, ZIndex=604, Parent=card,
        })
        Tw(prog,{Size=UDim2.new(0,0,0,2)},dur,Enum.EasingStyle.Linear):Play()
        card.Position=UDim2.new(1,10,0,0)
        Tw(card,{Position=UDim2.new(0,0,0,0)},0.26):Play()
        task.delay(dur,function()
            Tw(card,{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0)},0.2):Play()
            task.delay(0.22,function() card:Destroy() end)
        end)
    end

    return Window
end

return Library
