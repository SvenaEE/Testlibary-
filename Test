local function Tween(obj, props, t, s, d)
	return TweenService:Create(obj, TweenInfo.new(t or 0.15, s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out), props);
end

local function Make(cls, props)
	local o = Instance.new(cls);
	for k, v in pairs(props or {}) do
		if k ~= "Parent" then o[k] = v; end
	end
	if props and props.Parent then o.Parent = props.Parent; end
	return o;
end

local function Corner(radius, parent)
	local o = Instance.new("UICorner");
	o.CornerRadius = UDim.new(0, radius);
	o.Parent = parent;
end

local function Stroke(color, thickness, parent)
	local o = Instance.new("UIStroke");
	o.Color = color;
	o.Thickness = thickness or 1;
	o.Parent = parent;
end

local function Padding(l, r, t, b, parent)
	local o = Instance.new("UIPadding");
	o.PaddingLeft = UDim.new(0, l);
	o.PaddingRight = UDim.new(0, r);
	o.PaddingTop = UDim.new(0, t);
	o.PaddingBottom = UDim.new(0, b);
	o.Parent = parent;
end

local function ListLayout(parent, gap)
	local o = Instance.new("UIListLayout");
	o.SortOrder = Enum.SortOrder.LayoutOrder;
	o.Padding = UDim.new(0, gap or 0);
	o.FillDirection = Enum.FillDirection.Vertical;
	o.HorizontalAlignment = Enum.HorizontalAlignment.Left;
	o.Parent = parent;
end

