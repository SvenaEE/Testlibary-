	RunService.Heartbeat:Connect(function(dt)
		table.insert(fpsHistory, dt)
		if #fpsHistory > 30 then table.remove(fpsHistory, 1) end
		if #fpsHistory == 30 then
			local sum = 0
			for _, v in ipairs(fpsHistory) do sum += v end
			fpsCounter.Text = tostring(math.round(1 / (sum / 30)))
		end
	end)

	-- ── Ping counter ─────────────────────────────────────────────────────────
	RunService.Heartbeat:Connect(function()
		pingCounter.Text = tostring(math.round(LocalPlayer:GetNetworkPing() * 1000)) .. "ms"
	end)

	-- ── Toggle (Insert key) ───────────────────────────────────────────────────
	-- homePos stores each tab's "visible" position so toggle always
	-- returns to the right place even after dragging.
	local homePos   = {}   -- [tabFrame] = UDim2  (updated after drag)
	local isVisible  = true
	local isTweening = false

	local tweenOut = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
	local tweenIn  = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

	local OFFSCREEN_X = -1900  -- px to slide off to the left

	local function hiddenPos(tab)
		local h = homePos[tab] or tab.Position
		return UDim2.new(0, h.X.Offset + OFFSCREEN_X, 0, h.Y.Offset)
	end

	local function slideAll(info, targetFn, onDone)
		isTweening = true
		local done = 0
		if #tabs == 0 then isTweening = false if onDone then onDone() end return end
		for _, tab in ipairs(tabs) do
			local t = TweenService:Create(tab, info, {Position = targetFn(tab)})
			t:Play()
			t.Completed:Connect(function()
				done += 1
				if done >= #tabs then
					isTweening = false
					if onDone then onDone() end
				end
			end)
		end
	end

	ContextActionService:BindAction("ToggleUI", function(_, inputState, _)
		if inputState ~= Enum.UserInputState.Begin then return end
		if isTweening then return end

		if isVisible then
			-- Save current positions as home before sliding out
			for _, tab in ipairs(tabs) do
				homePos[tab] = tab.Position
			end
			isVisible = false
			slideAll(tweenOut, hiddenPos, function()
				layoutFrame.Visible = false
			end)
		else
			-- Snap to off-screen, then tween back to home
			for _, tab in ipairs(tabs) do
				tab.Position = hiddenPos(tab)
			end
			layoutFrame.Visible = true
			isVisible = true
			slideAll(tweenIn, function(tab)
				return homePos[tab] or tab.Position
			end)
		end
	end, false, Enum.KeyCode.Insert)

	-- ── Tab column positions (auto-layout left to right) ─────────────────────
	local TAB_PADDING = 22   -- px gap between tabs
	local TAB_START_X = 22   -- px from left edge
	local TAB_START_Y = 26   -- px from top edge
	local TAB_WIDTH   = 259

	-- Tab icon pool (cycles through for each new tab)
	local TAB_ICONS = {
		"rbxassetid://81872698913435",    -- sword  (Combat)
		"rbxassetid://112426178972099",   -- run    (Movement)
		"rbxassetid://125020872044147",   -- player (Player)
		"rbxassetid://100033680381365",   -- eye    (Render)
		"rbxassetid://120517954878160",   -- star   (Misc)
		"rbxassetid://116544501716299",   -- gear   (Setting)
	}

	-- ── Window:Tab(name, visible) ─────────────────────────────────────────────
	function Window:Tab(name, visible)
		tabCount += 1
		local idx = tabCount

		-- Default height; no content yet so keep it slim.
		-- Users can extend it by calling tab methods later.
		local TAB_HEIGHT = 200

		-- Calculate X position (side by side)
		local posX = TAB_START_X + (idx - 1) * (TAB_WIDTH + TAB_PADDING)

		-- ── Tab frame ────────────────────────────────────────────────────────
		local tabFrame = Instance.new("Frame", layoutFrame)
		tabFrame.Name             = "Tab_" .. name
		tabFrame.Size             = UDim2.new(0, TAB_WIDTH, 0, TAB_HEIGHT)
		tabFrame.Position         = UDim2.new(0, posX, 0, TAB_START_Y)
		tabFrame.BackgroundColor3 = Color3.fromRGB(9, 9, 12)
		tabFrame.BorderSizePixel  = 0
		tabFrame.Visible          = (visible ~= false)

		local tabCorner = Instance.new("UICorner", tabFrame)
		tabCorner.CornerRadius = UDim.new(0, 8)

		local tabStroke = Instance.new("UIStroke", tabFrame)
		tabStroke.Thickness = 1.5
		tabStroke.Color     = Color3.fromRGB(24, 25, 30)

		-- Drop shadow
		local shadowHolder = Instance.new("Frame", tabFrame)
		shadowHolder.Name               = "DropShadowHolder"
		shadowHolder.Size               = UDim2.new(1, 0, 1, 0)
		shadowHolder.BackgroundTransparency = 1
		shadowHolder.BorderSizePixel    = 0
		shadowHolder.ZIndex             = 0

		local shadow = Instance.new("ImageLabel", shadowHolder)
		shadow.Name               = "DropShadow"
		shadow.Size               = UDim2.new(1, 47, 1, 47)
		shadow.AnchorPoint        = Vector2.new(0.5, 0.5)
		shadow.Position           = UDim2.new(0.5, 0, 0.5, 0)
		shadow.BackgroundTransparency = 1
		shadow.BorderSizePixel    = 0
		shadow.Image              = "rbxassetid://6014261993"
		shadow.ImageColor3        = Color3.fromRGB(9, 9, 12)
		shadow.ImageTransparency  = 0.5
		shadow.ScaleType          = Enum.ScaleType.Slice
		shadow.SliceCenter        = Rect.new(49, 49, 450, 450)
		shadow.ZIndex             = 0

		-- ── Title bar (drag handle) ───────────────────────────────────────────
		local titleBar = Instance.new("Frame", tabFrame)
		titleBar.Name             = "UiLayourNameIcon"
		titleBar.Size             = UDim2.new(0, TAB_WIDTH, 0, 34)
		titleBar.Position         = UDim2.new(0, 0, 0, 0)
		titleBar.BackgroundColor3 = Color3.fromRGB(14, 14, 19)
		titleBar.BorderSizePixel  = 0

		local titleCorner = Instance.new("UICorner", titleBar)
		titleCorner.CornerRadius = UDim.new(0, 8)

		-- Icon
		local icon = Instance.new("ImageLabel", titleBar)
		icon.Size                = UDim2.new(0, 19, 0, 19)
		icon.Position            = UDim2.new(0, 10, 0.5, -9)
		icon.BackgroundTransparency = 1
		icon.BorderSizePixel     = 0
		icon.Image               = TAB_ICONS[((idx - 1) % #TAB_ICONS) + 1]
		icon.ImageColor3         = Color3.fromRGB(182, 182, 198)

		-- Name label
		local nameLabel = Instance.new("TextLabel", titleBar)
		nameLabel.Size                  = UDim2.new(1, -40, 1, 0)
		nameLabel.Position              = UDim2.new(0, 36, 0, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.BorderSizePixel       = 0
		nameLabel.FontFace              = Font.new([[rbxasset://fonts/families/JosefinSans.json]], Enum.FontWeight.Regular, Enum.FontStyle.Normal)
		nameLabel.TextSize              = 16
		nameLabel.TextColor3            = Color3.fromRGB(255, 255, 255)
		nameLabel.TextXAlignment        = Enum.TextXAlignment.Left
		nameLabel.Text                  = name

		local nameGrad = Instance.new("UIGradient", nameLabel)
		nameGrad.Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0,     Color3.fromRGB(204, 218, 255)),
			ColorSequenceKeypoint.new(0.502, Color3.fromRGB(255, 220, 220)),
			ColorSequenceKeypoint.new(1,     Color3.fromRGB(229, 236, 255)),
		}

		-- Separator line under title bar
		local sep = Instance.new("Frame", tabFrame)
		sep.Name             = "IgnoreLine"
		sep.Size             = UDim2.new(0, 246, 0, 3)
		sep.Position         = UDim2.new(0, 6, 0, 37)
		sep.BackgroundColor3 = Color3.fromRGB(82, 82, 111)
		sep.BorderSizePixel  = 0
		local sepCorner = Instance.new("UICorner", sep)
		sepCorner.CornerRadius = UDim.new(0, 5)

		-- Glow pulse on separator
		local glow = Instance.new("ImageLabel", sep)
		glow.Name               = "GlowEffect"
		glow.Size               = UDim2.new(1.3, 0, 1.3, 0)
		glow.Position           = UDim2.new(-0.15, 0, -0.15, 0)
		glow.BackgroundTransparency = 1
		glow.BorderSizePixel    = 0
		glow.Image              = "rbxassetid://15379289405"
		glow.ImageColor3        = Color3.fromRGB(81, 81, 110)
		glow.ImageTransparency  = 0.35
		glow.ZIndex             = 0
		task.spawn(function()
			while glow.Parent do
				glow.ImageTransparency = 0.25 + math.sin(tick() * 3) * 0.1
				task.wait(0.03)
			end
		end)

		-- Content scrolling frame
		local content = Instance.new("ScrollingFrame", tabFrame)
		content.Name                   = "ScrollingFrameFeatureInHere"
		content.Size                   = UDim2.new(0, TAB_WIDTH, 1, -44)
		content.Position               = UDim2.new(0, 0, 0, 44)
		content.BackgroundTransparency = 1
		content.BorderSizePixel        = 0
		content.ScrollBarThickness     = 3
		content.ScrollBarImageColor3   = Color3.fromRGB(82, 82, 111)
		content.ScrollBarImageTransparency = 0.6
		content.CanvasSize             = UDim2.new(0, 0, 0, 0)
		content.AutomaticCanvasSize    = Enum.AutomaticSize.Y

		local contentCorner = Instance.new("UICorner", content)
		contentCorner.CornerRadius = UDim.new(0, 4)

		local contentLayout = Instance.new("UIListLayout", content)
		contentLayout.SortOrder    = Enum.SortOrder.LayoutOrder
		contentLayout.Padding      = UDim.new(0, 6)

		local contentPadding = Instance.new("UIPadding", content)
		contentPadding.PaddingLeft   = UDim.new(0, 8)
		contentPadding.PaddingRight  = UDim.new(0, 8)
		contentPadding.PaddingTop    = UDim.new(0, 6)
		contentPadding.PaddingBottom = UDim.new(0, 6)

		-- Register tab for toggle sliding
		table.insert(tabs, tabFrame)

		-- Make tab draggable (smooth) using title bar as handle
		-- Also update homePos when drag ends so toggle returns to new spot
		makeDraggable(tabFrame, titleBar)
		titleBar.InputEnded:Connect(function(input)
			if input.UserInputType ~= Enum.UserInputType.MouseButton1
				and input.UserInputType ~= Enum.UserInputType.Touch then return end
			homePos[tabFrame] = tabFrame.Position
		end)

		-- Auto-resize tab height based on content
		contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			local newH = math.max(80, contentLayout.AbsoluteContentSize.Y + 44 + 16)
			tabFrame.Size = UDim2.new(0, TAB_WIDTH, 0, newH)
		end)

		-- ── Tab API ──────────────────────────────────────────────────────────
		local Tab = {}

		-- Show / hide the tab
		function Tab:SetVisible(v)
			tabFrame.Visible = v
		end

		return Tab
	end

	return Window
end

return Library
