	local function hiddenPos(tab)
		local h = homePos[tab] or tab.Position;
		return UDim2.new(0, h.X.Offset + G2L["OFFSCREEN_X"], 0, h.Y.Offset);
	end;

	local function slideAll(info, targetFn, onDone)
		isTweening = true;
		local done = 0;
		if #tabs == 0 then isTweening = false; if onDone then onDone() end; return end;
		for _, tab in ipairs(tabs) do
			local t = G2L["svc_tween"]:Create(tab, info, {["Position"] = targetFn(tab)});
			t:Play();
			t.Completed:Connect(function()
				done += 1;
				if done >= #tabs then
					isTweening = false;
					if onDone then onDone() end;
				end;
			end);
		end;
	end;

	G2L["svc_cas"]:BindAction("ToggleUI", function(_, inputState, _)
		if inputState ~= Enum.UserInputState.Begin then return end;
		if isTweening then return end;
		if isVisible then
			for _, tab in ipairs(tabs) do homePos[tab] = tab.Position end;
			isVisible = false;
			slideAll(G2L["TWEEN_OUT"], hiddenPos, function()
				G2L["layout"]["Visible"] = false;
			end);
		else
			for _, tab in ipairs(tabs) do tab["Position"] = hiddenPos(tab) end;
			G2L["layout"]["Visible"] = true;
			isVisible = true;
			slideAll(G2L["TWEEN_IN"], function(tab) return homePos[tab] or tab.Position end);
		end;
	end, false, Enum.KeyCode.Insert);

