-- ─────────────────────────────────────────────────────────────────────────────
-- Library:Notify(title, text, duration)
-- Shows a notification in the bottom-right corner.
-- The progress bar at the bottom shrinks over `duration` seconds,
-- then the notification slides out and fades away.
-- ─────────────────────────────────────────────────────────────────────────────

local G2L_notifyHolder = nil;  -- created once on first notify

local function ensureNotifyHolder()
	if G2L_notifyHolder then return end;
	local playerGui = G2L["localplayer"]:WaitForChild("PlayerGui");
	-- Find or reuse existing UILibrary ScreenGui
	local sg = playerGui:FindFirstChild("UILibrary") or playerGui;
	G2L_notifyHolder = Instance.new("Frame", sg);
	G2L_notifyHolder["Name"]             = [[NotifyHolder]];
	G2L_notifyHolder["Size"]             = UDim2.new(0, 245, 1, 0);
	G2L_notifyHolder["AnchorPoint"]      = Vector2.new(1, 1);
	G2L_notifyHolder["Position"]         = UDim2.new(1, -10, 1, -10);
	G2L_notifyHolder["BackgroundTransparency"] = 1;
	G2L_notifyHolder["BorderSizePixel"]  = 0;
	-- Stack notifications bottom-up
	local G2L_nhl = Instance.new("UIListLayout", G2L_notifyHolder);
	G2L_nhl["SortOrder"]        = Enum.SortOrder.LayoutOrder;
	G2L_nhl["VerticalAlignment"] = Enum.VerticalAlignment.Bottom;
	G2L_nhl["Padding"]          = UDim.new(0, 6);
	G2L_nhl["FillDirection"]    = Enum.FillDirection.Vertical;
end;

function Library:Notify(title, text, duration)
	duration = duration or 3;
	ensureNotifyHolder();

	-- StarterGui.UILibrary.NotifyHolder.NotifyFrame
	local G2L_nf = Instance.new("Frame", G2L_notifyHolder);
	G2L_nf["Name"]             = [[NotifyFrame]];
	G2L_nf["Size"]             = UDim2.new(1, 0, 0, 72);
	G2L_nf["BackgroundColor3"] = Color3.fromRGB(17, 17, 23);
	G2L_nf["BorderSizePixel"]  = 0;
	G2L_nf["LayoutOrder"]      = tick();
	G2L_nf["BackgroundTransparency"] = 1;  -- start invisible, slide in
	local G2L_nfc = Instance.new("UICorner", G2L_nf);
	G2L_nfc["CornerRadius"] = UDim.new(0, 6);
	local G2L_nfs = Instance.new("UIStroke", G2L_nf);
	G2L_nfs["Thickness"] = 1;
	G2L_nfs["Color"]     = Color3.fromRGB(40, 40, 55);
	G2L_nfs["Transparency"] = 1;

	-- StarterGui.UILibrary.NotifyHolder.NotifyFrame.NotifyTextLabel (title)
	local G2L_ntitle = Instance.new("TextLabel", G2L_nf);
	G2L_ntitle["Name"]               = [[NotifyTextLabel]];
	G2L_ntitle["Size"]               = UDim2.new(1, -12, 0, 18);
	G2L_ntitle["Position"]           = UDim2.new(0, 10, 0, 8);
	G2L_ntitle["BackgroundTransparency"] = 1;
	G2L_ntitle["BorderSizePixel"]    = 0;
	G2L_ntitle["FontFace"]           = G2L["FONT_JOSEFIN_B"];
	G2L_ntitle["TextSize"]           = 13;
	G2L_ntitle["TextColor3"]         = Color3.fromRGB(255, 255, 255);
	G2L_ntitle["TextXAlignment"]     = Enum.TextXAlignment.Left;
	G2L_ntitle["Text"]               = title or [[Notify]];
	G2L_ntitle["TextTransparency"]   = 1;

	-- StarterGui.UILibrary.NotifyHolder.NotifyFrame.Text Go in here frame
	local G2L_nbody = Instance.new("TextLabel", G2L_nf);
	G2L_nbody["Name"]               = [[NotifyBody]];
	G2L_nbody["Size"]               = UDim2.new(1, -12, 0, 30);
	G2L_nbody["Position"]           = UDim2.new(0, 10, 0, 28);
	G2L_nbody["BackgroundTransparency"] = 1;
	G2L_nbody["BorderSizePixel"]    = 0;
	G2L_nbody["FontFace"]           = G2L["FONT_JOSEFIN_B"];
	G2L_nbody["TextSize"]           = 12;
	G2L_nbody["TextColor3"]         = Color3.fromRGB(180, 180, 200);
	G2L_nbody["TextXAlignment"]     = Enum.TextXAlignment.Left;
	G2L_nbody["TextYAlignment"]     = Enum.TextYAlignment.Top;
	G2L_nbody["TextWrapped"]        = true;
	G2L_nbody["Text"]               = text or [[]];
	G2L_nbody["TextTransparency"]   = 1;

	-- StarterGui.UILibrary.NotifyHolder.NotifyFrame.IGNORELINE NO TOUCH (progress bar bg)
	local G2L_progBg = Instance.new("Frame", G2L_nf);
	G2L_progBg["Name"]             = [[ProgressBg]];
	G2L_progBg["Size"]             = UDim2.new(1, 0, 0, 3);
	G2L_progBg["Position"]         = UDim2.new(0, 0, 1, -3);
	G2L_progBg["BackgroundColor3"] = Color3.fromRGB(30, 30, 40);
	G2L_progBg["BorderSizePixel"]  = 0;
	G2L_progBg["BackgroundTransparency"] = 1;
	local G2L_progBgc = Instance.new("UICorner", G2L_progBg);
	G2L_progBgc["CornerRadius"] = UDim.new(0, 3);

	-- StarterGui.UILibrary.NotifyHolder.NotifyFrame.IGNORELINE NO TOCUHI (progress fill)
	local G2L_prog = Instance.new("Frame", G2L_progBg);
	G2L_prog["Name"]             = [[IGNORELINE NO TOCUHI]];
	G2L_prog["Size"]             = UDim2.new(1, 0, 1, 0);
	G2L_prog["BackgroundColor3"] = Color3.fromRGB(82, 82, 111);
	G2L_prog["BorderSizePixel"]  = 0;
	G2L_prog["BackgroundTransparency"] = 1;
	local G2L_progc = Instance.new("UICorner", G2L_prog);
	G2L_progc["CornerRadius"] = UDim.new(0, 3);

	-- Slide in from right + fade in
	G2L_nf["Position"] = UDim2.new(1, 10, 0, 0);  -- start off-screen right

	local tweenFadeIn  = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out);
	local tweenFadeOut = TweenInfo.new(0.4,  Enum.EasingStyle.Quint, Enum.EasingDirection.In);
	local tweenProg    = TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out);

	-- Slide + fade in
	G2L["svc_tween"]:Create(G2L_nf, tweenFadeIn, {
		["Position"]           = UDim2.new(0, 0, 0, 0);
		["BackgroundTransparency"] = 0;
	}):Play();
	G2L["svc_tween"]:Create(G2L_nfs, tweenFadeIn, {["Transparency"] = 0}):Play();
	G2L["svc_tween"]:Create(G2L_ntitle, tweenFadeIn, {["TextTransparency"] = 0}):Play();
	G2L["svc_tween"]:Create(G2L_nbody,  tweenFadeIn, {["TextTransparency"] = 0}):Play();
	G2L["svc_tween"]:Create(G2L_progBg, tweenFadeIn, {["BackgroundTransparency"] = 0}):Play();
	G2L["svc_tween"]:Create(G2L_prog,   tweenFadeIn, {["BackgroundTransparency"] = 0}):Play();

	-- Progress bar shrinks over duration
	task.delay(0.35, function()
		G2L["svc_tween"]:Create(G2L_prog, tweenProg, {
			["Size"] = UDim2.new(0, 0, 1, 0);
		}):Play();
	end);

	-- After duration: slide out to right + fade out, then destroy
	task.delay(duration + 0.35, function()
		G2L["svc_tween"]:Create(G2L_nf, tweenFadeOut, {
			["Position"]           = UDim2.new(1, 10, 0, 0);
			["BackgroundTransparency"] = 1;
		}):Play();
		G2L["svc_tween"]:Create(G2L_nfs,    tweenFadeOut, {["Transparency"]     = 1}):Play();
		G2L["svc_tween"]:Create(G2L_ntitle, tweenFadeOut, {["TextTransparency"] = 1}):Play();
		G2L["svc_tween"]:Create(G2L_nbody,  tweenFadeOut, {["TextTransparency"] = 1}):Play();
		G2L["svc_tween"]:Create(G2L_progBg, tweenFadeOut, {["BackgroundTransparency"] = 1}):Play();
		G2L["svc_tween"]:Create(G2L_prog,   tweenFadeOut, {["BackgroundTransparency"] = 1}):Play();
		task.delay(0.45, function()
			if G2L_nf and G2L_nf.Parent then
				G2L_nf:Destroy();
			end;
		end);
	end);
end;

return Library;
