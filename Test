	-- ── Hue bar (vertical, right side) ────────────────────────────────────────
	-- Build hue gradient from ColorSequence since rbx asset may not load
	local G2L_huebar = Instance.new("Frame", G2L_wrap);
	G2L_huebar["Name"]             = [[HueBar]];
	G2L_huebar["Size"]             = UDim2.new(0, 16, 0, 130);
