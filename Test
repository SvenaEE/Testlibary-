		if self._activeTab == tab then return end
		if self._activeTab then
			local prev = self._activeTab
			if prev._frame then prev._frame.Visible = false end
			tween(prev._btn, { BackgroundTransparency = 1 }, 0.14)
			prev._line.Visible = false
			tween(prev._lbl, { TextColor3 = col.txmut }, 0.14)
		end
