		if tab._frame then tab._frame.Visible = true end
		tab._line.Visible = true
		tween(tab._btn, { BackgroundTransparency = 0, BackgroundColor3 = col.acttab }, 0.14)
		tween(tab._lbl, { TextColor3 = col.txprim }, 0.14)
