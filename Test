-- ── addHoverFx: shimmer sweep + sparkles + background brighten ───────────────
local function addHoverFx(row)
	local baseCol = row.BackgroundColor3;

	local G2L_sh = Instance.new("Frame", row);
	G2L_sh["Name"]             = [[Shimmer]];
	G2L_sh["ZIndex"]           = 5;
	G2L_sh["BorderSizePixel"]  = 0;
	G2L_sh["BackgroundColor3"] = Color3.fromRGB(255, 255, 255);
	G2L_sh["BackgroundTransparency"] = 1;
	G2L_sh["Size"]             = UDim2.new(0.4, 0, 1, 0);
	G2L_sh["Position"]         = UDim2.new(-0.4, 0, 0, 0);
	G2L_sh["ClipsDescendants"] = false;
	local G2L_shc = Instance.new("UICorner", G2L_sh);
	G2L_shc["CornerRadius"] = UDim.new(0, 6);
	local G2L_shg = Instance.new("UIGradient", G2L_sh);
	G2L_shg["Transparency"] = NumberSequence.new{
		NumberSequenceKeypoint.new(0,   1);
		NumberSequenceKeypoint.new(0.5, 0.88);
		NumberSequenceKeypoint.new(1,   1);
	};

	local isHovered = false;

	row.MouseEnter:Connect(function()
		if isHovered then return end;
		isHovered = true;
		G2L["svc_tween"]:Create(row, G2L["TWEEN_FADE"], {["BackgroundColor3"] = G2L["HOVER_COL"]}):Play();
		G2L_sh["Position"] = UDim2.new(-0.4, 0, 0, 0);
		G2L_sh["BackgroundTransparency"] = 0.88;
		G2L["svc_tween"]:Create(G2L_sh, G2L["TWEEN_SHIMMER"], {["Position"] = UDim2.new(1.1, 0, 0, 0)}):Play();
		task.delay(0.36, function()
			G2L_sh["BackgroundTransparency"] = 1;
			G2L_sh["Position"] = UDim2.new(-0.4, 0, 0, 0);
		end);
		for i = 1, math.random(3, 5) do
			task.delay((i - 1) * 0.07, function()
				if isHovered then spawnSparkle(row) end;
			end);
		end;
	end);

	row.MouseLeave:Connect(function()
		isHovered = false;
		G2L["svc_tween"]:Create(row, G2L["TWEEN_FADE"], {["BackgroundColor3"] = baseCol}):Play();
		G2L_sh["BackgroundTransparency"] = 1;
	end);
end;

-- ── makeDraggable: smooth lerp drag ──────────────────────────────────────────
local function makeDraggable(frame, handle)
	handle["Active"] = true;
	local dragging = false;
	local dragConn = nil;
	local curX, curY, wantX, wantY = 0, 0, 0, 0;

	handle.InputBegan:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1
			and input.UserInputType ~= Enum.UserInputType.Touch then return end;
		dragging = true;
		local ap = frame.AbsolutePosition;
		frame["AnchorPoint"] = Vector2.new(0, 0);
		frame["Position"]    = UDim2.new(0, ap.X, 0, ap.Y);
		local mp   = G2L["svc_input"]:GetMouseLocation();
		local offX = mp.X - ap.X;
		local offY = mp.Y - ap.Y;
		curX = ap.X; curY = ap.Y; wantX = ap.X; wantY = ap.Y;
		dragConn = G2L["svc_run"].Heartbeat:Connect(function(dt)
			if not dragging then return end;
			local m  = G2L["svc_input"]:GetMouseLocation();
			local vp = workspace.CurrentCamera.ViewportSize;
			wantX = math.clamp(m.X - offX, 0, vp.X - frame.AbsoluteSize.X);
			wantY = math.clamp(m.Y - offY, 0, vp.Y - frame.AbsoluteSize.Y);
			local a = math.clamp(dt / G2L["DRAG_SMOOTH"], 0, 1);
			curX = curX + (wantX - curX) * a;
			curY = curY + (wantY - curY) * a;
			frame["Position"] = UDim2.new(0, curX, 0, curY);
		end);
	end);

	handle.InputEnded:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1
			and input.UserInputType ~= Enum.UserInputType.Touch then return end;
		dragging = false;
		if dragConn then dragConn:Disconnect(); dragConn = nil; end;
	end);
end;

