		G2L_seg["ZIndex"]           = 1;
		local G2L_segGrad = Instance.new("UIGradient", G2L_seg);
		G2L_segGrad["Color"]    = ColorSequence.new(hueColors[i], hueColors[i+1]);
		G2L_segGrad["Rotation"] = 90;
