			local function setExpanded(newExpanded)
				expanded = newExpanded
				expandBtn.Image = expanded
					and "rbxassetid://121304296213645"  -- minimize/hide icon
					or  "rbxassetid://112384738137814"  -- expand/show icon
				local targetH = expanded and subPanel.AbsoluteSize.Y or 0
				TweenService:Create(clipper, tweenSlide, {
