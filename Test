-- ── Smooth drag helper ───────────────────────────────────────────────────────
-- Lerps the frame position toward the mouse for a smooth "floating" feel
local DRAG_SMOOTH = 0.18  -- lower = smoother/slower, higher = snappier

local function makeDraggable(frame, handle)
	handle.Active = true

	local dragging  = false
	local dragConn  = nil
	local curX      = 0
	local curY      = 0
	local wantX     = 0
	local wantY     = 0

	handle.InputBegan:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1
			and input.UserInputType ~= Enum.UserInputType.Touch then return end

		dragging = true

		-- Normalise: reset AnchorPoint and convert to pure pixel position
		-- so drag math is always simple and consistent
		local ap   = frame.AbsolutePosition  -- top-left pixel, ignores AnchorPoint
		frame.AnchorPoint = Vector2.new(0, 0)
		frame.Position    = UDim2.new(0, ap.X, 0, ap.Y)

		local mp  = UserInputService:GetMouseLocation()
		local offX = mp.X - ap.X
		local offY = mp.Y - ap.Y

		curX  = ap.X
		curY  = ap.Y
		wantX = ap.X
		wantY = ap.Y

		dragConn = RunService.Heartbeat:Connect(function(dt)
			if not dragging then return end

			local m  = UserInputService:GetMouseLocation()
			local vp = workspace.CurrentCamera.ViewportSize

			wantX = math.clamp(m.X - offX, 0, vp.X - frame.AbsoluteSize.X)
			wantY = math.clamp(m.Y - offY, 0, vp.Y - frame.AbsoluteSize.Y)

			-- Smooth lerp toward want position
			local alpha = math.clamp(dt / DRAG_SMOOTH, 0, 1)
			curX = curX + (wantX - curX) * alpha
			curY = curY + (wantY - curY) * alpha

			frame.Position = UDim2.new(0, curX, 0, curY)
		end)
	end)

	handle.InputEnded:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1
			and input.UserInputType ~= Enum.UserInputType.Touch then return end
		dragging = false
		if dragConn then
			dragConn:Disconnect()
			dragConn = nil
		end
	end)
end

