		local G2L_tspl = Instance.new("UIListLayout", G2L_tsubp);
		G2L_tspl["SortOrder"] = Enum.SortOrder.LayoutOrder;
		G2L_tspl["Padding"]   = UDim.new(0, 6);
		local G2L_tspp = Instance.new("UIPadding", G2L_tsubp);
		G2L_tspp["PaddingLeft"]   = UDim.new(0, 8);
		G2L_tspp["PaddingRight"]  = UDim.new(0, 8);
		G2L_tspp["PaddingTop"]    = UDim.new(0, 8);
		G2L_tspp["PaddingBottom"] = UDim.new(0, 8);

		local G2L_tclip = makeClipper(G2L_themeWrap, 2);
		G2L_tsubp["Parent"] = G2L_tclip;

		local tExpanded = false;
		local function setThemeExpanded(v)
			tExpanded = v;
			G2L_thicon["Image"] = tExpanded
				and [[rbxassetid://121304296213645]]
				or  [[rbxassetid://112384738137814]];
			task.defer(function()
				local targetH = tExpanded and G2L_tsubp.AbsoluteSize.Y or 0;
				G2L["svc_tween"]:Create(G2L_tclip, G2L["TWEEN_SLIDE"], {
					["Size"] = UDim2.new(1, 0, 0, targetH);
				}):Play();
			end);
		end;
		G2L_thdr.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.MouseButton2 then
				setThemeExpanded(not tExpanded);
			end;
		end);
		G2L_thicon.MouseButton1Click:Connect(function() setThemeExpanded(not tExpanded) end);

		-- StarterGui.UILibrary.Setting.ThemeSection.ColorPicker (Color)
		makeToggleColorRow(G2L_tsubp, "Color", 12, true,
			Color3.fromRGB(255, 255, 255),
			nil,  -- no toggle callback needed here
			function(col)
				-- accent color — user can use this however they want
				-- stored in G2L for global access
				G2L["accent_color"] = col;
			end
		);
	end;

	return Window;
end;

return Library;
