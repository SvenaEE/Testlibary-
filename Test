    function Window:_setTab(tab)
        if self._activeTab == tab then return end
        if self._activeTab then
            local prev = self._activeTab
            Tween(prev._btn, {BackgroundColor3 = Color3.fromRGB(0,0,0)}, 0.15):Play()
            prev._btn.BackgroundTransparency = 1
            Tween(prev._btn:FindFirstChild("Indicator"), {BackgroundTransparency = 1}, 0.15):Play()
            Tween(prev._btn:FindFirstChildWhichIsA("TextLabel"),
                {TextColor3 = T.TextSecondary}, 0.15):Play()
            prev._frame.Visible = false
        end
        self._activeTab = tab
        tab._btn.BackgroundColor3 = T.SurfaceAlt
        tab._btn.BackgroundTransparency = 0
        Tween(tab._btn:FindFirstChild("Indicator"), {BackgroundTransparency = 0}, 0.15):Play()
        Tween(tab._btn:FindFirstChildWhichIsA("TextLabel"),
            {TextColor3 = T.TextPrimary}, 0.15):Play()
        tab._frame.Visible = true
    end

