		G2L["CtxBtn_"..opt].Parent = G2L["CtxMenu"];
		Corner(4, G2L["CtxBtn_"..opt]);
		Padding(10, 6, 0, 0, G2L["CtxBtn_"..opt]);

		if isCurrent then
			G2L["CtxDot_"..opt] = Instance.new("Frame");
			G2L["CtxDot_"..opt].Size = UDim2.new(0, 4, 0, 4);
			G2L["CtxDot_"..opt].AnchorPoint = Vector2.new(1, 0.5);
			G2L["CtxDot_"..opt].Position = UDim2.new(1, -6, 0.5, 0);
			G2L["CtxDot_"..opt].BackgroundColor3 = T.Accent;
