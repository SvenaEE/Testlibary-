-- ════════════════════════════════════════════════════════════
--  HELPERS
-- ════════════════════════════════════════════════════════════
local function Tw(o,p,t,s,d)
    return TweenSvc:Create(o,TweenInfo.new(
        t or .15, s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out),p)
end

local function New(cls,props)
    local o = Instance.new(cls)
    for k,v in pairs(props or {}) do
        if k~="Parent" then o[k]=v end
    end
    if props and props.Parent then o.Parent=props.Parent end
    return o
end

local function Crn(r,p)    New("UICorner",{CornerRadius=UDim.new(0,r),Parent=p}) end
local function Stk(c,t,p)  New("UIStroke",{Color=c,Thickness=t or 1,Parent=p}) end
local function Pad(l,r,t,b,p)
    New("UIPadding",{PaddingLeft=UDim.new(0,l),PaddingRight=UDim.new(0,r),
        PaddingTop=UDim.new(0,t),PaddingBottom=UDim.new(0,b),Parent=p})
end
local function VList(p,gap)
    New("UIListLayout",{Parent=p,SortOrder=Enum.SortOrder.LayoutOrder,
        Padding=UDim.new(0,gap or 0),FillDirection=Enum.FillDirection.Vertical,
        HorizontalAlignment=Enum.HorizontalAlignment.Left})
end

