	local wmBar = make("Frame", gui, {
		Position         = UDim2.new(0, 8, 0, 6),
		Size             = UDim2.new(0, 10, 0, 24),
		AutomaticSize    = Enum.AutomaticSize.X,
		BackgroundColor3 = col.wmbg,
		BorderSizePixel  = 0,
		ZIndex           = 500,
	})
	corner(4, wmBar)
	stroke(col.border, 1, wmBar)
	-- left accent stripe
	make("Frame", wmBar, {
		Size             = UDim2.new(0, 2, 1, 0),
		BackgroundColor3 = col.accent,
		BorderSizePixel  = 0,
		ZIndex           = 501,
	})
	local wmLbl = make("TextLabel", wmBar, {
		Text                   = " loading... ",
		Font                   = Enum.Font.Code,
		TextSize               = 12,
		TextColor3             = col.txsec,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Size                   = UDim2.new(0, 10, 1, 0),
