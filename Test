--[[
    UILibrary v2.0  —  Primordial-style layout
    ─────────────────────────────────────────────
    • Bottom icon tab bar  (like Primordial)
    • Left sidebar for sub-pages per tab
    • Two-column section grid in content area
    • NO close / minimise buttons — keybind toggle only
    • Toggle with options.Key (default RightShift)

    QUICK START:
        local UI = loadstring(game:HttpGet("RAW_URL"))()
        local Win = UI:CreateWindow("MyHub", {
            Key   = Enum.KeyCode.RightShift,
            Theme = "Dark",   -- "Dark" | "Midnight" | "Light"
            Logo  = "rbxassetid://...",
        })
        local AimbotTab  = Win:AddTab("Aimbot",   "rbxassetid://...")
        local Page       = AimbotTab:AddPage("General")
        local Sec        = Page:AddSection("Settings")
        Sec:AddToggle("Enable", false, function(v) print(v) end)
        Sec:AddSlider("FOV", 0, 360, 90, function(v) print(v) end)
        Sec:AddDropdown("Hitpart",{"Head","Torso"},"Head",function(v) print(v) end)
        Win:Notify({Title="Loaded!", Message="Injected.", Duration=4})
]]

