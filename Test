--  LIBRARY
-- ════════════════════════════════════════════════════════════
local Library = {}
Library.__index = Library

function Library:CreateWindow(title, opts)
    opts = opts or {}
    local T         = Themes[opts.Theme or "Dark"] or Themes.Dark
    local toggleKey = opts.Key  or Enum.KeyCode.RightShift
    local logoAsset = opts.Logo or ""

    local WIN_W, WIN_H = 760, 480
    local TAB_H        = 52
    local SIDEBAR_W    = 130
    local TITLE_H      = 38
    local BODY_H       = WIN_H - TITLE_H - TAB_H

    -- ── ScreenGui ─────────────────────────────────────────────
    local gui = New("ScreenGui", {
        Name           = "UL_" .. HttpService:GenerateGUID(false):sub(1,6),
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder   = 999,
        Parent         = (RunService:IsStudio() and LocalPlayer.PlayerGui) or game:GetService("CoreGui"),
    })

    -- ── Notification anchor ───────────────────────────────────
    local notifHolder = New("Frame", {
        AnchorPoint = Vector2.new(1,1),
        Position    = UDim2.new(1,-14,1,-14),
        Size        = UDim2.new(0,295,1,-28),
        BackgroundTransparency = 1,
        ZIndex      = 300,
        Parent      = gui,
    })
    New("UIListLayout", {
        Parent=notifHolder, VerticalAlignment=Enum.VerticalAlignment.Bottom,
        SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0,6),
    })

    -- ── Root ──────────────────────────────────────────────────
    local root = New("Frame", {
        Name             = "Root",
        AnchorPoint      = Vector2.new(0.5,0.5),
        Position         = UDim2.new(0.5,0,0.5,0),
        Size             = UDim2.new(0,WIN_W,0,WIN_H),
        BackgroundColor3 = T.BG,
        BorderSizePixel  = 0,
        ClipsDescendants = false,
        Parent           = gui,
    })
    Corner(10, root)
    Stroke(T.Border, 1, root)
    -- shadow
    New("ImageLabel", {
        AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(0.5,0,0.5,12),
        Size=UDim2.new(1,56,1,56), ZIndex=0,
        BackgroundTransparency=1, Image="rbxassetid://6015897843",
        ImageColor3=Color3.new(0,0,0), ImageTransparency=0.5,
        ScaleType=Enum.ScaleType.Slice, SliceCenter=Rect.new(49,49,450,450),
        Parent=root,
    })

    -- clipping inner
    local inner = New("Frame", {
        Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
        ClipsDescendants=true, ZIndex=1, Parent=root,
    })
    Corner(10, inner)

    -- ── Title bar ─────────────────────────────────────────────
    local titleBar = New("Frame", {
        Size=UDim2.new(1,0,0,TITLE_H), BackgroundColor3=T.Panel,
        BorderSizePixel=0, ZIndex=10, Parent=inner,
    })
    -- bottom rule
    New("Frame", {
        Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=T.Border, BorderSizePixel=0, ZIndex=11, Parent=titleBar,
    })
    if logoAsset ~= "" then
        New("ImageLabel", {
            Image=logoAsset, Size=UDim2.new(0,18,0,18),
            Position=UDim2.new(0,12,0.5,-9),
            BackgroundTransparency=1, ZIndex=12, Parent=titleBar,
        })
    end
    New("TextLabel", {
        Text=title, Font=Enum.Font.GothamBold, TextSize=13,
        TextColor3=T.TextPrim, TextXAlignment=Enum.TextXAlignment.Left,
        Position=UDim2.new(0, logoAsset~="" and 36 or 13, 0,0),
        Size=UDim2.new(1,-100,1,0),
        BackgroundTransparency=1, ZIndex=12, Parent=titleBar,
    })
    New("TextLabel", {
        Text=toggleKey.Name, Font=Enum.Font.GothamBold, TextSize=9,
        TextColor3=T.TextMuted, TextXAlignment=Enum.TextXAlignment.Center,
        AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-10,0.5,0),
        Size=UDim2.new(0,60,0,18),
        BackgroundColor3=T.Surface, BackgroundTransparency=0,
        BorderSizePixel=0, ZIndex=12, Parent=titleBar,
    })
    do local h = titleBar:FindFirstChildOfClass("TextLabel",true)
        -- corner on the key hint badge
        local badge = titleBar:GetChildren()[#titleBar:GetChildren()]
        Corner(4, badge)
    end

    -- drag
    do
        local drag, ds, sp
        titleBar.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                drag=true; ds=i.Position; sp=root.Position
            end
        end)
        titleBar.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
                local d=i.Position-ds
                root.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
            end
        end)
    end

    -- ── Body ──────────────────────────────────────────────────
    local body = New("Frame", {
        Size=UDim2.new(1,0,0,BODY_H),
        Position=UDim2.new(0,0,0,TITLE_H),
        BackgroundTransparency=1, ZIndex=2, Parent=inner,
    })

    -- Sidebar
    local sidebar = New("Frame", {
        Size=UDim2.new(0,SIDEBAR_W,1,0),
        BackgroundColor3=T.Sidebar, BorderSizePixel=0, ZIndex=3, Parent=body,
    })
    New("Frame", {
        Size=UDim2.new(0,1,1,0), Position=UDim2.new(1,-1,0,0),
        BackgroundColor3=T.Border, BorderSizePixel=0, ZIndex=4, Parent=sidebar,
    })
    -- sidebar inner scroll container (pages listed here)
    local sideHolder = New("Frame", {
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1, ZIndex=4, Parent=sidebar,
    })

    -- Content area
    local contentArea = New("Frame", {
        Size=UDim2.new(1,-SIDEBAR_W,1,0),
        Position=UDim2.new(0,SIDEBAR_W,0,0),
        BackgroundTransparency=1,
        ClipsDescendants=true,
        ZIndex=2, Parent=body,
    })

    -- ── Bottom tab bar ────────────────────────────────────────
    local tabBar = New("Frame", {
        Size=UDim2.new(1,0,0,TAB_H),
        Position=UDim2.new(0,0,1,-TAB_H),
        BackgroundColor3=T.TabBar,
        BorderSizePixel=0, ZIndex=10, Parent=inner,
    })
    New("Frame", {
        Size=UDim2.new(1,0,0,1), BackgroundColor3=T.Border,
        BorderSizePixel=0, ZIndex=11, Parent=tabBar,
    })
    local tabRowFrame = New("Frame", {
        Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
        ZIndex=11, Parent=tabBar,
    })
    New("UIListLayout", {
        Parent=tabRowFrame,
        FillDirection=Enum.FillDirection.Horizontal,
        HorizontalAlignment=Enum.HorizontalAlignment.Center,
        VerticalAlignment=Enum.VerticalAlignment.Center,
        SortOrder=Enum.SortOrder.LayoutOrder,
        Padding=UDim.new(0,0),
    })

    -- ── Toggle visibility ─────────────────────────────────────
    local visible = true
    UserInputService.InputBegan:Connect(function(i,gp)
        if gp then return end
        if i.KeyCode == toggleKey then
            visible = not visible
            root.Visible = visible
        end
    end)

    -- ── Window object ─────────────────────────────────────────
    local Window = {
        _T           = T,
        _tabs        = {},
        _activeTab   = nil,
        _sideHolder  = sideHolder,
        _contentArea = contentArea,
        _tabRowFrame = tabRowFrame,
        _notifHolder = notifHolder,
        _gui         = gui,
    }

    function Window:_switchTab(tab)
        if self._activeTab == tab then return end
        if self._activeTab then
            local o = self._activeTab
            o._sideFrame.Visible = false
            Tween(o._btn, {BackgroundTransparency=1}, 0.15):Play()
            o._btn:FindFirstChild("ActiveLine").Visible = false
            Tween(o._btnLbl, {TextColor3=T.TextMuted}, 0.15):Play()
        end
        self._activeTab = tab
        tab._sideFrame.Visible = true
        tab._btn:FindFirstChild("ActiveLine").Visible = true
        Tween(tab._btn, {BackgroundTransparency=0, BackgroundColor3=T.Surface}, 0.15):Play()
        Tween(tab._btnLbl, {TextColor3=T.TextPrim}, 0.15):Play()
        if tab._activePage == nil and #tab._pages > 0 then
            tab:_switchPage(tab._pages[1])
        elseif tab._activePage then
            tab._activePage._frame.Visible = true
        end
    end

    -- ══════════════════════════════════════════════════════════
    --  AddTab
    -- ══════════════════════════════════════════════════════════
    function Window:AddTab(name, icon)
        local T     = self._T
        local TAB_W = 90

        -- bottom bar button
        local btn = New("TextButton", {
            Text="", Size=UDim2.new(0,TAB_W,1,0),
            BackgroundColor3=T.Surface, BackgroundTransparency=1,
            AutoButtonColor=false, ZIndex=12,
            Parent=self._tabRowFrame,
        })
        -- top highlight line (active indicator)
        local actLine = New("Frame", {
            Name="ActiveLine",
            Size=UDim2.new(0.6,0,0,2),
            AnchorPoint=Vector2.new(0.5,0),
            Position=UDim2.new(0.5,0,0,0),
            BackgroundColor3=T.Accent,
            BorderSizePixel=0, Visible=false, ZIndex=13,
            Parent=btn,
        })
        Corner(1, actLine)
        -- icon
        if icon and icon ~= "" then
            New("ImageLabel", {
                Image=icon, Size=UDim2.new(0,18,0,18),
                AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new(0.5,0,0.5,-7),
                BackgroundTransparency=1, ZIndex=13, Parent=btn,
            })
        end
        -- label
        local btnLbl = New("TextLabel", {
            Text=name, Font=Enum.Font.GothamSemibold, TextSize=10,
            TextColor3=T.TextMuted,
            AnchorPoint=Vector2.new(0.5,1),
            Position=UDim2.new(0.5,0,1,-5),
            Size=UDim2.new(1,-4,0,13),
            TextXAlignment=Enum.TextXAlignment.Center,
            BackgroundTransparency=1, ZIndex=13, Parent=btn,
        })

        -- sidebar container for this tab's pages
        local sideFrame = New("ScrollingFrame", {
            Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1,
            BorderSizePixel=0,
            ScrollBarThickness=2,
            ScrollBarImageColor3=T.Scroll,
            CanvasSize=UDim2.new(0,0,0,0),
            AutomaticCanvasSize=Enum.AutomaticSize.Y,
            Visible=false, ZIndex=5,
            Parent=self._sideHolder,
        })
        VList(sideFrame, 2)
        Pad(6,6,8,8, sideFrame)

        local tab = {
            _btn        = btn,
            _btnLbl     = btnLbl,
            _sideFrame  = sideFrame,
            _pages      = {},
            _activePage = nil,
            _window     = self,
            _T          = T,
        }

        function tab:_switchPage(page)
            if self._activePage == page then return end
            if self._activePage then
                self._activePage._frame.Visible = false
                Tween(self._activePage._sideBtn, {BackgroundTransparency=1, TextColor3=T.TextSec}, 0.12):Play()
                self._activePage._sideDot.BackgroundTransparency = 1
            end
            self._activePage = page
            page._frame.Visible = true
            Tween(page._sideBtn, {BackgroundTransparency=0, BackgroundColor3=T.SurfaceHov, TextColor3=T.TextPrim}, 0.12):Play()
            page._sideDot.BackgroundTransparency = 0
        end

        btn.MouseEnter:Connect(function()
            if self._activeTab ~= tab then
                Tween(btn, {BackgroundTransparency=0.7, BackgroundColor3=T.Surface}, 0.12):Play()
                Tween(btnLbl, {TextColor3=T.TextSec}, 0.12):Play()
            end
        end)
        btn.MouseLeave:Connect(function()
            if self._activeTab ~= tab then
                Tween(btn, {BackgroundTransparency=1}, 0.12):Play()
                Tween(btnLbl, {TextColor3=T.TextMuted}, 0.12):Play()
            end
        end)
        btn.MouseButton1Click:Connect(function() self:_switchTab(tab) end)

        table.insert(self._tabs, tab)
        if #self._tabs == 1 then self:_switchTab(tab) end

        -- ════════════════════════════════════════════════════
        --  AddPage
        -- ════════════════════════════════════════════════════
        function tab:AddPage(pageName)
            local T = self._T

            local sideBtn = New("TextButton", {
                Text=pageName, Font=Enum.Font.Gotham, TextSize=12,
                TextColor3=T.TextSec,
                TextXAlignment=Enum.TextXAlignment.Left,
                Size=UDim2.new(1,0,0,30),
                BackgroundColor3=T.SurfaceHov,
                BackgroundTransparency=1,
                AutoButtonColor=false, ZIndex=6,
                Parent=sideFrame,
            })
            Corner(5, sideBtn)
            Pad(22,8,0,0, sideBtn)

            local sideDot = New("Frame", {
                Name="Dot",
                Size=UDim2.new(0,3,0,14),
                AnchorPoint=Vector2.new(0,0.5),
                Position=UDim2.new(0,8,0.5,0),
                BackgroundColor3=T.Accent,
                BackgroundTransparency=1,
                BorderSizePixel=0, ZIndex=7,
                Parent=sideBtn,
            })
            Corner(2, sideDot)

            sideBtn.MouseEnter:Connect(function()
                if self._activePage and self._activePage._sideBtn == sideBtn then return end
                Tween(sideBtn, {BackgroundTransparency=0.6, BackgroundColor3=T.SurfaceHov}, 0.1):Play()
            end)
            sideBtn.MouseLeave:Connect(function()
                if self._activePage and self._activePage._sideBtn == sideBtn then return end
                Tween(sideBtn, {BackgroundTransparency=1}, 0.1):Play()
            end)

            -- Two-column scrolling page
            local pageFrame = New("ScrollingFrame", {
                Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1, BorderSizePixel=0,
                ScrollBarThickness=3,
                ScrollBarImageColor3=T.Scroll,
                CanvasSize=UDim2.new(0,0,0,0),
                AutomaticCanvasSize=Enum.AutomaticSize.Y,
                Visible=false, ZIndex=3,
                Parent=self._window._contentArea,
            })
            Pad(10,10,10,10, pageFrame)
            -- grid: 2 columns
            New("UIGridLayout", {
                Parent=pageFrame,
                CellSize=UDim2.new(0.5,-6,0,1), -- height=1 auto grows per section
                CellPaddingX=UDim.new(0,8),
                CellPaddingY=UDim.new(0,8),
                SortOrder=Enum.SortOrder.LayoutOrder,
                FillDirection=Enum.FillDirection.Horizontal,
                HorizontalAlignment=Enum.HorizontalAlignment.Left,
                VerticalAlignment=Enum.VerticalAlignment.Top,
            })

            local page = {
                _sideBtn = sideBtn,
                _sideDot = sideDot,
                _frame   = pageFrame,
                _T       = T,
                _tab     = self,
            }
            sideBtn.MouseButton1Click:Connect(function() tab:_switchPage(page) end)
            table.insert(self._pages, page)
            if #self._pages == 1 and self._window._activeTab == self then
                self:_switchPage(page)
            end

            -- ════════════════════════════════════════════════
            --  AddSection
            -- ════════════════════════════════════════════════
            function page:AddSection(sectionName)
                local T = self._T

                local secWrap = New("Frame", {
                    -- UIGridLayout drives width; height = auto
                    Size=UDim2.new(1,0,0,32), -- grows via refresh
                    BackgroundColor3=T.Panel,
                    BorderSizePixel=0, ZIndex=4,
                    Parent=pageFrame,
                })
                Corner(6, secWrap)
                Stroke(T.Border, 1, secWrap)

                -- Header
                local hdr = New("Frame", {
                    Size=UDim2.new(1,0,0,30),
                    BackgroundColor3=T.Surface,
                    BorderSizePixel=0, ZIndex=5, Parent=secWrap,
                })
                Corner(6, hdr)
                -- mask bottom-round of header
                New("Frame", {
                    Size=UDim2.new(1,0,0,6), Position=UDim2.new(0,0,1,-6),
                    BackgroundColor3=T.Surface, BorderSizePixel=0, ZIndex=6, Parent=hdr,
                })
                -- accent bar
                New("Frame", {
                    Size=UDim2.new(0,2,0,14), Position=UDim2.new(0,9,0.5,-7),
                    BackgroundColor3=T.Accent, BorderSizePixel=0, ZIndex=7, Parent=hdr,
                })
                New("TextLabel", {
                    Text=sectionName, Font=Enum.Font.GothamBold, TextSize=10,
                    TextColor3=T.TextSec, TextXAlignment=Enum.TextXAlignment.Left,
                    Position=UDim2.new(0,18,0,0), Size=UDim2.new(1,-22,1,0),
                    BackgroundTransparency=1, ZIndex=7, Parent=hdr,
                })

                -- Elements container (auto-grows)
                local elems = New("Frame", {
                    Size=UDim2.new(1,0,0,0),
                    Position=UDim2.new(0,0,0,30),
                    AutomaticSize=Enum.AutomaticSize.Y,
                    BackgroundTransparency=1, ZIndex=5,
                    Parent=secWrap,
                })
                VList(elems, 0)

                local function refresh()
                    task.defer(function()
                        secWrap.Size = UDim2.new(1,0,0, 30 + elems.AbsoluteSize.Y)
                    end)
                end

                local SEC    = {_elems=elems, _wrap=secWrap, _T=T, _refresh=refresh}
                local ROW_H  = 30

                -- Row helper
                local function Row(h)
                    local r = New("Frame", {
                        Size=UDim2.new(1,0,0,h or ROW_H),
                        BackgroundTransparency=1, ZIndex=6,
                        Parent=elems,
                    })
                    New("Frame", { -- divider
                        Size=UDim2.new(1,-18,0,1), Position=UDim2.new(0,9,1,-1),
                        BackgroundColor3=T.BorderDim, BackgroundTransparency=0.35,
                        BorderSizePixel=0, ZIndex=6, Parent=r,
                    })
                    return r
                end

                local function RowLbl(row, text)
                    New("TextLabel", {
                        Text=text, Font=Enum.Font.Gotham, TextSize=11,
                        TextColor3=T.TextPrim, TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,10,0,0), Size=UDim2.new(0.54,0,1,0),
                        BackgroundTransparency=1, ZIndex=7, Parent=row,
                    })
                end

                -- ── AddLabel ──────────────────────────────────
