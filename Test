                    refresh()
                    return {
                        Set=function(_,v) on=v; upd(); task.spawn(cb,on) end,
                        Get=function(_) return on end,
                    }
                end

                -- ── AddSlider ─────────────────────────────────
                function SEC:AddSlider(text, min, max, default, cb)
                    local val = math.clamp(default or min, min, max)
                    local r   = Row(44)
                    RowLbl(r, text)

                    local valLbl = New("TextLabel", {
                        Text=tostring(val), Font=Enum.Font.GothamBold, TextSize=10,
                        TextColor3=T.Accent, TextXAlignment=Enum.TextXAlignment.Right,
                        AnchorPoint=Vector2.new(1,0), Position=UDim2.new(1,-10,0,0),
                        Size=UDim2.new(0,38,0,20),
                        BackgroundTransparency=1, ZIndex=8, Parent=r,
                    })

                    local trackBg = New("Frame", {
                        Size=UDim2.new(1,-20,0,3),
                        Position=UDim2.new(0,10,0,32),
                        BackgroundColor3=T.Border,
                        BorderSizePixel=0, ZIndex=8, Parent=r,
                    })
                    Corner(2, trackBg)

                    local fill = New("Frame", {
                        Size=UDim2.new((val-min)/(max-min),0,1,0),
                        BackgroundColor3=T.Accent,
                        BorderSizePixel=0, ZIndex=9, Parent=trackBg,
                    })
                    Corner(2, fill)

                    local knob = New("Frame", {
                        Size=UDim2.new(0,9,0,9),
                        AnchorPoint=Vector2.new(0.5,0.5),
                        Position=UDim2.new((val-min)/(max-min),0,0.5,0),
                        BackgroundColor3=Color3.new(1,1,1),
                        ZIndex=10, Parent=trackBg,
                    })
                    Corner(5, knob)
                    Stroke(T.Accent, 2, knob)

                    local drag = false
                    trackBg.InputBegan:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
                    end)
                    UserInputService.InputEnded:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
                    end)
                    UserInputService.InputChanged:Connect(function(i)
                        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
                            local rel=math.clamp((i.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1)
                            val=math.floor(min+(max-min)*rel)
                            fill.Size=UDim2.new(rel,0,1,0)
                            knob.Position=UDim2.new(rel,0,0.5,0)
                            valLbl.Text=tostring(val)
                            task.spawn(cb,val)
                        end
                    end)
                    refresh()
                    return {
                        Set=function(_,v)
                            val=math.clamp(v,min,max)
                            local rel=(val-min)/(max-min)
                            fill.Size=UDim2.new(rel,0,1,0)
                            knob.Position=UDim2.new(rel,0,0.5,0)
                            valLbl.Text=tostring(val)
                            task.spawn(cb,val)
                        end,
                        Get=function(_) return val end,
                    }
                end

                -- ── AddDropdown ───────────────────────────────
                function SEC:AddDropdown(text, options, default, cb)
                    local sel  = default or options[1]
                    local open = false
                    local r    = Row()
                    RowLbl(r, text)

                    local dropBtn = New("TextButton", {
                        Text="",
                        Size=UDim2.new(0.44,0,0,20),
                        AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=T.Surface,
                        AutoButtonColor=false, ZIndex=8, Parent=r,
                    })
                    Corner(4, dropBtn)
                    Stroke(T.Border, 1, dropBtn)

                    local selLbl = New("TextLabel", {
                        Text=sel, Font=Enum.Font.Gotham, TextSize=10,
                        TextColor3=T.TextPrim, TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,6,0,0), Size=UDim2.new(1,-18,1,0),
                        BackgroundTransparency=1, ZIndex=9, Parent=dropBtn,
                    })
                    local arrow = New("TextLabel", {
                        Text="▾", Font=Enum.Font.GothamBold, TextSize=8,
                        TextColor3=T.TextMuted,
                        AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-4,0.5,0),
                        Size=UDim2.new(0,10,1,0),
                        BackgroundTransparency=1, ZIndex=9, Parent=dropBtn,
                    })

                    local panH   = math.min(#options,6)*24+6
                    local panel  = New("Frame", {
                        Size=UDim2.new(0.44,0,0,panH),
                        AnchorPoint=Vector2.new(1,0),
                        Position=UDim2.new(1,-10,1,2),
                        BackgroundColor3=T.Panel,
                        BorderSizePixel=0, Visible=false,
                        ZIndex=50, ClipsDescendants=true,
                        Parent=r,
                    })
                    Corner(5, panel)
                    Stroke(T.Border,1,panel)

                    local panScroll = New("ScrollingFrame", {
                        Size=UDim2.new(1,0,1,0),
                        BackgroundTransparency=1, BorderSizePixel=0,
                        ScrollBarThickness=2, ScrollBarImageColor3=T.Scroll,
                        CanvasSize=UDim2.new(0,0,0,0),
                        AutomaticCanvasSize=Enum.AutomaticSize.Y,
                        ZIndex=51, Parent=panel,
                    })
                    VList(panScroll, 0)
                    Pad(4,4,3,3,panScroll)

                    local function buildOpts()
                        for _,c in ipairs(panScroll:GetChildren()) do
                            if c:IsA("TextButton") then c:Destroy() end
                        end
                        for _, opt in ipairs(options) do
                            local ob = New("TextButton", {
                                Text=opt, Font=Enum.Font.Gotham, TextSize=10,
                                TextColor3=opt==sel and T.Accent or T.TextPrim,
                                TextXAlignment=Enum.TextXAlignment.Left,
                                Size=UDim2.new(1,0,0,24),
                                BackgroundColor3=T.SurfaceHov,
                                BackgroundTransparency=1,
                                AutoButtonColor=false, ZIndex=52,
                                Parent=panScroll,
                            })
                            Corner(3,ob)
                            Pad(8,8,0,0,ob)
                            ob.MouseEnter:Connect(function() Tween(ob,{BackgroundTransparency=0},0.1):Play() end)
                            ob.MouseLeave:Connect(function() Tween(ob,{BackgroundTransparency=1},0.1):Play() end)
                            ob.MouseButton1Click:Connect(function()
                                sel=opt; selLbl.Text=opt
                                open=false; panel.Visible=false
                                Tween(arrow,{Rotation=0},0.15):Play()
                                buildOpts(); task.spawn(cb,opt)
                            end)
                        end
                    end
                    buildOpts()

                    dropBtn.MouseButton1Click:Connect(function()
                        open=not open; panel.Visible=open
                        Tween(arrow,{Rotation=open and 180 or 0},0.15):Play()
                    end)
                    refresh()
                    return {
                        Set=function(_,v) sel=v; selLbl.Text=v; buildOpts(); task.spawn(cb,v) end,
                        Get=function(_) return sel end,
                        Refresh=function(_,newOpts) options=newOpts; buildOpts() end,
                    }
                end

                -- ── AddTextbox ────────────────────────────────
                function SEC:AddTextbox(text, placeholder, cb)
                    local r = Row()
                    RowLbl(r, text)
                    local box = New("TextBox", {
                        PlaceholderText=placeholder or "",
                        Text="", Font=Enum.Font.Gotham, TextSize=10,
                        TextColor3=T.TextPrim, PlaceholderColor3=T.TextMuted,
                        TextXAlignment=Enum.TextXAlignment.Left,
                        Size=UDim2.new(0.44,0,0,20),
                        AnchorPoint=Vector2.new(1,0.5),
