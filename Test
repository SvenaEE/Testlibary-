		G2L_seg["BorderSizePixel"]  = 0;
		G2L_seg["Size"]             = UDim2.new(1, 0, 1/(#hueColors-1), 0);
		G2L_seg["Position"]         = UDim2.new(0, 0, (i-1)/(#hueColors-1), 0);
