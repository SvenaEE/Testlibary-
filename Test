	local G2L_kc = Instance.new("UICorner", G2L_knob);
	G2L_kc["CornerRadius"] = UDim.new(1, 0);

	local function setPill(newState)
		G2L["svc_tween"]:Create(G2L_track, G2L["TWEEN_TOGGLE"], {
			["BackgroundColor3"] = newState and Color3.fromRGB(81,81,110) or Color3.fromRGB(40,40,55);
