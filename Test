            -- ──────────────────────────────────────────────────
            --  NewKeybind(name, info, default, callback)
            -- ──────────────────────────────────────────────────
            function Sec:NewKeybind(name,info,default,cb)
                local key=default; local binding=false
                local hasInfo=info and info~=""
                local r=Row(hasInfo and 42 or 30)
                RowLabel(r,name,info)
                local kBtn=New("TextButton",{
                    Text=key and key.Name or "None",
                    Font=Enum.Font.GothamBold,TextSize=9,TextColor3=T.Accent,
                    Size=UDim2.new(0.44,0,0,20),
                    AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                    BackgroundColor3=T.Surface,AutoButtonColor=false,ZIndex=8,Parent=r,
                })
                Crn(4,kBtn); Stk(T.Border,1,kBtn)
                local kbE=kbAdd(name,key)
                kBtn.MouseButton1Click:Connect(function()
                    binding=true; kBtn.Text="..."; kBtn.TextColor3=T.Warn
                end)
                UIS.InputBegan:Connect(function(i,gp)
                    if binding and not gp then
                        binding=false; key=i.KeyCode
                        kBtn.Text=key.Name; kBtn.TextColor3=T.Accent
                        kbUpd(kbE,key)
                    elseif not binding and key and i.KeyCode==key and cb then
                        task.spawn(cb,key)
                    end
                end)
                -- RIGHT-CLICK on keybind button: mode picker
                local kbMode = "Toggle"  -- Toggle | Hold | Always On
                local kbCtx  = nil

                local function destroyKbCtx()
                    if kbCtx then kbCtx:Destroy(); kbCtx=nil end
                end

                local function showKbCtx()
                    destroyKbCtx()
                    local modes = {"Toggle","Hold","Always On"}
                    local menuH = #modes*24+6
                    kbCtx=New("Frame",{
                        Size=UDim2.new(0,110,0,menuH),
                        AnchorPoint=Vector2.new(1,0),
                        Position=UDim2.new(1,0,1,4),
                        BackgroundColor3=T.Panel,BorderSizePixel=0,
                        ZIndex=80,ClipsDescendants=true,Parent=r,
                    })
                    Crn(5,kbCtx); Stk(T.Border,1,kbCtx)
                    local cl=New("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=81,Parent=kbCtx})
                    VList(cl,0); Pad(4,4,3,3,cl)
                    for _,mode in ipairs(modes) do
                        local mb=New("TextButton",{
                            Text=mode,Font=Enum.Font.Gotham,TextSize=10,
                            TextColor3=mode==kbMode and T.Accent or T.TxPrim,
                            TextXAlignment=Enum.TextXAlignment.Left,
                            Size=UDim2.new(1,0,0,24),
                            BackgroundColor3=T.Hover,BackgroundTransparency=1,
                            AutoButtonColor=false,ZIndex=82,Parent=cl,
                        })
                        Crn(3,mb); Pad(8,8,0,0,mb)
                        if mode==kbMode then
                            New("Frame",{
                                Size=UDim2.new(0,4,0,4),AnchorPoint=Vector2.new(1,0.5),
                                Position=UDim2.new(1,-6,0.5,0),
                                BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=83,Parent=mb,
                            })
                        end
                        mb.MouseEnter:Connect(function() Tw(mb,{BackgroundTransparency=0},0.1):Play() end)
                        mb.MouseLeave:Connect(function() Tw(mb,{BackgroundTransparency=1},0.1):Play() end)
                        mb.MouseButton1Click:Connect(function()
                            kbMode=mode; destroyKbCtx()
                            if mode=="Always On" and cb then task.spawn(cb,key) end
                        end)
                    end
                    local cc
                    cc=UIS.InputBegan:Connect(function(i,gp)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then
                            task.defer(destroyKbCtx); cc:Disconnect()
                        end
                    end)
                end

                -- right-click on the whole row (bigger target than just kBtn)
                r.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton2 then
                        showKbCtx()
                    end
                end)

                -- Override InputBegan to respect mode
                -- (original connection already handles Toggle and rebinding)
                -- Hold mode wiring
                local kHolding=false
                kBtn.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 and kbMode=="Hold" and key then
                        kHolding=true; task.spawn(cb,key)
                    end
                end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 and kHolding then
                        kHolding=false
                    end
                end)

                return {
                    Get=function(_) return key end,
                    Set=function(_,k) key=k;kBtn.Text=k and k.Name or "None";kbUpd(kbE,k) end,
                    GetMode=function(_) return kbMode end,
                }
            end

            -- ──────────────────────────────────────────────────
            --  NewDropdown(name, info, options, callback)
            -- ──────────────────────────────────────────────────
            function Sec:NewDropdown(name,info,options,cb)
                local sel=options[1] or ""; local open=false
                local hasInfo=info and info~=""
                local r=Row(hasInfo and 42 or 30)
                RowLabel(r,name,info)
                local dBtn=New("TextButton",{
                    Text="",Size=UDim2.new(0.44,0,0,20),
                    AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                    BackgroundColor3=T.Surface,AutoButtonColor=false,ZIndex=8,Parent=r,
                })
                Crn(4,dBtn); Stk(T.Border,1,dBtn)
                local selLbl=New("TextLabel",{
                    Text=sel,Font=Enum.Font.Gotham,TextSize=10,TextColor3=T.TxPrim,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    Position=UDim2.new(0,6,0,0),Size=UDim2.new(1,-18,1,0),
                    BackgroundTransparency=1,ZIndex=9,Parent=dBtn,
                })
                local arrow=nil  -- arrow removed per design
                local panH=math.min(#options,6)*24+6
                local panel=New("Frame",{
                    Size=UDim2.new(0.44,0,0,panH),AnchorPoint=Vector2.new(1,0),
                    Position=UDim2.new(1,-10,1,2),BackgroundColor3=T.Panel,
                    BorderSizePixel=0,Visible=false,ZIndex=60,ClipsDescendants=true,Parent=r,
                })
                Crn(5,panel); Stk(T.Border,1,panel)
                local pScr=New("ScrollingFrame",{
                    Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                    BorderSizePixel=0,ScrollBarThickness=2,ScrollBarImageColor3=T.Scroll,
                    CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
                    ZIndex=61,Parent=panel,
                })
                VList(pScr,0); Pad(4,4,3,3,pScr)
                local function buildOpts()
                    for _,c in ipairs(pScr:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _,opt in ipairs(options) do
                        local ob=New("TextButton",{
                            Text=opt,Font=Enum.Font.Gotham,TextSize=10,
                            TextColor3=opt==sel and T.Accent or T.TxPrim,
                            TextXAlignment=Enum.TextXAlignment.Left,
                            Size=UDim2.new(1,0,0,24),BackgroundColor3=T.Hover,
                            BackgroundTransparency=1,AutoButtonColor=false,ZIndex=62,Parent=pScr,
                        })
                        Crn(3,ob); Pad(8,8,0,0,ob)
                        ob.MouseEnter:Connect(function() Tw(ob,{BackgroundTransparency=0},0.1):Play() end)
                        ob.MouseLeave:Connect(function() Tw(ob,{BackgroundTransparency=1},0.1):Play() end)
                        ob.MouseButton1Click:Connect(function()
                            sel=opt; selLbl.Text=opt
                            open=false; panel.Visible=false
                            -- arrow removed
                            buildOpts()
                            if cb then task.spawn(cb,opt) end
                        end)
                    end
                end
                buildOpts()
                dBtn.MouseButton1Click:Connect(function()
                    open=not open; panel.Visible=open
                    -- arrow removed
                end)
                return {
                    Get=function(_) return sel end,
                    Set=function(_,v) sel=v;selLbl.Text=v;buildOpts() end,
                    Refresh=function(_,o2) options=o2;buildOpts() end,
                }
            end

            -- ──────────────────────────────────────────────────
            --  NewColorPicker(name, info, default, callback)
            -- ──────────────────────────────────────────────────
            function Sec:NewColorPicker(name,info,default,cb)
                local color=default or Color3.fromRGB(255,50,50)
                local open=false; local h,s,v=color:ToHSV()
                local hasInfo=info and info~=""
                local r=Row(hasInfo and 42 or 30)
                RowLabel(r,name,info)
                local sw=New("TextButton",{
                    Text="",Size=UDim2.new(0,28,0,18),
                    AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                    BackgroundColor3=color,AutoButtonColor=false,ZIndex=8,Parent=r,
                })
                Crn(4,sw); Stk(T.Border,1,sw)
                local pp=New("Frame",{
                    Size=UDim2.new(0,160,0,134),AnchorPoint=Vector2.new(1,0),
                    Position=UDim2.new(1,-10,1,4),BackgroundColor3=T.Panel,
                    BorderSizePixel=0,Visible=false,ZIndex=70,Parent=r,
                })
                Crn(7,pp); Stk(T.Border,1,pp); Pad(8,8,8,8,pp)
                local hBar=New("ImageLabel",{
                    Image="rbxassetid://2615689002",Size=UDim2.new(1,0,0,13),
                    BackgroundTransparency=1,ZIndex=71,Parent=pp,
                })
                Crn(4,hBar)
                local hC=New("Frame",{
                    Size=UDim2.new(0,5,1,4),AnchorPoint=Vector2.new(0.5,0.5),
                    Position=UDim2.new(h,0,0.5,0),BackgroundColor3=Color3.new(1,1,1),
                    ZIndex=72,Parent=hBar,
                })
                Crn(2,hC)
                local svC=New("ImageLabel",{
                    Image="rbxassetid://2615689003",Size=UDim2.new(1,0,0,85),
                    Position=UDim2.new(0,0,0,20),BackgroundColor3=Color3.fromHSV(h,1,1),
                    ZIndex=71,Parent=pp,
                })
                Crn(4,svC)
                local svK=New("Frame",{
                    Size=UDim2.new(0,9,0,9),AnchorPoint=Vector2.new(0.5,0.5),
                    Position=UDim2.new(s,0,1-v,0),BackgroundColor3=Color3.new(1,1,1),
                    ZIndex=72,Parent=svC,
                })
                Crn(5,svK); Stk(Color3.new(0,0,0),1,svK)
                local function upd()
                    color=Color3.fromHSV(h,s,v)
                    sw.BackgroundColor3=color
                    svC.BackgroundColor3=Color3.fromHSV(h,1,1)
                    hC.Position=UDim2.new(h,0,0.5,0)
                    svK.Position=UDim2.new(s,0,1-v,0)
                    if cb then task.spawn(cb,color) end
                end
                local dH,dSV=false,false
                hBar.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dH=true end end)
                svC.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dSV=true end end)
                UIS.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 then dH=false;dSV=false end
                end)
                UIS.InputChanged:Connect(function(i)
                    if i.UserInputType~=Enum.UserInputType.MouseMovement then return end
                    if dH then
                        h=math.clamp((i.Position.X-hBar.AbsolutePosition.X)/hBar.AbsoluteSize.X,0,1); upd()
                    elseif dSV then
                        s=math.clamp((i.Position.X-svC.AbsolutePosition.X)/svC.AbsoluteSize.X,0,1)
                        v=1-math.clamp((i.Position.Y-svC.AbsolutePosition.Y)/svC.AbsoluteSize.Y,0,1); upd()
                    end
                end)
                sw.MouseButton1Click:Connect(function() open=not open;pp.Visible=open end)
                return {
                    Get=function(_) return color end,
                    Set=function(_,c) color=c;h,s,v=c:ToHSV();upd() end,
                }
            end

            -- ──────────────────────────────────────────────────
            --  NewDivider(label)
            -- ──────────────────────────────────────────────────
            function Sec:NewDivider(label)
                local r=New("Frame",{
                    Size=UDim2.new(1,0,0,16),BackgroundTransparency=1,ZIndex=6,Parent=elems,
                })
                New("Frame",{
                    Size=UDim2.new(1,-16,0,1),Position=UDim2.new(0,8,0.5,0),
                    BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=7,Parent=r,
                })
                if label and label~="" then
                    New("TextLabel",{
                        Text=label,Font=Enum.Font.GothamBold,TextSize=8,
                        TextColor3=T.TxMut,TextXAlignment=Enum.TextXAlignment.Center,
                        AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),
                        Size=UDim2.new(0.5,0,1,0),BackgroundColor3=T.Card,
                        ZIndex=8,Parent=r,
                    })
                end
            end

            return Sec
        end  -- NewSection

        return tab
    end  -- NewTab

    -- ════════════════════════════════════════════════════════
