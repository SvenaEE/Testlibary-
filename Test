-- ════════════════════════════════════════════════════════════
--  KEYBIND REGISTRY
-- ════════════════════════════════════════════════════════════
local KBList   = {}
local kbRebuildFn = nil

local function KBAdd(label, key)
    local e = {label=label, keyName=key and key.Name or "None"}
    table.insert(KBList, e)
    if kbRebuildFn then kbRebuildFn() end
    return e
end
local function KBUpdate(e, key)
    e.keyName = key and key.Name or "None"
    if kbRebuildFn then kbRebuildFn() end
end

