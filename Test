--  LIBRARY
-- ════════════════════════════════════════════════════════════
local Lib = {}
Lib.__index = Lib

function Lib:CreateWindow(title, opts)
    opts = opts or {}
    local T    = Themes[opts.Theme or "Primordial"] or Themes.Primordial
    local tKey = opts.Key or Enum.KeyCode.RightShift

    local WIN_W   = 760
    local WIN_H   = 480
    local TAB_H   = 50
    local SIDE_W  = 140
    local TITLE_H = 36
    local BODY_H  = WIN_H - TITLE_H - TAB_H

    -- ── ScreenGui ─────────────────────────────────────────────
    local gui = New("ScreenGui",{
        Name           = "UL_"..Http:GenerateGUID(false):sub(1,6),
        ResetOnSpawn   = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        DisplayOrder   = 999,
        Parent         = Run:IsStudio() and LP.PlayerGui
                         or game:GetService("CoreGui"),
    })

    -- ── Watermark ─────────────────────────────────────────────
    local wmFrame = New("Frame",{
        Position=UDim2.new(0,8,0,6), Size=UDim2.new(0,10,0,24),
        AutomaticSize=Enum.AutomaticSize.X,
        BackgroundColor3=T.WMBG, BorderSizePixel=0, ZIndex=500, Parent=gui,
    })
    Crn(4,wmFrame); Stk(T.Border,1,wmFrame)
    New("Frame",{  -- accent left stripe
        Size=UDim2.new(0,2,1,0), BackgroundColor3=T.Accent,
        BorderSizePixel=0, ZIndex=501, Parent=wmFrame,
    })
    local wmLbl = New("TextLabel",{
        Text="", Font=Enum.Font.Code, TextSize=12,
        TextColor3=T.TextSec, TextXAlignment=Enum.TextXAlignment.Left,
        Size=UDim2.new(0,10,1,0), AutomaticSize=Enum.AutomaticSize.X,
        BackgroundTransparency=1, ZIndex=502, Parent=wmFrame,
    })
    Pad(10,12,0,0,wmLbl)

    local fpsAccum, fpsCount, fpsVal, lastWM = 0,0,60,0
    local function doWM()
        local ok,ping = pcall(function() return LP:GetNetworkPing() end)
        local p = ok and math.round((ping or 0)*1000) or 0
        local t = os.date("*t")
        wmLbl.Text = string.format(" %s  |  %s  |  FPS: %d  |  Ping: %dms  |  %02d:%02d ",
            title, LP.Name, fpsVal, p, t.hour, t.min)
    end
    Run.Heartbeat:Connect(function(dt)
        fpsAccum = fpsAccum + (1/dt)
        fpsCount = fpsCount + 1
        if fpsCount >= 20 then
            fpsVal   = math.floor(fpsAccum/fpsCount)
            fpsAccum = 0; fpsCount = 0
        end
        local now = os.clock()
        if now - lastWM >= 1 then lastWM=now; doWM() end
    end)
    doWM()

    -- ── Keybind list (middle-left) ─────────────────────────────
    local kbFrame = New("Frame",{
        AnchorPoint=Vector2.new(0,0.5), Position=UDim2.new(0,8,0.5,0),
        Size=UDim2.new(0,192,0,0), AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundColor3=T.WMBG, BorderSizePixel=0,
        ZIndex=500, Visible=false, Parent=gui,
    })
    Crn(4,kbFrame); Stk(T.Border,1,kbFrame); Pad(0,0,4,4,kbFrame)
    VList(kbFrame,0)

    local kbHdr = New("Frame",{Size=UDim2.new(1,0,0,20),BackgroundTransparency=1,ZIndex=501,Parent=kbFrame})
    New("Frame",{Size=UDim2.new(0,2,1,0),BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=502,Parent=kbHdr})
    New("TextLabel",{
        Text=" KEYBINDS",Font=Enum.Font.GothamBold,TextSize=9,
        TextColor3=T.TextMut,TextXAlignment=Enum.TextXAlignment.Left,
        Position=UDim2.new(0,8,0,0),Size=UDim2.new(1,-8,1,0),
        BackgroundTransparency=1,ZIndex=502,Parent=kbHdr,
    })
    local kbBody = New("Frame",{
        Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1,ZIndex=501,Parent=kbFrame,
    })
    VList(kbBody,0)

    kbRebuildFn = function()
        for _,c in ipairs(kbBody:GetChildren()) do
            if not c:IsA("UIListLayout") then c:Destroy() end
        end
        if #KBList==0 then kbFrame.Visible=false; return end
        kbFrame.Visible=true
        for _,kb in ipairs(KBList) do
            local row=New("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1,ZIndex=502,Parent=kbBody})
            New("TextLabel",{
                Text=kb.label,Font=Enum.Font.Code,TextSize=10,TextColor3=T.TextSec,
                TextXAlignment=Enum.TextXAlignment.Left,
                Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-70,1,0),
                BackgroundTransparency=1,ZIndex=503,Parent=row,
            })
            New("TextLabel",{
                Text="["..kb.keyName.."]",Font=Enum.Font.Code,TextSize=10,TextColor3=T.Accent,
                TextXAlignment=Enum.TextXAlignment.Right,
                AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-8,0,0),
                Size=UDim2.new(0,62,1,0),
                BackgroundTransparency=1,ZIndex=503,Parent=row,
            })
        end
    end

    -- ── Notification holder ────────────────────────────────────
    local notifHolder = New("Frame",{
        AnchorPoint=Vector2.new(1,1),Position=UDim2.new(1,-12,1,-12),
        Size=UDim2.new(0,295,1,-24),BackgroundTransparency=1,ZIndex=600,Parent=gui,
    })
    New("UIListLayout",{
        Parent=notifHolder,VerticalAlignment=Enum.VerticalAlignment.Bottom,
        SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6),
    })

    -- ── Root window ────────────────────────────────────────────
    local root = New("Frame",{
        AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),
        Size=UDim2.new(0,WIN_W,0,WIN_H),
        BackgroundColor3=T.BG,BorderSizePixel=0,ClipsDescendants=false,Parent=gui,
    })
    Crn(8,root); Stk(T.Border,1,root)
    New("ImageLabel",{
        AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,14),
        Size=UDim2.new(1,60,1,60),ZIndex=0,BackgroundTransparency=1,
        Image="rbxassetid://6015897843",ImageColor3=Color3.new(0,0,0),
        ImageTransparency=0.46,ScaleType=Enum.ScaleType.Slice,
        SliceCenter=Rect.new(49,49,450,450),Parent=root,
    })
    local inner = New("Frame",{
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
        ClipsDescendants=true,ZIndex=1,Parent=root,
    })
    Crn(8,inner)

    -- ── Title bar ──────────────────────────────────────────────
    local titleBar = New("Frame",{
        Size=UDim2.new(1,0,0,TITLE_H),BackgroundColor3=T.Panel,
        BorderSizePixel=0,ZIndex=10,Parent=inner,
    })
    New("Frame",{  -- bottom rule
        Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=11,Parent=titleBar,
    })
    New("Frame",{  -- left accent stripe
        Size=UDim2.new(0,3,0,16),Position=UDim2.new(0,10,0.5,-8),
        BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=12,Parent=titleBar,
    })
    New("TextLabel",{
        Text=title,Font=Enum.Font.GothamBold,TextSize=12,
        TextColor3=T.TextPrim,TextXAlignment=Enum.TextXAlignment.Left,
        Position=UDim2.new(0,22,0,0),Size=UDim2.new(1,-110,1,0),
        BackgroundTransparency=1,ZIndex=12,Parent=titleBar,
    })
    -- keybind badge — vertically centered
    local kbBadge = New("Frame",{
        Size=UDim2.new(0,82,0,20),
        AnchorPoint=Vector2.new(1,0.5),  -- ← centered vertically
        Position=UDim2.new(1,-10,0.5,0),
        BackgroundColor3=T.Surface,BorderSizePixel=0,ZIndex=12,Parent=titleBar,
    })
    Crn(4,kbBadge); Stk(T.Border,1,kbBadge)
    local kbBadgeLbl = New("TextLabel",{
        Text=tKey.Name,Font=Enum.Font.GothamBold,TextSize=9,
        TextColor3=T.TextSec,TextXAlignment=Enum.TextXAlignment.Center,
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=13,Parent=kbBadge,
    })

    -- drag
    do
        local drag,ds,sp
        titleBar.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                drag=true; ds=i.Position; sp=root.Position
            end
        end)
        titleBar.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
        end)
        UIS.InputChanged:Connect(function(i)
            if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
                local d=i.Position-ds
                root.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
            end
        end)
    end

    -- ── Body ───────────────────────────────────────────────────
    local body = New("Frame",{
        Size=UDim2.new(1,0,0,BODY_H),Position=UDim2.new(0,0,0,TITLE_H),
        BackgroundTransparency=1,ZIndex=2,Parent=inner,
    })

    local sidebar = New("Frame",{
        Size=UDim2.new(0,SIDE_W,1,0),BackgroundColor3=T.SideBar,
        BorderSizePixel=0,ZIndex=3,Parent=body,
    })
    New("Frame",{
        Size=UDim2.new(0,1,1,0),Position=UDim2.new(1,-1,0,0),
        BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=4,Parent=sidebar,
    })
    local sideContent = New("Frame",{
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=4,Parent=sidebar,
    })

    local contentArea = New("Frame",{
        Size=UDim2.new(1,-SIDE_W,1,0),Position=UDim2.new(0,SIDE_W,0,0),
        BackgroundColor3=T.BG,BorderSizePixel=0,
        ClipsDescendants=true,ZIndex=2,Parent=body,
    })

    -- ── Tab bar ────────────────────────────────────────────────
    local tabBar = New("Frame",{
        Size=UDim2.new(1,0,0,TAB_H),Position=UDim2.new(0,0,1,-TAB_H),
        BackgroundColor3=T.TabBG,BorderSizePixel=0,ZIndex=10,Parent=inner,
    })
    New("Frame",{
        Size=UDim2.new(1,0,0,1),BackgroundColor3=T.Border,
        BorderSizePixel=0,ZIndex=11,Parent=tabBar,
    })
    local tabRow = New("Frame",{
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=11,Parent=tabBar,
    })
    New("UIListLayout",{
        Parent=tabRow,FillDirection=Enum.FillDirection.Horizontal,
        HorizontalAlignment=Enum.HorizontalAlignment.Center,
        VerticalAlignment=Enum.VerticalAlignment.Center,
        SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,0),
    })

    -- ── Toggle visibility ──────────────────────────────────────
    local visible = true
    UIS.InputBegan:Connect(function(i,gp)
        if gp then return end
        if i.KeyCode==tKey then
            visible=not visible
            root.Visible    = visible
            wmFrame.Visible = visible
            kbFrame.Visible = visible and #KBList>0
        end
    end)

    -- ════════════════════════════════════════════════════════
    --  Window object
    -- ════════════════════════════════════════════════════════
    local Win = {
        _T=T, _tabs={}, _activeTab=nil,
        _sideContent=sideContent,
        _contentArea=contentArea,
        _tabRow=tabRow,
        _notifHolder=notifHolder,
        _gui=gui,
        _tKey=tKey,
        _kbBadgeLbl=kbBadgeLbl,
    }

    function Win:SetToggleKey(k)
        tKey=k; self._tKey=k
        self._kbBadgeLbl.Text=k.Name
    end

    function Win:_switchTab(tab)
        if self._activeTab==tab then return end
        if self._activeTab then
            local o=self._activeTab
            o._pageList.Visible=false
            Tw(o._btn,{BackgroundTransparency=1},0.14):Play()
            o._btnLine.Visible=false
            Tw(o._btnLbl,{TextColor3=T.TextMut},0.14):Play()
            -- FIX: hide the old tab's active page content frame
            if o._activePage then
                o._activePage._frame.Visible=false
            end
        end
        self._activeTab=tab
        tab._pageList.Visible=true
        tab._btnLine.Visible=true
        Tw(tab._btn,{BackgroundTransparency=0,BackgroundColor3=T.ActTab},0.14):Play()
        Tw(tab._btnLbl,{TextColor3=T.TextPrim},0.14):Play()
        if not tab._activePage and #tab._pages>0 then
            tab:_switchPage(tab._pages[1])
        elseif tab._activePage then
            tab._activePage._frame.Visible=true
        end
    end

    -- ════════════════════════════════════════════════════════
    --  AddTab  (name, iconAssetId)
    --  iconAssetId: optional rbxassetid:// string
    -- ════════════════════════════════════════════════════════
    function Win:AddTab(name, icon)
        local T=self._T
        local btn=New("TextButton",{
            Text="",Size=UDim2.new(0,90,1,0),
            BackgroundColor3=T.ActTab,BackgroundTransparency=1,
            AutoButtonColor=false,ZIndex=12,Parent=self._tabRow,
        })
        -- active top-edge line indicator
        local btnLine=New("Frame",{
            Size=UDim2.new(0.55,0,0,2),AnchorPoint=Vector2.new(0.5,0),
            Position=UDim2.new(0.5,0,0,0),BackgroundColor3=T.Accent,
            BorderSizePixel=0,Visible=false,ZIndex=13,Parent=btn,
        })
        Crn(1,btnLine)

        -- icon (optional) — shown above label
        local hasIcon = icon and icon~=""
        if hasIcon then
            New("ImageLabel",{
                Image=icon,
                Size=UDim2.new(0,18,0,18),
                AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new(0.5,0,0.5,-8),  -- center-ish, above label
                BackgroundTransparency=1,ZIndex=13,Parent=btn,
            })
        end

        -- label (bottom of tab button)
        local btnLbl=New("TextLabel",{
            Text=name,Font=Enum.Font.GothamSemibold,TextSize=10,
            TextColor3=T.TextMut,
            AnchorPoint=Vector2.new(0.5,1),
            Position=UDim2.new(0.5,0,1,-5),
            Size=UDim2.new(1,-4,0,12),
            TextXAlignment=Enum.TextXAlignment.Center,
            BackgroundTransparency=1,ZIndex=13,Parent=btn,
        })

        -- sidebar page list for this tab
        local pageList=New("ScrollingFrame",{
            Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
            BorderSizePixel=0,ScrollBarThickness=2,ScrollBarImageColor3=T.Scroll,
            CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
            Visible=false,ZIndex=5,Parent=self._sideContent,
        })
        VList(pageList,2); Pad(6,6,8,6,pageList)

        local tab={
            _btn=btn,_btnLbl=btnLbl,_btnLine=btnLine,
            _pageList=pageList,_pages={},_activePage=nil,
            _window=self,_T=T,
        }

        function tab:_switchPage(page)
            if self._activePage==page then return end
            if self._activePage then
                self._activePage._frame.Visible=false
                Tw(self._activePage._sBtn,{BackgroundTransparency=1,TextColor3=T.TextSec},0.12):Play()
                self._activePage._sDot.BackgroundTransparency=1
            end
            self._activePage=page
            page._frame.Visible=true
            Tw(page._sBtn,{BackgroundTransparency=0,BackgroundColor3=T.SurfHov,TextColor3=T.TextPrim},0.12):Play()
            page._sDot.BackgroundTransparency=0
        end

        btn.MouseEnter:Connect(function()
            if self._activeTab~=tab then
                Tw(btn,{BackgroundTransparency=0.65,BackgroundColor3=T.ActTab},0.12):Play()
                Tw(btnLbl,{TextColor3=T.TextSec},0.12):Play()
            end
        end)
        btn.MouseLeave:Connect(function()
            if self._activeTab~=tab then
                Tw(btn,{BackgroundTransparency=1},0.12):Play()
                Tw(btnLbl,{TextColor3=T.TextMut},0.12):Play()
            end
        end)
        btn.MouseButton1Click:Connect(function() self:_switchTab(tab) end)
        table.insert(self._tabs,tab)
        if #self._tabs==1 then self:_switchTab(tab) end

        -- ════════════════════════════════════════════════════
        --  AddPage
        -- ════════════════════════════════════════════════════
        function tab:AddPage(pageName)
            local T=self._T
            local sBtn=New("TextButton",{
                Text=pageName,Font=Enum.Font.Gotham,TextSize=12,
                TextColor3=T.TextSec,TextXAlignment=Enum.TextXAlignment.Left,
                Size=UDim2.new(1,0,0,28),
                BackgroundColor3=T.SurfHov,BackgroundTransparency=1,
                AutoButtonColor=false,ZIndex=6,Parent=pageList,
            })
            Crn(5,sBtn); Pad(20,8,0,0,sBtn)
            local sDot=New("Frame",{
                Size=UDim2.new(0,3,0,12),AnchorPoint=Vector2.new(0,0.5),
                Position=UDim2.new(0,7,0.5,0),BackgroundColor3=T.Accent,
                BackgroundTransparency=1,BorderSizePixel=0,ZIndex=7,Parent=sBtn,
            })
            Crn(2,sDot)
            sBtn.MouseEnter:Connect(function()
                if self._activePage and self._activePage._sBtn==sBtn then return end
                Tw(sBtn,{BackgroundTransparency=0.65,BackgroundColor3=T.SurfHov},0.1):Play()
            end)
            sBtn.MouseLeave:Connect(function()
                if self._activePage and self._activePage._sBtn==sBtn then return end
                Tw(sBtn,{BackgroundTransparency=1},0.1):Play()
            end)

            -- ── Page scroll frame ─────────────────────────────
            -- KEY FIX: each page gets its OWN isolated scroll frame.
            -- Inside we use a Frame with a horizontal UIListLayout
            -- holding exactly two column frames.
            -- Sections are added alternately left / right.
            -- AutomaticSize.Y on columns and sections makes them grow correctly.
            local pageScroll=New("ScrollingFrame",{
                Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                BorderSizePixel=0,ScrollBarThickness=3,ScrollBarImageColor3=T.Scroll,
                CanvasSize=UDim2.new(0,0,0,0),
                AutomaticCanvasSize=Enum.AutomaticSize.Y,
                Visible=false,ZIndex=3,
                Parent=self._window._contentArea,
            })
            Pad(10,10,10,10,pageScroll)

            -- outer wrapper — full width, auto height
            local outer=New("Frame",{
                Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,ZIndex=3,Parent=pageScroll,
            })
            -- horizontal list of two columns
            New("UIListLayout",{
                Parent=outer,
                FillDirection=Enum.FillDirection.Horizontal,
                VerticalAlignment=Enum.VerticalAlignment.Top,
                HorizontalAlignment=Enum.HorizontalAlignment.Left,
                SortOrder=Enum.SortOrder.LayoutOrder,
                Padding=UDim.new(0,10),
            })

            -- column A (left) — explicit pixel width = (contentArea - padding*2 - gap) / 2
            local colA=New("Frame",{
                Size=UDim2.new(0.5,-5,0,0),
                AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,ZIndex=3,Parent=outer,
            })
            VList(colA,10)

            -- column B (right)
            local colB=New("Frame",{
                Size=UDim2.new(0.5,-5,0,0),
                AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,ZIndex=3,Parent=outer,
            })
            VList(colB,10)

            local page={
                _sBtn=sBtn,_sDot=sDot,_frame=pageScroll,
                _colA=colA,_colB=colB,
                _secCount=0,  -- alternates L/R
                _T=T,_tab=self,
            }
            sBtn.MouseButton1Click:Connect(function() tab:_switchPage(page) end)
            table.insert(self._pages,page)
            if #self._pages==1 and self._window._activeTab==self then
                self:_switchPage(page)
            end

            -- ════════════════════════════════════════════════
            --  AddSection
            -- ════════════════════════════════════════════════
            function page:AddSection(secName)
                local T=self._T
                -- alternate columns: odd → left, even → right
                self._secCount=self._secCount+1
                local parentCol=(self._secCount%2==1) and self._colA or self._colB

                -- section card (full width of its column, auto-grows vertically)
                local card=New("Frame",{
                    Size=UDim2.new(1,0,0,0),
                    AutomaticSize=Enum.AutomaticSize.Y,
                    BackgroundColor3=T.Card,
                    BorderSizePixel=0,ZIndex=4,
                    Parent=parentCol,
                })
                Crn(6,card); Stk(T.Border,1,card)

                -- header bar
                local hdr=New("Frame",{
                    Size=UDim2.new(1,0,0,28),
                    BackgroundColor3=T.Surface,
                    BorderSizePixel=0,ZIndex=5,Parent=card,
                })
                Crn(6,hdr)
                -- mask bottom corners of rounded header
                New("Frame",{
                    Size=UDim2.new(1,0,0,8),Position=UDim2.new(0,0,1,-8),
                    BackgroundColor3=T.Surface,BorderSizePixel=0,ZIndex=6,Parent=hdr,
                })
                -- left accent stripe in header
                New("Frame",{
                    Size=UDim2.new(0,2,0,14),Position=UDim2.new(0,8,0.5,-7),
                    BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=7,Parent=hdr,
                })
                New("TextLabel",{
                    Text=secName,Font=Enum.Font.GothamBold,TextSize=10,
                    TextColor3=T.TextSec,TextXAlignment=Enum.TextXAlignment.Left,
                    Position=UDim2.new(0,17,0,0),Size=UDim2.new(1,-21,1,0),
                    BackgroundTransparency=1,ZIndex=7,Parent=hdr,
                })

                -- elements list (grows with content)
                local elems=New("Frame",{
                    Size=UDim2.new(1,0,0,0),
                    AutomaticSize=Enum.AutomaticSize.Y,
                    Position=UDim2.new(0,0,0,28),
                    BackgroundTransparency=1,ZIndex=5,Parent=card,
                })
                VList(elems,0)

                -- ── element builders ──────────────────────────
                local function Row(h)
                    local r=New("Frame",{
                        Size=UDim2.new(1,0,0,h or 30),
                        BackgroundTransparency=1,ZIndex=6,Parent=elems,
                    })
                    -- thin separator at bottom of row
                    New("Frame",{
                        Size=UDim2.new(1,-16,0,1),Position=UDim2.new(0,8,1,-1),
                        BackgroundColor3=T.BorderDm,BackgroundTransparency=0.5,
                        BorderSizePixel=0,ZIndex=6,Parent=r,
                    })
                    return r
                end

                -- left label inside a row
                local function RowLbl(row,text)
                    New("TextLabel",{
                        Text=text,Font=Enum.Font.Gotham,TextSize=11,
                        TextColor3=T.TextPrim,TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,10,0,0),Size=UDim2.new(0.55,0,1,0),
                        BackgroundTransparency=1,ZIndex=7,Parent=row,
                    })
                end

                local SEC={_T=T,_elems=elems}

                -- AddLabel
                function SEC:AddLabel(text)
                    local r=Row()
                    New("TextLabel",{
                        Text=text,Font=Enum.Font.Gotham,TextSize=11,
                        TextColor3=T.TextSec,TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-20,1,0),
                        BackgroundTransparency=1,ZIndex=7,Parent=r,
                    })
                end

                -- AddButton
                function SEC:AddButton(text,cb)
                    local r=Row()
                    local btn=New("TextButton",{
                        Text="",Size=UDim2.new(1,0,1,0),
                        BackgroundTransparency=1,AutoButtonColor=false,ZIndex=7,Parent=r,
                    })
                    New("TextLabel",{
                        Text=text,Font=Enum.Font.Gotham,TextSize=11,
                        TextColor3=T.TextPrim,TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-28,1,0),
                        BackgroundTransparency=1,ZIndex=8,Parent=btn,
                    })
                    New("TextLabel",{
                        Text="›",Font=Enum.Font.GothamBold,TextSize=14,TextColor3=T.TextMut,
                        AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                        Size=UDim2.new(0,12,1,0),BackgroundTransparency=1,ZIndex=8,Parent=btn,
                    })
                    btn.MouseEnter:Connect(function()
                        Tw(r,{BackgroundColor3=T.SurfHov,BackgroundTransparency=0},0.1):Play()
                    end)
                    btn.MouseLeave:Connect(function()
                        Tw(r,{BackgroundTransparency=1},0.1):Play()
                    end)
                    btn.MouseButton1Click:Connect(function() task.spawn(cb) end)
                end

                -- AddToggle  (no real logic needed per request — just visual)
                function SEC:AddToggle(text, default)
                    local on=default or false
                    local r=Row(); RowLbl(r,text)
                    local track=New("Frame",{
                        Size=UDim2.new(0,32,0,17),
                        AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=on and T.Accent or T.ChkOff,
                        BorderSizePixel=0,ZIndex=8,Parent=r,
                    })
                    Crn(9,track); Stk(T.Border,1,track)
                    local knob=New("Frame",{
                        Size=UDim2.new(0,11,0,11),AnchorPoint=Vector2.new(0,0.5),
                        Position=on and UDim2.new(1,-14,0.5,0) or UDim2.new(0,3,0.5,0),
                        BackgroundColor3=Color3.new(1,1,1),ZIndex=9,Parent=track,
                    })
                    Crn(6,knob)
                    -- visual-only click (no callback needed per request)
                    local clickable=New("TextButton",{
                        Text="",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                        AutoButtonColor=false,ZIndex=10,Parent=track,
                    })
                    clickable.MouseButton1Click:Connect(function()
                        on=not on
                        Tw(track,{BackgroundColor3=on and T.Accent or T.ChkOff},0.14):Play()
                        Tw(knob,{Position=on and UDim2.new(1,-14,0.5,0) or UDim2.new(0,3,0.5,0)},0.14):Play()
                    end)
                    return {Get=function(_) return on end}
                end

                -- AddSlider  (visual only)
                function SEC:AddSlider(text, mn, mx, def)
                    local val=math.clamp(def or mn,mn,mx)
                    local r=Row(44); RowLbl(r,text)
                    local valLbl=New("TextLabel",{
                        Text=tostring(val),Font=Enum.Font.GothamBold,TextSize=10,
                        TextColor3=T.Accent,TextXAlignment=Enum.TextXAlignment.Right,
                        AnchorPoint=Vector2.new(1,0),Position=UDim2.new(1,-10,0,0),
                        Size=UDim2.new(0,40,0,22),BackgroundTransparency=1,ZIndex=8,Parent=r,
                    })
                    local bg=New("Frame",{
                        Size=UDim2.new(1,-20,0,3),Position=UDim2.new(0,10,0,32),
                        BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=8,Parent=r,
                    })
                    Crn(2,bg)
                    local fill=New("Frame",{
                        Size=UDim2.new((val-mn)/(mx-mn),0,1,0),
                        BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=9,Parent=bg,
                    })
                    Crn(2,fill)
                    local knob=New("Frame",{
                        Size=UDim2.new(0,9,0,9),AnchorPoint=Vector2.new(0.5,0.5),
                        Position=UDim2.new((val-mn)/(mx-mn),0,0.5,0),
                        BackgroundColor3=Color3.new(1,1,1),ZIndex=10,Parent=bg,
                    })
                    Crn(5,knob); Stk(T.Accent,2,knob)
                    -- functional drag
                    local drag=false
                    bg.InputBegan:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
                    end)
                    UIS.InputEnded:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
                    end)
                    UIS.InputChanged:Connect(function(i)
                        if not drag or i.UserInputType~=Enum.UserInputType.MouseMovement then return end
                        local rel=math.clamp((i.Position.X-bg.AbsolutePosition.X)/bg.AbsoluteSize.X,0,1)
                        val=math.floor(mn+(mx-mn)*rel)
                        fill.Size=UDim2.new(rel,0,1,0)
                        knob.Position=UDim2.new(rel,0,0.5,0)
                        valLbl.Text=tostring(val)
                    end)
                    return {Get=function(_) return val end}
                end

                -- AddDropdown
                function SEC:AddDropdown(text,options,default)
                    local sel=default or options[1]; local open=false
                    local r=Row(); RowLbl(r,text)
                    local dBtn=New("TextButton",{
                        Text="",Size=UDim2.new(0.44,0,0,20),
                        AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=T.Surface,AutoButtonColor=false,ZIndex=8,Parent=r,
                    })
                    Crn(4,dBtn); Stk(T.Border,1,dBtn)
                    local selLbl=New("TextLabel",{
                        Text=sel,Font=Enum.Font.Gotham,TextSize=10,TextColor3=T.TextPrim,
                        TextXAlignment=Enum.TextXAlignment.Left,
                        Position=UDim2.new(0,6,0,0),Size=UDim2.new(1,-18,1,0),
                        BackgroundTransparency=1,ZIndex=9,Parent=dBtn,
                    })
                    local arrow=New("TextLabel",{
                        Text="▾",Font=Enum.Font.GothamBold,TextSize=8,TextColor3=T.TextMut,
                        AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-4,0.5,0),
                        Size=UDim2.new(0,10,1,0),BackgroundTransparency=1,ZIndex=9,Parent=dBtn,
                    })
                    local panH=math.min(#options,6)*24+6
                    local panel=New("Frame",{
                        Size=UDim2.new(0.44,0,0,panH),AnchorPoint=Vector2.new(1,0),
                        Position=UDim2.new(1,-10,1,2),BackgroundColor3=T.Panel,
                        BorderSizePixel=0,Visible=false,ZIndex=60,ClipsDescendants=true,Parent=r,
                    })
                    Crn(5,panel); Stk(T.Border,1,panel)
                    local pScr=New("ScrollingFrame",{
                        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                        BorderSizePixel=0,ScrollBarThickness=2,ScrollBarImageColor3=T.Scroll,
                        CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
                        ZIndex=61,Parent=panel,
                    })
                    VList(pScr,0); Pad(4,4,3,3,pScr)
                    local function buildOpts()
                        for _,c in ipairs(pScr:GetChildren()) do
                            if c:IsA("TextButton") then c:Destroy() end
                        end
                        for _,opt in ipairs(options) do
                            local ob=New("TextButton",{
                                Text=opt,Font=Enum.Font.Gotham,TextSize=10,
                                TextColor3=opt==sel and T.Accent or T.TextPrim,
                                TextXAlignment=Enum.TextXAlignment.Left,
                                Size=UDim2.new(1,0,0,24),BackgroundColor3=T.SurfHov,
                                BackgroundTransparency=1,AutoButtonColor=false,ZIndex=62,Parent=pScr,
                            })
                            Crn(3,ob); Pad(8,8,0,0,ob)
                            ob.MouseEnter:Connect(function() Tw(ob,{BackgroundTransparency=0},0.1):Play() end)
                            ob.MouseLeave:Connect(function() Tw(ob,{BackgroundTransparency=1},0.1):Play() end)
                            ob.MouseButton1Click:Connect(function()
                                sel=opt;selLbl.Text=opt
                                open=false;panel.Visible=false
                                Tw(arrow,{Rotation=0},0.14):Play()
                                buildOpts()
                            end)
                        end
                    end
                    buildOpts()
                    dBtn.MouseButton1Click:Connect(function()
                        open=not open;panel.Visible=open
                        Tw(arrow,{Rotation=open and 180 or 0},0.14):Play()
                    end)
                    return {Get=function(_) return sel end}
                end

                -- AddTextbox
                function SEC:AddTextbox(text,placeholder)
                    local r=Row(); RowLbl(r,text)
                    local box=New("TextBox",{
                        PlaceholderText=placeholder or "",Text="",
                        Font=Enum.Font.Gotham,TextSize=10,
                        TextColor3=T.TextPrim,PlaceholderColor3=T.TextMut,
                        TextXAlignment=Enum.TextXAlignment.Left,
                        Size=UDim2.new(0.44,0,0,20),AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),BackgroundColor3=T.Surface,
                        BorderSizePixel=0,ClearTextOnFocus=false,ZIndex=8,Parent=r,
                    })
                    Crn(4,box)
                    local bs=New("UIStroke",{Color=T.Border,Thickness=1,Parent=box})
                    Pad(6,6,0,0,box)
                    box.Focused:Connect(function()
                        Tw(box,{BackgroundColor3=T.SurfHov},0.12):Play(); bs.Color=T.Accent
                    end)
                    box.FocusLost:Connect(function()
                        Tw(box,{BackgroundColor3=T.Surface},0.12):Play(); bs.Color=T.Border
                    end)
                    return {Get=function(_) return box.Text end}
                end

                -- AddKeybind  (registers in KB list, functional)
                function SEC:AddKeybind(text, default, cb)
                    local key=default; local binding=false
                    local r=Row(); RowLbl(r,text)
                    local kBtn=New("TextButton",{
                        Text=key and key.Name or "None",
                        Font=Enum.Font.GothamBold,TextSize=9,TextColor3=T.Accent,
                        Size=UDim2.new(0.44,0,0,20),AnchorPoint=Vector2.new(1,0.5),
                        Position=UDim2.new(1,-10,0.5,0),BackgroundColor3=T.Surface,
                        AutoButtonColor=false,ZIndex=8,Parent=r,
                    })
                    Crn(4,kBtn); Stk(T.Border,1,kBtn)
                    local kbE=KBAdd(text,key)
                    kBtn.MouseButton1Click:Connect(function()
                        binding=true; kBtn.Text="..."; kBtn.TextColor3=T.Warning
                    end)
                    UIS.InputBegan:Connect(function(i,gp)
                        if binding and not gp then
                            binding=false; key=i.KeyCode
                            kBtn.Text=key.Name; kBtn.TextColor3=T.Accent
                            KBUpdate(kbE,key)
                        elseif not binding and key and i.KeyCode==key and cb then
                            task.spawn(cb,key)
                        end
                    end)
                    return {Get=function(_) return key end}
                end

                -- AddColorPicker
                function SEC:AddColorPicker(text,default,cb)
                    local color=default or Color3.fromRGB(255,50,50)
                    local open=false; local h,s,v=color:ToHSV()
                    local r=Row(); RowLbl(r,text)
                    local sw=New("TextButton",{
                        Text="",Size=UDim2.new(0,26,0,16),
                        AnchorPoint=Vector2.new(1,0.5),Position=UDim2.new(1,-10,0.5,0),
                        BackgroundColor3=color,AutoButtonColor=false,ZIndex=8,Parent=r,
                    })
                    Crn(4,sw); Stk(T.Border,1,sw)
                    local pp=New("Frame",{
                        Size=UDim2.new(0,155,0,130),AnchorPoint=Vector2.new(1,0),
                        Position=UDim2.new(1,-10,1,4),BackgroundColor3=T.Panel,
                        BorderSizePixel=0,Visible=false,ZIndex=70,Parent=r,
                    })
                    Crn(7,pp); Stk(T.Border,1,pp); Pad(7,7,7,7,pp)
                    local hBar=New("ImageLabel",{
                        Image="rbxassetid://2615689002",Size=UDim2.new(1,0,0,12),
                        BackgroundTransparency=1,ZIndex=71,Parent=pp,
                    })
                    Crn(4,hBar)
                    local hC=New("Frame",{
                        Size=UDim2.new(0,4,1,4),AnchorPoint=Vector2.new(0.5,0.5),
                        Position=UDim2.new(h,0,0.5,0),BackgroundColor3=Color3.new(1,1,1),
                        ZIndex=72,Parent=hBar,
                    })
                    Crn(2,hC)
                    local svC=New("ImageLabel",{
                        Image="rbxassetid://2615689003",Size=UDim2.new(1,0,0,82),
                        Position=UDim2.new(0,0,0,18),BackgroundColor3=Color3.fromHSV(h,1,1),
                        ZIndex=71,Parent=pp,
                    })
                    Crn(4,svC)
                    local svK=New("Frame",{
                        Size=UDim2.new(0,8,0,8),AnchorPoint=Vector2.new(0.5,0.5),
                        Position=UDim2.new(s,0,1-v,0),BackgroundColor3=Color3.new(1,1,1),
                        ZIndex=72,Parent=svC,
                    })
                    Crn(4,svK); Stk(Color3.new(0,0,0),1,svK)
                    local function upd()
                        color=Color3.fromHSV(h,s,v)
                        sw.BackgroundColor3=color
                        svC.BackgroundColor3=Color3.fromHSV(h,1,1)
                        hC.Position=UDim2.new(h,0,0.5,0)
                        svK.Position=UDim2.new(s,0,1-v,0)
                        if cb then task.spawn(cb,color) end
                    end
                    local dH,dSV=false,false
                    hBar.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dH=true end end)
                    svC.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dSV=true end end)
                    UIS.InputEnded:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then dH=false;dSV=false end
                    end)
                    UIS.InputChanged:Connect(function(i)
                        if i.UserInputType~=Enum.UserInputType.MouseMovement then return end
                        if dH then h=math.clamp((i.Position.X-hBar.AbsolutePosition.X)/hBar.AbsoluteSize.X,0,1);upd()
                        elseif dSV then
                            s=math.clamp((i.Position.X-svC.AbsolutePosition.X)/svC.AbsoluteSize.X,0,1)
                            v=1-math.clamp((i.Position.Y-svC.AbsolutePosition.Y)/svC.AbsoluteSize.Y,0,1);upd()
                        end
                    end)
                    sw.MouseButton1Click:Connect(function() open=not open;pp.Visible=open end)
                    return {Get=function(_) return color end}
                end

                -- AddDivider
                function SEC:AddDivider(labelText)
                    local r=New("Frame",{Size=UDim2.new(1,0,0,15),BackgroundTransparency=1,ZIndex=6,Parent=elems})
                    New("Frame",{
                        Size=UDim2.new(1,-16,0,1),Position=UDim2.new(0,8,0.5,0),
                        BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=7,Parent=r,
                    })
                    if labelText and labelText~="" then
                        New("TextLabel",{
                            Text=labelText,Font=Enum.Font.GothamBold,TextSize=8,
                            TextColor3=T.TextMut,TextXAlignment=Enum.TextXAlignment.Center,
                            AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(0.5,0,0.5,0),
                            Size=UDim2.new(0.55,0,1,0),BackgroundColor3=T.Card,
                            ZIndex=8,Parent=r,
                        })
                    end
                end

                return SEC
            end  -- AddSection
            return page
        end  -- AddPage
        return tab
    end  -- AddTab

    -- ════════════════════════════════════════════════════════
    --  AddSettingsTab
    -- ════════════════════════════════════════════════════════
    function Win:AddSettingsTab()
        local T    = self._T
        local sTab = self:AddTab("Settings")
        local sPage= sTab:AddPage("General")
        local sSec = sPage:AddSection("Toggle Key")
        sSec:AddLabel("Click badge, then press a new key.")

        -- manual keybind row
        local r=New("Frame",{
            Size=UDim2.new(1,0,0,30),BackgroundTransparency=1,ZIndex=6,
            Parent=sSec._elems,
        })
        New("TextLabel",{
            Text="UI Toggle",Font=Enum.Font.Gotham,TextSize=11,
            TextColor3=T.TextPrim,TextXAlignment=Enum.TextXAlignment.Left,
            Position=UDim2.new(0,10,0,0),Size=UDim2.new(0.55,0,1,0),
            BackgroundTransparency=1,ZIndex=7,Parent=r,
        })
        local tBtn=New("TextButton",{
            Text=self._tKey.Name,Font=Enum.Font.GothamBold,TextSize=9,TextColor3=T.Accent,
            Size=UDim2.new(0.44,0,0,20),AnchorPoint=Vector2.new(1,0.5),
            Position=UDim2.new(1,-10,0.5,0),BackgroundColor3=T.Surface,
            AutoButtonColor=false,ZIndex=8,Parent=r,
        })
        Crn(4,tBtn); Stk(T.Border,1,tBtn)
        local kbE=KBAdd("UI Toggle",self._tKey)
        local binding=false
        tBtn.MouseButton1Click:Connect(function()
            binding=true; tBtn.Text="..."; tBtn.TextColor3=T.Warning
        end)
        UIS.InputBegan:Connect(function(i,gp)
            if binding and not gp then
                binding=false
                self:SetToggleKey(i.KeyCode)
                tBtn.Text=i.KeyCode.Name; tBtn.TextColor3=T.Accent
                KBUpdate(kbE,i.KeyCode)
            end
        end)
        return sTab
    end

