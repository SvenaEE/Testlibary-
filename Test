	G2L_alphaGrad["BackgroundColor3"] = Color3.fromRGB(255, 0, 0);
	G2L_alphaGrad["BorderSizePixel"]  = 0;
	G2L_alphaGrad["ZIndex"]           = 2;
	local G2L_alphaGradc = Instance.new("UICorner", G2L_alphaGrad);
	G2L_alphaGradc["CornerRadius"] = UDim.new(0, 4);
	local G2L_alphaGradg = Instance.new("UIGradient", G2L_alphaGrad);
	G2L_alphaGradg["Transparency"] = NumberSequence.new{
		NumberSequenceKeypoint.new(0, 0);
		NumberSequenceKeypoint.new(1, 1);
