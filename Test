			ZIndex           = 604,
		})

		TweenService:Create(prog, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
			Size = UDim2.new(0, 0, 0, 2)
		}):Play()

		card.Position = UDim2.new(1, 10, 0, 0)
		tween(card, { Position = UDim2.new(0, 0, 0, 0) }, 0.25)

		task.delay(duration, function()
			tween(card, { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0) }, 0.2)
			task.delay(0.22, function() card:Destroy() end)
		end)
	end

	return Win
end

return UILib
