			local G2L_segtc = Instance.new("UICorner", G2L_seg);
			G2L_segtc["CornerRadius"] = UDim.new(0, 4);
		elseif i == #hueColors - 1 then
			local G2L_segbc = Instance.new("UICorner", G2L_seg);
			G2L_segbc["CornerRadius"] = UDim.new(0, 4);
