	-- Alpha cursor
	local G2L_alphacur = Instance.new("Frame", G2L_alphabar);
	G2L_alphacur["Name"]             = [[AlphaCursor]];
	G2L_alphacur["Size"]             = UDim2.new(0, 3, 1, 6);
	G2L_alphacur["AnchorPoint"]      = Vector2.new(0.5, 0.5);
	G2L_alphacur["Position"]         = UDim2.new(0, 0, 0.5, 0);
	G2L_alphacur["BackgroundColor3"] = Color3.fromRGB(255, 255, 255);
	G2L_alphacur["BorderSizePixel"]  = 0;
	G2L_alphacur["ZIndex"]           = 6;
	local G2L_alphacurc = Instance.new("UICorner", G2L_alphacur);
	G2L_alphacurc["CornerRadius"] = UDim.new(1, 0);
	local G2L_alphacurs = Instance.new("UIStroke", G2L_alphacur);
	G2L_alphacurs["Thickness"] = 1;
	G2L_alphacurs["Color"]     = Color3.fromRGB(0, 0, 0);

	-- ── RGB TextBox input ──────────────────────────────────────────────────────
	local G2L_inputBox = Instance.new("TextBox", G2L_wrap);
	G2L_inputBox["Name"]               = [[RGBInput]];
	G2L_inputBox["Size"]               = UDim2.new(1, -30, 0, 22);
	G2L_inputBox["Position"]           = UDim2.new(0, 6, 0, 164);
	G2L_inputBox["BackgroundColor3"]   = Color3.fromRGB(20, 20, 28);
	G2L_inputBox["BorderSizePixel"]    = 0;
	G2L_inputBox["FontFace"]           = G2L["FONT_JOSEFIN"];
	G2L_inputBox["TextSize"]           = 12;
	G2L_inputBox["TextColor3"]         = Color3.fromRGB(200, 200, 220);
	G2L_inputBox["PlaceholderText"]    = [[255, 255, 255]];
	G2L_inputBox["PlaceholderColor3"]  = Color3.fromRGB(100, 100, 120);
	G2L_inputBox["Text"]               = [[255, 255, 255]];
	G2L_inputBox["ClearTextOnFocus"]   = false;
	G2L_inputBox["TextXAlignment"]     = Enum.TextXAlignment.Left;
	local G2L_ibc = Instance.new("UICorner", G2L_inputBox);
	G2L_ibc["CornerRadius"] = UDim.new(0, 4);
	local G2L_ibp = Instance.new("UIPadding", G2L_inputBox);
	G2L_ibp["PaddingLeft"] = UDim.new(0, 6);
	local G2L_ibs = Instance.new("UIStroke", G2L_inputBox);
	G2L_ibs["Thickness"] = 1;
	G2L_ibs["Color"]     = Color3.fromRGB(50, 50, 70);

	-- Alpha percentage label
	local G2L_alphaLbl = Instance.new("TextLabel", G2L_wrap);
	G2L_alphaLbl["Name"]               = [[AlphaLabel]];
	G2L_alphaLbl["Size"]               = UDim2.new(0, 22, 0, 22);
	G2L_alphaLbl["Position"]           = UDim2.new(1, -22, 0, 164);
	G2L_alphaLbl["BackgroundTransparency"] = 1;
	G2L_alphaLbl["BorderSizePixel"]    = 0;
	G2L_alphaLbl["FontFace"]           = G2L["FONT_JOSEFIN"];
	G2L_alphaLbl["TextSize"]           = 10;
	G2L_alphaLbl["TextColor3"]         = Color3.fromRGB(150, 150, 170);
	G2L_alphaLbl["Text"]               = [[100%]];

	-- ── Internal state ─────────────────────────────────────────────────────────
	local h, s, v = Color3.toHSV(defaultColor);
	local alpha    = 1;  -- 1 = fully opaque, 0 = fully transparent

	local function updateFromHSV(fireCallback)
		local col = Color3.fromHSV(h, s, v);
		G2L_canvas["BackgroundColor3"]   = Color3.fromHSV(h, 1, 1);
		G2L_alphaGrad["BackgroundColor3"]= Color3.fromHSV(h, 1, 1);
		local r = math.round(col.R*255);
		local g = math.round(col.G*255);
		local b = math.round(col.B*255);
		G2L_inputBox["Text"] = r .. [[, ]] .. g .. [[, ]] .. b;
		G2L_alphaLbl["Text"] = math.round(alpha * 100) .. [[%]];
		if fireCallback ~= false and onChange then onChange(col, alpha) end;
	end;

	local function placeSVCursor()
		G2L_dot["Position"] = UDim2.new(s, 0, 1 - v, 0);
	end;
	local function placeHueCursor()
		G2L_huecur["Position"] = UDim2.new(0, -3, 1 - h, 0);
	end;
	local function placeAlphaCursor()
		G2L_alphacur["Position"] = UDim2.new(alpha, 0, 0.5, 0);
	end;

	placeSVCursor();
	placeHueCursor();
	placeAlphaCursor();
	updateFromHSV(false);

	-- ── Drag logic ─────────────────────────────────────────────────────────────
	local svDragging    = false;
	local hueDragging   = false;
	local alphaDragging = false;

	G2L_canvas.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = true end;
	end);
	G2L_canvas.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then svDragging = false end;
	end);
	G2L_huebar.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then hueDragging = true end;
	end);
	G2L_huebar.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then hueDragging = false end;
	end);
	G2L_alphabar.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then alphaDragging = true end;
	end);
	G2L_alphabar.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then alphaDragging = false end;
	end);

	G2L["svc_run"].Heartbeat:Connect(function()
		if not G2L_wrap.Visible then return end;
		local mp = G2L["svc_input"]:GetMouseLocation();

		if svDragging then
			local ap = G2L_canvas.AbsolutePosition;
			local sz = G2L_canvas.AbsoluteSize;
			s = math.clamp((mp.X - ap.X) / sz.X, 0, 1);
			v = 1 - math.clamp((mp.Y - ap.Y) / sz.Y, 0, 1);
			placeSVCursor();
			updateFromHSV();
		end;

		if hueDragging then
			local ap = G2L_huebar.AbsolutePosition;
			local sz = G2L_huebar.AbsoluteSize;
			h = 1 - math.clamp((mp.Y - ap.Y) / sz.Y, 0, 1);
			placeHueCursor();
			updateFromHSV();
		end;

		if alphaDragging then
			local ap = G2L_alphabar.AbsolutePosition;
			local sz = G2L_alphabar.AbsoluteSize;
			alpha = math.clamp((mp.X - ap.X) / sz.X, 0, 1);
			placeAlphaCursor();
			updateFromHSV();
		end;
	end);

	-- ── RGB TextBox: type values like "255, 0, 128" ────────────────────────────
	G2L_inputBox.FocusLost:Connect(function()
		local txt = G2L_inputBox.Text:gsub("%s", "");
		local r, g, b = txt:match("^(%d+),(%d+),(%d+)$");
		if r and g and b then
			r = math.clamp(tonumber(r), 0, 255);
			g = math.clamp(tonumber(g), 0, 255);
			b = math.clamp(tonumber(b), 0, 255);
			local col = Color3.fromRGB(r, g, b);
			h, s, v   = Color3.toHSV(col);
			placeSVCursor();
			placeHueCursor();
			updateFromHSV();
		else
			-- invalid input: restore current value
			local col = Color3.fromHSV(h, s, v);
			G2L_inputBox["Text"] = math.round(col.R*255)..[[, ]]..math.round(col.G*255)..[[, ]]..math.round(col.B*255);
		end;
	end);

	local function getCurrentColor()
		return Color3.fromHSV(h, s, v), alpha;
	end;

	return G2L_wrap, getCurrentColor;
end;

-- ── makeToggleColorRow: toggle row with a colored swatch that opens a picker ──
local function makeToggleColorRow(parent, label, fontSize, defaultToggle, defaultColor, onToggle, onColor)
	defaultColor = defaultColor or Color3.fromRGB(255, 255, 255);
	local state  = (defaultToggle == true);

	-- Wrapper so picker can sit below the row
	local G2L_outerWrap = Instance.new("Frame", parent);
	G2L_outerWrap["Name"]             = [[ToggleColor_]] .. label;
	G2L_outerWrap["Size"]             = UDim2.new(1, 0, 0, fontSize == 12 and 28 or 32);
	G2L_outerWrap["AutomaticSize"]    = Enum.AutomaticSize.Y;
	G2L_outerWrap["BackgroundTransparency"] = 1;
	G2L_outerWrap["BorderSizePixel"]  = 0;
	G2L_outerWrap["LayoutOrder"]      = #parent:GetChildren();
	local G2L_owl = Instance.new("UIListLayout", G2L_outerWrap);
	G2L_owl["SortOrder"] = Enum.SortOrder.LayoutOrder;
	G2L_owl["Padding"]   = UDim.new(0, 3);

	-- Main row
	local G2L_row = Instance.new("Frame", G2L_outerWrap);
	G2L_row["Name"]             = [[Row]];
	G2L_row["Size"]             = UDim2.new(1, 0, 0, fontSize == 12 and 28 or 32);
	G2L_row["BackgroundColor3"] = fontSize == 12
		and Color3.fromRGB(18, 18, 24)
		or  Color3.fromRGB(14, 14, 19);
	G2L_row["BorderSizePixel"]  = 0;
	G2L_row["LayoutOrder"]      = 1;
	G2L_row["Active"]           = true;
	local G2L_rc = Instance.new("UICorner", G2L_row);
	G2L_rc["CornerRadius"] = UDim.new(0, fontSize == 12 and 5 or 6);
	addHoverFx(G2L_row);

	-- Label
	local G2L_lbl = Instance.new("TextLabel", G2L_row);
	G2L_lbl["Size"]                  = UDim2.new(1, -90, 1, 0);
	G2L_lbl["Position"]              = UDim2.new(0, fontSize == 12 and 8 or 10, 0, 0);
	G2L_lbl["BackgroundTransparency"] = 1;
	G2L_lbl["BorderSizePixel"]       = 0;
	G2L_lbl["FontFace"]              = G2L["FONT_JOSEFIN"];
	G2L_lbl["TextSize"]              = fontSize;
	G2L_lbl["TextColor3"]            = fontSize == 12
		and Color3.fromRGB(180, 180, 200)
		or  Color3.fromRGB(200, 200, 215);
	G2L_lbl["TextXAlignment"]        = Enum.TextXAlignment.Left;
	G2L_lbl["Text"]                  = label;

	-- Color swatch button (left of pill)
	local G2L_swatch = Instance.new("Frame", G2L_row);
	G2L_swatch["Name"]             = [[Swatch]];
	G2L_swatch["Size"]             = UDim2.new(0, 18, 0, 18);
	G2L_swatch["Position"]         = UDim2.new(1, -66, 0.5, -9);
	G2L_swatch["BackgroundColor3"] = defaultColor;
	G2L_swatch["BorderSizePixel"]  = 0;
	local G2L_swc = Instance.new("UICorner", G2L_swatch);
	G2L_swc["CornerRadius"] = UDim.new(0, 4);
	local G2L_sws = Instance.new("UIStroke", G2L_swatch);
	G2L_sws["Thickness"] = 1.2;
	G2L_sws["Color"]     = Color3.fromRGB(80, 80, 100);

	-- Pill toggle
	local G2L_track, _, setPill = makePill(G2L_row, state);
	G2L_track["Position"] = UDim2.new(1, fontSize == 12 and -40 or -44, 0.5, -9);

	-- Color picker (below row, hidden until swatch clicked)
	local pickerOpen = false;
	local G2L_picker, getColor = makeColorPicker(G2L_outerWrap, defaultColor, function(col)
		G2L_swatch["BackgroundColor3"] = col;
		if onColor then onColor(col) end;
	end);
	G2L_picker["LayoutOrder"] = 2;

	-- Toggle pill click (left-click row)
	local function set(newState)
		state = newState;
		setPill(state);
		if onToggle then onToggle(state) end;
	end;

	G2L_row.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			set(not state);
		end;
	end);

	-- Swatch click opens/closes picker
	G2L_swatch["Active"] = true;
	G2L_swatch.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			pickerOpen = not pickerOpen;
			G2L_picker["Visible"] = pickerOpen;
			input:Handled();
		end;
	end);

	if onToggle then onToggle(state) end;
	if onColor  then onColor(defaultColor) end;

	return set, getColor;
end;

