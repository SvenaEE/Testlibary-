--  HELPERS
-- ════════════════════════════════════════════════════════════
local function Tw(obj, props, t, s, d)
    return TweenService:Create(obj, TweenInfo.new(
        t or 0.16,
        s or Enum.EasingStyle.Quart,
        d or Enum.EasingDirection.Out
    ), props)
end

local function New(cls, p)
    local o = Instance.new(cls)
    for k,v in pairs(p or {}) do if k~="Parent" then o[k]=v end end
    if p and p.Parent then o.Parent = p.Parent end
    return o
end

local function Crn(r,p)   New("UICorner",{CornerRadius=UDim.new(0,r),Parent=p}) end
local function Stk(c,t,p) New("UIStroke",{Color=c,Thickness=t or 1,Parent=p}) end
local function Pad(l,r,t,b,p)
    New("UIPadding",{PaddingLeft=UDim.new(0,l),PaddingRight=UDim.new(0,r),
        PaddingTop=UDim.new(0,t),PaddingBottom=UDim.new(0,b),Parent=p})
end
local function VList(p,gap,ha)
    New("UIListLayout",{Parent=p,SortOrder=Enum.SortOrder.LayoutOrder,
        Padding=UDim.new(0,gap or 0),
        HorizontalAlignment=ha or Enum.HorizontalAlignment.Left,
        FillDirection=Enum.FillDirection.Vertical})
end
local function HList(p,gap,va)
    New("UIListLayout",{Parent=p,SortOrder=Enum.SortOrder.LayoutOrder,
        Padding=UDim.new(0,gap or 0),
        VerticalAlignment=va or Enum.VerticalAlignment.Top,
        FillDirection=Enum.FillDirection.Horizontal})
end

