			knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			knob.BorderSizePixel  = 0
			local knobCorner = Instance.new("UICorner", knob)
			knobCorner.CornerRadius = UDim.new(1, 0)

			local tweenToggle = TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

			local function setToggle(newState, fireCallback)
				state = newState
				TweenService:Create(track, tweenToggle, {
					BackgroundColor3 = state and Color3.fromRGB(82, 82, 180) or Color3.fromRGB(40, 40, 55)
				}):Play()
				TweenService:Create(knob, tweenToggle, {
					Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6)
				}):Play()
				if fireCallback and callback then
					callback(state)
				end
			end

			-- Click anywhere on row to toggle
			row.Active = true
			row.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.Touch then
					setToggle(not state, true)
				end
			end)

			-- Fire default state callback once
			if callback then callback(state) end

			-- Return setter so Setting tab can control it externally
			return setToggle
		end

		return Tab
	end

	-- ── Built-in Setting tab toggles (added AFTER Window:Tab is defined) ─────
	-- Call Window:AddSettingToggles(settingTab) from user code, or we wire it
	-- automatically when the 6th tab (Setting) is created via a post-hook.
	-- Exposed so user can call: local settingTab = Window:Tab("Setting", true)
	-- then Window:BuildSettingToggles(settingTab)
	function Window:BuildSettingToggles(settingTab)
		-- Watermark toggle
		settingTab:AddToggle("Watermark", true, function(on)
			wmName.Visible = on
		end)

		-- FPS counter toggle
		settingTab:AddToggle("FPS Counter", true, function(on)
			fpsBadge.Visible = on
		end)

		-- Ping counter toggle
		settingTab:AddToggle("Ping Counter", true, function(on)
			pingBadge.Visible = on
		end)
	end

	return Window
end

return Library
